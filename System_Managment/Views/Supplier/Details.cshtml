@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@model ApplicationUser

<div class="relative flex h-auto w-full flex-col group/design-root overflow-x-hidden p-4">

    <h1 class="text-2xl font-bold text-center text-text-light dark:text-text-dark mb-6">ملف المستخدم</h1>

    <!-- Profile Section -->
    <div class="flex flex-col items-center">
        <div class="relative mb-4">
            @{
                string img = Model.ProfilePicture ?? "uploads/alter.png";
            }
            <div class="bg-center bg-no-repeat aspect-square bg-cover rounded-full h-32 w-32"
                 data-alt="Profile picture of @Model.FullName"
                 style="background-image: url('/files/@img');">
            </div>
            <button class="absolute bottom-1 end-1 flex h-8 w-8 items-center justify-center rounded-full bg-custom text-white shadow-md">
                <span class="material-symbols-outlined text-base">photo_camera</span>
            </button>
        </div>
        @{
            var roles = await UserManager.GetRolesAsync(new ApplicationUser { Id = Model.Id });
            var roleName = roles.FirstOrDefault() ?? "غير محدد";
            string viewedRoleName = roleName switch
            {
                "SuperAdmin" => "مسؤول",
                "Admin" => "مشرف",
                _ => "موظف"
            };
        }
        <h2 class="text-2xl font-bold text-text-light dark:text-text-dark">@Model.FullName</h2>
        <p class="text-custom dark:text-accent font-medium">@viewedRoleName</p>
    </div>

    <!-- Personal Info -->
    <div class="mt-6 space-y-4">
        <div class="rounded-lg bg-white dark:bg-gray-800 p-4 shadow-sm">
            <h3 class="mb-3 text-lg font-semibold text-text-light dark:text-text-dark">المعلومات الشخصية</h3>
            <div class="space-y-3">
                <div class="flex items-start gap-4">
                    <span class="material-symbols-outlined mt-1 text-custom dark:text-accent">person</span>
                    <div class="flex-1">
                        <p class="text-sm text-gray-500 dark:text-gray-400">الاسم الكامل</p>
                        <p class="font-medium text-text-light dark:text-text-dark">@Model.FullName</p>
                    </div>
                </div>
                <div class="flex items-start gap-4">
                    <span class="material-symbols-outlined mt-1 text-custom dark:text-accent">mail</span>
                    <div class="flex-1">
                        <p class="text-sm text-gray-500 dark:text-gray-400">البريد الإلكتروني</p>
                        <p class="font-medium text-text-light dark:text-text-dark">@Model.Email</p>
                    </div>
                </div>
                <div class="flex items-start gap-4">
                    <span class="material-symbols-outlined mt-1 text-custom dark:text-accent">phone</span>
                    <div class="flex-1">
                        <p class="text-sm text-gray-500 dark:text-gray-400">رقم الهاتف</p>
                        <p class="font-medium text-text-light dark:text-text-dark">@Model.PhoneNumber</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Account Info -->
        <div class="rounded-lg bg-white dark:bg-gray-800 p-4 shadow-sm">
            <h3 class="mb-3 text-lg font-semibold text-text-light dark:text-text-dark">معلومات الحساب</h3>
            <div class="space-y-3">
                <div class="flex items-start gap-4">
                    <span class="material-symbols-outlined mt-1 text-custom dark:text-accent">badge</span>
                    <div class="flex-1">
                        <p class="text-sm text-gray-500 dark:text-gray-400">رقم المستخدم</p>
                        <p class="font-medium text-text-light dark:text-text-dark">@Model.Id</p>
                    </div>
                </div>
                <div class="flex items-start gap-4">
                    <span class="material-symbols-outlined mt-1 text-custom dark:text-accent">schedule</span>
                    <div class="flex-1">
                        <p class="text-sm text-gray-500 dark:text-gray-400">تاريخ الانضمام</p>
                        <p class="font-medium text-text-light dark:text-text-dark">@Model.CreatedAt.ToString("dd MMMM yyyy")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
