@model IEnumerable<SupplierTransactionVM>
@using BLL.ViewModels.Transactions

@{
    ViewData["Title"] = "معاملات المورد";
    var supplier = ViewBag.Supplier as Supplier;
    var fromDate = ViewBag.FromDate as DateTime?;
    var toDate = ViewBag.ToDate as DateTime?;
    var totalPurchases = (decimal)ViewBag.TotalPurchases;
    var totalPayments = (decimal)ViewBag.TotalPayments;
    var currentBalance = (decimal)ViewBag.CurrentBalance;
}

<div class="mb-8 flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-4">
        <div class="size-12 text-primary bg-white rounded-xl shadow-sm border border-border-light p-2.5 flex items-center justify-center">
            <span class="material-symbols-outlined text-[28px]">store</span>
        </div>
        <div>
            <h1 class="text-2xl font-bold text-text-main tracking-tight">معاملات المورد</h1>
            <p class="text-sm text-text-secondary mt-1">@supplier.Name</p>
        </div>
    </div>
    <div class="flex gap-3 w-full md:w-auto">
        <a asp-controller="Supplier" asp-action="Index"
           class="flex-1 md:flex-none px-6 py-2.5 text-sm font-medium text-text-secondary bg-white border border-border-light rounded-xl hover:bg-gray-50 transition-all text-center">
            رجوع
        </a>
        <button onclick="exportTransactions()"
                class="flex-1 md:flex-none px-6 py-2.5 text-sm font-medium text-white bg-green-600 rounded-xl hover:bg-green-700 transition-all flex items-center justify-center gap-2">
            <span class="material-symbols-outlined text-[20px]">download</span>
            تصدير
        </button>
    </div>
</div>

<!-- Summary Cards -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-6">
    <div class="bg-white rounded-2xl border border-border-light shadow-sm p-6">
        <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-semibold text-text-secondary">إجمالي المشتريات</span>
            <span class="material-symbols-outlined text-purple-600 bg-purple-100 p-2 rounded-lg">shopping_cart</span>
        </div>
        <div class="text-2xl font-bold text-text-main">@totalPurchases.ToString("N2")</div>
        <div class="text-xs text-text-secondary mt-1">جنيه مصري</div>
    </div>

    <div class="bg-white rounded-2xl border border-border-light shadow-sm p-6">
        <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-semibold text-text-secondary">إجمالي المدفوعات</span>
            <span class="material-symbols-outlined text-green-600 bg-green-100 p-2 rounded-lg">payments</span>
        </div>
        <div class="text-2xl font-bold text-text-main">@totalPayments.ToString("N2")</div>
        <div class="text-xs text-text-secondary mt-1">جنيه مصري</div>
    </div>

    <div class="bg-white rounded-2xl border border-border-light shadow-sm p-6">
        <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-semibold text-text-secondary">الرصيد الحالي</span>
            <span class="material-symbols-outlined text-orange-600 bg-orange-100 p-2 rounded-lg">account_balance_wallet</span>
        </div>
        <div class="text-2xl font-bold text-text-main">@currentBalance.ToString("N2")</div>
        <div class="text-xs text-text-secondary mt-1">جنيه مصري</div>
    </div>

    <div class="bg-white rounded-2xl border border-border-light shadow-sm p-6">
        <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-semibold text-text-secondary">عدد المعاملات</span>
            <span class="material-symbols-outlined text-blue-600 bg-blue-100 p-2 rounded-lg">list</span>
        </div>
        <div class="text-2xl font-bold text-text-main">@Model.Count()</div>
        <div class="text-xs text-text-secondary mt-1">معاملة</div>
    </div>
</div>

<!-- Filter Section -->
<div class="bg-white rounded-2xl border border-border-light shadow-sm p-6 mb-6">
    <h3 class="text-lg font-bold text-text-main mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-primary">filter_alt</span>
        تصفية حسب التاريخ
    </h3>

    <form method="get" asp-action="Transactions" class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <input type="hidden" name="id" value="@supplier.Id" />

        <div>
            <label class="text-sm font-semibold text-text-secondary mb-2 block">من تاريخ</label>
            <input type="date" name="fromDate" value="@fromDate?.ToString("yyyy-MM-dd")"
                   class="w-full h-11 rounded-xl border-border-light bg-background-light text-text-main focus:border-primary focus:ring-primary px-3" />
        </div>

        <div>
            <label class="text-sm font-semibold text-text-secondary mb-2 block">إلى تاريخ</label>
            <input type="date" name="toDate" value="@toDate?.ToString("yyyy-MM-dd")"
                   class="w-full h-11 rounded-xl border-border-light bg-background-light text-text-main focus:border-primary focus:ring-primary px-3" />
        </div>

        <div class="flex items-end gap-2">
            <button type="submit"
                    class="flex-1 h-11 px-6 bg-primary hover:bg-primary-dark text-white font-bold rounded-xl transition-all flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-[20px]">search</span>
                بحث
            </button>
            <a asp-action="Transactions" asp-route-id="@supplier.Id"
               class="h-11 px-4 bg-gray-200 hover:bg-gray-300 text-text-main font-bold rounded-xl transition-all flex items-center justify-center">
                <span class="material-symbols-outlined text-[20px]">refresh</span>
            </a>
        </div>
    </form>
</div>

<!-- Transactions Table -->
<div class="bg-white rounded-2xl border border-border-light shadow-sm overflow-hidden">
    @if (Model != null && Model.Any())
    {
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-gray-50 border-b border-border-light">
                    <tr>
                        <th class="py-4 px-6 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">التاريخ</th>
                        <th class="py-4 px-6 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">رقم الفاتورة</th>
                        <th class="py-4 px-6 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">نوع المعاملة</th>
                        <th class="py-4 px-6 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الرصيد قبل</th>
                        <th class="py-4 px-6 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">المبلغ</th>
                        <th class="py-4 px-6 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الرصيد بعد</th>
                        <th class="py-4 px-6 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الوصف</th>
                        <th class="py-4 px-6 text-center text-xs font-bold text-text-secondary uppercase tracking-wider">الإجراءات</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border-light">
                    @foreach (var transaction in Model)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors">
                            <td class="py-4 px-6 text-sm text-text-secondary">
                                @transaction.TransactionDate.ToString("dd/MM/yyyy")
                            </td>
                            <td class="py-4 px-6 text-sm font-bold text-primary">
                                @transaction.ReferenceNumber
                            </td>
                            <td class="py-4 px-6 text-sm">
                                @if (transaction.TransactionType == "Purchase")
                                {
                                    <span class="inline-flex items-center gap-1 px-3 py-1 bg-purple-100 text-purple-800 text-xs font-bold rounded-full">
                                        <span class="material-symbols-outlined text-[14px]">shopping_cart</span>
                                        شراء
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1 px-3 py-1 bg-green-100 text-green-800 text-xs font-bold rounded-full">
                                        <span class="material-symbols-outlined text-[14px]">payments</span>
                                        دفع
                                    </span>
                                }
                            </td>
                            <td class="py-4 px-6 text-sm text-text-secondary">
                                @transaction.BalanceBefore.ToString("N2") جنيه
                            </td>
                            <td class="py-4 px-6 text-sm font-bold @(transaction.AmountChanged >= 0 ? "text-red-600" : "text-green-600")">
                                @(transaction.AmountChanged >= 0 ? "+" : "")@transaction.AmountChanged.ToString("N2") جنيه
                            </td>
                            <td class="py-4 px-6 text-sm font-medium text-text-main">
                                @transaction.BalanceAfter.ToString("N2") جنيه
                            </td>
                            <td class="py-4 px-6 text-sm text-text-secondary">
                                @transaction.Description
                            </td>
                            <td class="py-4 px-6 text-center">
                                @if (transaction.InvoiceId > 0)
                                {
                                    <a asp-controller="Invoice" asp-action="Details" asp-route-id="@transaction.InvoiceId"
                                       class="text-primary hover:text-primary-dark p-2 hover:bg-primary/10 rounded-lg transition-all inline-flex items-center"
                                       title="عرض الفاتورة">
                                        <span class="material-symbols-outlined text-[20px]">visibility</span>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="p-12 text-center">
            <span class="material-symbols-outlined text-gray-400 text-6xl mb-4">store</span>
            <p class="text-text-secondary text-lg font-medium mb-2">لا توجد معاملات</p>
            <p class="text-text-secondary text-sm">لم يتم تسجيل أي معاملات لهذا المورد في الفترة المحددة</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        function exportTransactions() {
            const supplierId = @supplier.Id;
            const fromDate = '@fromDate?.ToString("yyyy-MM-dd")';
            const toDate = '@toDate?.ToString("yyyy-MM-dd")';

            let url = `/Supplier/ExportTransactions?id=${supplierId}`;
            if (fromDate) url += `&fromDate=${fromDate}`;
            if (toDate) url += `&toDate=${toDate}`;

            window.location.href = url;
        }
    </script>
}