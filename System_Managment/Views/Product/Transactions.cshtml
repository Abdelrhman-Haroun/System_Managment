@model IEnumerable<ProductTransactionVM>
@using BLL.ViewModels.Transactions
@using DAL.Models

@{
    ViewData["Title"] = "حركة المنتج";
    var product = ViewBag.Product as Product;
    var fromDate = ViewBag.FromDate as DateTime?;
    var toDate = ViewBag.ToDate as DateTime?;
    var totalPurchases = (decimal)ViewBag.TotalPurchases;
    var totalSales = (decimal)ViewBag.TotalSales;
    var totalInternalUsage = (decimal)ViewBag.TotalInternalUsage;
    var totalPurchaseValue = (decimal)ViewBag.TotalPurchaseValue;
    var totalSalesValue = (decimal)ViewBag.TotalSalesValue;
    var totalInternalUsageValue = (decimal)ViewBag.TotalInternalUsageValue;
    var currentStock = (decimal)ViewBag.CurrentStock;
    var hasDateFilter = (bool)(ViewBag.HasDateFilter ?? false);
    var openingBalance = (decimal)(ViewBag.OpeningBalance ?? currentStock);
    var closingBalance = (decimal)(ViewBag.ClosingBalance ?? currentStock);
    var productType = (int)ViewBag.ProductType;
}

<div class="mb-8 flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-4">
        <div class="size-12 text-primary bg-white rounded-xl shadow-sm border border-border-light p-2.5 flex items-center justify-center">
            <span class="material-symbols-outlined text-[28px]">inventory_2</span>
        </div>
        <div>
            <h1 class="text-2xl font-bold text-text-main tracking-tight">حركة المنتج</h1>
            <p class="text-sm text-text-secondary mt-1">@product.Name</p>
        </div>
    </div>
    <div class="flex gap-3 w-full md:w-auto">
        <a asp-controller="Product" asp-action="Index"
           class="flex-1 md:flex-none px-6 py-2.5 text-sm font-medium text-text-secondary bg-white border border-border-light rounded-xl hover:bg-gray-50 transition-all text-center">
            رجوع
        </a>
        <button onclick="exportTransactions()"
                class="flex-1 md:flex-none px-6 py-2.5 text-sm font-medium text-white bg-green-600 rounded-xl hover:bg-green-700 transition-all flex items-center justify-center gap-2">
            <span class="material-symbols-outlined text-[20px]">download</span>
            تصدير
        </button>
    </div>
</div>

<!-- Filter Section -->
<div class="bg-white rounded-2xl border border-border-light shadow-sm p-6 mb-6">
    <h3 class="text-lg font-bold text-text-main mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-primary">filter_alt</span>
        تصفية حسب التاريخ
    </h3>

    <form method="get" asp-action="Transactions" class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <input type="hidden" name="id" value="@product.Id" />

        <div>
            <label class="text-sm font-semibold text-text-secondary mb-2 block">من تاريخ</label>
            <input type="date" name="fromDate" value="@fromDate?.ToString("yyyy-MM-dd")"
                   class="w-full h-11 rounded-xl border-border-light bg-background-light text-text-main focus:border-primary focus:ring-primary px-3" />
        </div>

        <div>
            <label class="text-sm font-semibold text-text-secondary mb-2 block">إلى تاريخ</label>
            <input type="date" name="toDate" value="@toDate?.ToString("yyyy-MM-dd")"
                   class="w-full h-11 rounded-xl border-border-light bg-background-light text-text-main focus:border-primary focus:ring-primary px-3" />
        </div>

        <div class="flex items-end gap-2">
            <button type="submit"
                    class="flex-1 h-11 px-6 bg-primary hover:bg-primary-dark text-white font-bold rounded-xl transition-all flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-[20px]">search</span>
                بحث
            </button>
            <a asp-action="Transactions" asp-route-id="@product.Id"
               class="h-11 px-4 bg-gray-200 hover:bg-gray-300 text-text-main font-bold rounded-xl transition-all flex items-center justify-center">
                <span class="material-symbols-outlined text-[20px]">refresh</span>
            </a>
        </div>
    </form>
</div>

@if (hasDateFilter)
{
    <div class="mb-6 flex flex-wrap items-center gap-3 rounded-2xl border border-primary/15 bg-primary/5 px-5 py-4 text-sm">
        <span class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1.5 font-bold text-primary border border-primary/10">
            <span class="material-symbols-outlined text-[18px]">filter_alt</span>
            التصفية مطبقة على السجل والملخص
        </span>
        <span class="text-text-secondary">رصيد بداية الفترة: <strong class="text-text-main">@openingBalance.ToString("N2")</strong></span>
        <span class="text-text-secondary">رصيد نهاية الفترة: <strong class="text-text-main">@closingBalance.ToString("N2")</strong></span>
    </div>
}

<!-- Summary Cards - NOW WITH 6 CARDS -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-4 mb-6">
    <div class="bg-white rounded-2xl border border-border-light shadow-sm p-6">
        <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-semibold text-text-secondary">المخزون الحالي</span>
            <span class="material-symbols-outlined text-blue-600 bg-blue-100 p-2 rounded-lg">inventory</span>
        </div>
        <div class="text-2xl font-bold text-text-main">@(hasDateFilter ? closingBalance.ToString("N2") : currentStock.ToString("N2"))</div>
        <div class="text-xs text-text-secondary mt-1">@(hasDateFilter ? "رصيد نهاية الفترة" : "الرصيد الحالي") - @(ProductTypeExtensions.IsCountType(productType) ? "قطعة" : "كجم")</div>
    </div>

    <div class="bg-white rounded-2xl border border-border-light shadow-sm p-6">
        <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-semibold text-text-secondary">إجمالي المشتريات</span>
            <span class="material-symbols-outlined text-green-600 bg-green-100 p-2 rounded-lg">add_circle</span>
        </div>
        <div class="text-2xl font-bold text-text-main">@totalPurchases.ToString("N2")</div>
        <div class="text-xs text-text-secondary mt-1">@(ProductTypeExtensions.IsCountType(productType) ? "قطعة" : "كجم")</div>
    </div>

    <div class="bg-white rounded-2xl border border-border-light shadow-sm p-6">
        <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-semibold text-text-secondary">إجمالي المبيعات</span>
            <span class="material-symbols-outlined text-red-600 bg-red-100 p-2 rounded-lg">remove_circle</span>
        </div>
        <div class="text-2xl font-bold text-text-main">@totalSales.ToString("N2")</div>
        <div class="text-xs text-text-secondary mt-1">@(ProductTypeExtensions.IsCountType(productType) ? "قطعة" : "كجم")</div>
    </div>

    <div class="bg-white rounded-2xl border border-border-light shadow-sm p-6">
        <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-semibold text-text-secondary">الاستخدام الداخلي</span>
            <span class="material-symbols-outlined text-amber-600 bg-amber-100 p-2 rounded-lg">engineering</span>
        </div>
        <div class="text-2xl font-bold text-text-main">@totalInternalUsage.ToString("N2")</div>
        <div class="text-xs text-text-secondary mt-1">@(ProductTypeExtensions.IsCountType(productType) ? "قطعة" : "كجم")</div>
    </div>

    <div class="bg-white rounded-2xl border border-border-light shadow-sm p-6">
        <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-semibold text-text-secondary">قيمة المشتريات</span>
            <span class="material-symbols-outlined text-purple-600 bg-purple-100 p-2 rounded-lg">attach_money</span>
        </div>
        <div class="text-2xl font-bold text-text-main">@totalPurchaseValue.ToString("N0")</div>
        <div class="text-xs text-text-secondary mt-1">جنيه</div>
    </div>

    <div class="bg-white rounded-2xl border border-border-light shadow-sm p-6">
        <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-semibold text-text-secondary">قيمة المبيعات</span>
            <span class="material-symbols-outlined text-orange-600 bg-orange-100 p-2 rounded-lg">payments</span>
        </div>
        <div class="text-2xl font-bold text-text-main">@totalSalesValue.ToString("N0")</div>
        <div class="text-xs text-text-secondary mt-1">جنيه</div>
    </div>

    <div class="bg-white rounded-2xl border border-border-light shadow-sm p-6">
        <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-semibold text-text-secondary">قيمة الاستخدام الداخلي</span>
            <span class="material-symbols-outlined text-amber-600 bg-amber-100 p-2 rounded-lg">account_balance_wallet</span>
        </div>
        <div class="text-2xl font-bold text-text-main">@totalInternalUsageValue.ToString("N0")</div>
        <div class="text-xs text-text-secondary mt-1">جنيه</div>
    </div>
</div>

<!-- Transactions Table -->
<div class="bg-white rounded-2xl border border-border-light shadow-sm overflow-hidden">
    @if (Model != null && Model.Any())
    {
        <div class="overflow-x-auto">
            <table class="w-full min-w-[900px]">
                <thead class="bg-gray-50 border-b border-border-light">
                    <tr>
                        <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase">التاريخ</th>
                        <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase">رقم المرجع</th>
                        <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase">النوع</th>
                        <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase">الكمية قبل</th>
                        <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase">التغيير</th>
                        <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase">الوزن</th>
                        <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase">الكمية بعد</th>
                        <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase">سعر الوحدة</th>
                        <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase">الإجمالي</th>
                        <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase">ملاحظات</th>
                        <th class="py-4 px-4 text-center text-xs font-bold text-text-secondary uppercase">الإجراءات</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border-light">
                    @foreach (var transaction in Model)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors">
                            <td class="py-4 px-4 text-sm text-text-secondary">
                                @transaction.TransactionDate.ToString("dd/MM/yyyy")
                            </td>
                            <td class="py-4 px-4 text-sm font-bold text-primary">
                                @transaction.ReferenceNumber
                            </td>
                            <td class="py-4 px-4 text-sm">
                                @if (TransactionTypes.IsPurchase(transaction.TransactionType))
                                {
                                    <span class="inline-flex items-center gap-1 px-2 py-1 bg-green-100 text-green-800 text-xs font-bold rounded-full">
                                        <span class="material-symbols-outlined text-[14px]">add</span>
                                        إضافة
                                    </span>
                                }
                                else if (TransactionTypes.IsSales(transaction.TransactionType))
                                {
                                    <span class="inline-flex items-center gap-1 px-2 py-1 bg-red-100 text-red-800 text-xs font-bold rounded-full">
                                        <span class="material-symbols-outlined text-[14px]">remove</span>
                                        خصم
                                    </span>
                                }
                                else if (TransactionTypes.IsInternalUsage(transaction.TransactionType))
                                {
                                    <span class="inline-flex items-center gap-1 px-2 py-1 bg-amber-100 text-amber-800 text-xs font-bold rounded-full">
                                        <span class="material-symbols-outlined text-[14px]">engineering</span>
                                        استخدام داخلي
                                    </span>
                                }
                            </td>
                            <td class="py-4 px-4 text-sm text-text-secondary">
                                @transaction.QuantityBefore.ToString("N2")
                            </td>
                            <td class="py-4 px-4 text-sm font-bold @(TransactionTypes.IsPurchase(transaction.TransactionType) ? "text-green-600" : (TransactionTypes.IsInternalUsage(transaction.TransactionType) ? "text-amber-600" : "text-red-600"))">
                                @(TransactionTypes.IsPurchase(transaction.TransactionType) ? "+" : "-")@Math.Abs(transaction.QuantityChanged).ToString("N2")
                            </td>
                            <td class="py-4 px-4 text-sm text-text-secondary">
                                @transaction.WeightChanged.ToString("N2") كجم
                            </td>
                            <td class="py-4 px-4 text-sm font-medium text-text-main">
                                @transaction.QuantityAfter.ToString("N2")
                            </td>
                            <td class="py-4 px-4 text-sm text-text-secondary">
                                @transaction.UnitPrice.ToString("N2") جنيه
                            </td>
                            <td class="py-4 px-4 text-sm font-bold text-primary">
                                @transaction.DisplayTotalAmount.ToString("N2") جنيه
                            </td>
                            <td class="py-4 px-4 text-sm text-text-secondary max-w-xs truncate" title="@transaction.Notes">
                                @transaction.Notes
                            </td>
                            <td class="py-4 px-4 text-center">
                                @if (transaction.InvoiceId > 0)
                                {
                                    <a asp-controller="Invoice" asp-action="Details" asp-route-id="@transaction.InvoiceId"
                                       class="text-primary hover:text-primary-dark p-2 hover:bg-primary/10 rounded-lg transition-all inline-flex items-center"
                                       title="عرض الفاتورة">
                                        <span class="material-symbols-outlined text-[20px]">visibility</span>
                                    </a>
                                }
                                else if (TransactionTypes.IsInternalUsage(transaction.TransactionType))
                                {
                                    <a asp-controller="InternalUsage"
                                       asp-action="DetailsByReference"
                                       asp-route-productId="@product.Id"
                                       asp-route-referenceNumber="@transaction.ReferenceNumber"
                                       class="text-amber-700 hover:text-amber-800 p-2 hover:bg-amber-50 rounded-lg transition-all inline-flex items-center"
                                       title="عرض سجل الاستخدام الداخلي">
                                        <span class="material-symbols-outlined text-[20px]">visibility</span>
                                    </a>
                                }
                                else
                                {
                                    <span class="text-gray-400">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="p-12 text-center">
            <span class="material-symbols-outlined text-gray-400 text-6xl mb-4">inventory_2</span>
            <p class="text-text-secondary text-lg font-medium mb-2">لا توجد حركات</p>
            <p class="text-text-secondary text-sm">لم يتم تسجيل أي حركات لهذا المنتج في الفترة المحددة</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        function exportTransactions() {
            const productId = @product.Id;
            const fromDate = '@fromDate?.ToString("yyyy-MM-dd")';
            const toDate = '@toDate?.ToString("yyyy-MM-dd")';

            let url = `/Product/ExportTransactions?id=${productId}`;
            if (fromDate) url += `&fromDate=${fromDate}`;
            if (toDate) url += `&toDate=${toDate}`;

            window.location.href = url;
        }
    </script>
}
