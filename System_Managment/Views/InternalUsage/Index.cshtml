@using BLL.ViewModels.InternalUsage
@model List<InternalUsageDetailsVM>

@{
    ViewData["Title"] = "سجلات الاستخدام الداخلي";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string GetCategoryBadgeClass(string category) => category switch
    {
        "تغذية الحيوانات" => "bg-blue-100 text-blue-800",
        "عمليات المزرعة" => "bg-orange-100 text-orange-800",
        "العناية بالماشية" => "bg-red-100 text-red-800",
        "الصيانة" => "bg-purple-100 text-purple-800",
        _ => "bg-gray-100 text-gray-800"
    };
}

<div class="container">
    <!-- Header -->
    <div class="mb-8 flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-4">
            <div class="size-12 text-primary bg-white rounded-xl shadow-sm border border-border-light p-2.5 flex items-center justify-center">
                <span class="material-symbols-outlined text-[28px]">inventory_2</span>
            </div>
            <div>
                <h1 class="text-2xl font-bold text-text-main tracking-tight">سجلات الاستخدام الداخلي</h1>
                <p class="text-sm text-text-secondary mt-1">إدارة استخدام المنتجات الداخلية للمزرعة</p>
            </div>
        </div>
        <a asp-action="Create" class="px-6 py-2.5 bg-primary hover:bg-primary-dark text-white font-bold rounded-xl shadow-lg transition-all flex items-center gap-2">
            <span class="material-symbols-outlined">add</span>
            تسجيل استخدام جديد
        </a>
    </div>

    <!-- Filter Tabs -->
    <div class="bg-white rounded-xl shadow-sm border border-border-light p-2 mb-6 flex gap-2">
        <a asp-action="Index" class="flex-1 text-center py-2.5 rounded-lg @(ViewBag.SelectedCategory == null ? "bg-primary text-white" : "text-text-secondary hover:bg-gray-50") font-bold text-sm transition-all">
            جميع السجلات
        </a>
        <a asp-action="Index" asp-route-category="تغذية الحيوانات" class="flex-1 text-center py-2.5 rounded-lg @(ViewBag.SelectedCategory?.ToString() == "تغذية الحيوانات" ? "bg-primary text-white" : "text-text-secondary hover:bg-gray-50") font-bold text-sm transition-all">
            تغذية الحيوانات
        </a>
        <a asp-action="Index" asp-route-category="عمليات المزرعة" class="flex-1 text-center py-2.5 rounded-lg @(ViewBag.SelectedCategory?.ToString() == "عمليات المزرعة" ? "bg-primary text-white" : "text-text-secondary hover:bg-gray-50") font-bold text-sm transition-all">
            عمليات المزرعة
        </a>
        <a asp-action="Index" asp-route-category="العناية بالماشية" class="flex-1 text-center py-2.5 rounded-lg @(ViewBag.SelectedCategory?.ToString() == "العناية بالماشية" ? "bg-primary text-white" : "text-text-secondary hover:bg-gray-50") font-bold text-sm transition-all">
            العناية بالماشية
        </a>
    </div>

    <!-- Date Range Filter -->
    <div class="bg-white rounded-xl shadow-sm border border-border-light p-4 mb-6">
        <form method="get" class="flex flex-col md:flex-row gap-4 items-end">
            <div class="flex-1">
                <label class="text-sm font-bold text-text-main mb-2 block">من</label>
                <input type="date" name="startDate" class="w-full px-4 py-2.5 border border-border-light rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary"
                       value="@ViewBag.StartDate?.ToString("yyyy-MM-dd")">
            </div>
            <div class="flex-1">
                <label class="text-sm font-bold text-text-main mb-2 block">إلى</label>
                <input type="date" name="endDate" class="w-full px-4 py-2.5 border border-border-light rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary"
                       value="@ViewBag.EndDate?.ToString("yyyy-MM-dd")">
            </div>
            <button type="submit" class="px-6 py-2.5 bg-primary hover:bg-primary-dark text-white font-bold rounded-lg transition-all flex items-center gap-2">
                <span class="material-symbols-outlined">search</span>
                بحث
            </button>
        </form>
    </div>

    <!-- Success Message -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-50 border border-green-200 rounded-xl p-4 mb-6 flex items-center gap-3">
            <span class="material-symbols-outlined text-green-600">check_circle</span>
            <span class="text-green-800 font-medium">@TempData["SuccessMessage"]</span>
        </div>
    }

    <!-- Usage Records Table -->
    <div class="bg-white rounded-2xl shadow-sm border border-border-light overflow-hidden">
        @if (Model != null && Model.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50 border-b border-border-light">
                        <tr>
                            <th class="py-4 px-6 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">التاريخ</th>
                            <th class="py-4 px-6 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">المنتج</th>
                            <th class="py-4 px-6 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الكمية</th>
                            <th class="py-4 px-6 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">التكلفة</th>
                            <th class="py-4 px-6 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الفئة</th>
                            <th class="py-4 px-6 text-center text-xs font-bold text-text-secondary uppercase tracking-wider">الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border-light">
                        @foreach (var usage in Model.OrderByDescending(u => u.UsageDate))
                        {
                            <tr class="hover:bg-gray-50/50 transition-colors">
                                <td class="py-4 px-6 text-sm text-text-secondary">
                                    @usage.UsageDate.ToString("dd/MM/yyyy")
                                </td>
                                <td class="py-4 px-6 text-sm font-bold text-text-main">
                                    @usage.ProductName
                                </td>
                                <td class="py-4 px-6 text-sm text-text-secondary">
                                    @usage.Weight كغ
                                </td>
                                <td class="py-4 px-6 text-sm font-bold text-text-main">
                                    @usage.TotalCost.ToString("N2") جنيه
                                </td>
                                <td class="py-4 px-6 text-sm">
                                    <span class="inline-flex items-center px-3 py-1 text-xs font-bold rounded-full @GetCategoryBadgeClass(usage.UsageCategory)">
                                        @usage.UsageCategory
                                    </span>
                                </td>
                                <td class="py-4 px-6 text-center">
                                    <div class="flex items-center justify-center gap-2">
                                        <a asp-action="Details" asp-route-id="@usage.Id"
                                           class="text-slate-600 hover:text-slate-800 p-2 hover:bg-slate-100 rounded-lg transition-all"
                                           title="عرض التفاصيل">
                                            <span class="material-symbols-outlined text-xl">visibility</span>
                                        </a>

                                        <a asp-action="ByProduct" asp-route-productId="@usage.ProductId"
                                           class="text-blue-600 hover:text-blue-800 p-2 hover:bg-blue-100 rounded-lg transition-all"
                                           title="إحصائيات المنتج">
                                            <span class="material-symbols-outlined text-xl">bar_chart</span>
                                        </a>
                                        <a href="@Url.Action("Edit", new { id = usage.Id })"
                                           class="p-2 text-primary hover:bg-primary/10 rounded-lg transition-all"
                                           title="تعديل">
                                            <span class="material-symbols-outlined text-[20px]">edit</span>
                                        </a>
                                        <button type="button" onclick="deleteUsage(@usage.Id)"
                                                class="p-2 text-red-600 hover:bg-red-50 rounded-lg transition-all"
                                                title="حذف">
                                            <span class="material-symbols-outlined text-[20px]">delete</span>
                                        </button>
                                        <form id="deleteForm_@usage.Id" method="post" asp-action="Delete" asp-route-id="@usage.Id" style="display:none;">
                                            @Html.AntiForgeryToken()
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-12 text-center">
                <span class="material-symbols-outlined text-gray-400 text-6xl mb-4">inventory_2</span>
                <p class="text-text-secondary text-lg font-medium mb-2">لا توجد سجلات استخدام</p>
                <p class="text-text-secondary text-sm">ابدأ بتسجيل استخدام جديد للمنتجات</p>
                <a asp-action="Create" class="inline-block mt-4 px-6 py-2.5 bg-primary hover:bg-primary-dark text-white font-bold rounded-xl transition-all">
                    تسجيل استخدام جديد
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function deleteUsage(id) {
            Swal.fire({
                title: 'هل أنت متأكد؟',
                text: "سيتم حذف السجل واستعادة المخزون إلى حالته السابقة",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#2a7f40',
                cancelButtonColor: '#d33',
                confirmButtonText: 'نعم، احذف',
                cancelButtonText: 'إلغاء'
            }).then((result) => {
                if (result.isConfirmed) {
                    const form = document.getElementById('deleteForm_' + id);
                    if (form) {
                        form.submit();
                    } else {
                        console.error('Form not found for id: ' + id);
                    }
                }
            });
        }
    </script>
}
