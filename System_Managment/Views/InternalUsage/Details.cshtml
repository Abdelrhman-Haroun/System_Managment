@using BLL.ViewModels.InternalUsage
@model InternalUsageDetailsVM

@{
    ViewData["Title"] = "تفاصيل الاستخدام الداخلي";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string GetCategoryBadgeClass(string category) => category switch
    {
        "تغذية الحيوانات" => "bg-blue-100 text-blue-800",
        "عمليات المزرعة" => "bg-orange-100 text-orange-800",
        "العناية بالماشية" => "bg-red-100 text-red-800",
        "الصيانة" => "bg-purple-100 text-purple-800",
        _ => "bg-gray-100 text-gray-800"
    };
}

<div class="mb-8 flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-4">
        <div class="size-12 text-primary bg-white rounded-xl shadow-sm border border-border-light p-2.5 flex items-center justify-center">
            <span class="material-symbols-outlined text-[28px]">info</span>
        </div>
        <div>
            <h1 class="text-2xl font-bold text-text-main tracking-tight">تفاصيل الاستخدام الداخلي</h1>
            <p class="text-sm text-text-secondary mt-1">@Model.ProductName</p>
        </div>
    </div>
    <div class="flex gap-3 w-full md:w-auto">
        <a href="@Url.Action("Index")" class="flex-1 md:flex-none px-6 py-2.5 text-sm font-medium text-text-secondary bg-white border border-border-light rounded-xl hover:bg-gray-50 hover:text-text-main focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary/20 transition-all text-center">
            رجوع
        </a>
        <a href="@Url.Action("ByProduct", new { productId = Model.ProductId })" class="flex-1 md:flex-none px-6 py-2.5 text-sm font-medium text-white bg-blue-600 rounded-xl hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 shadow-sm transition-all flex items-center justify-center gap-2">
            <span class="material-symbols-outlined text-[20px]">bar_chart</span>
            إحصائيات
        </a>
        <a href="@Url.Action("Edit", new { id = Model.Id })" class="flex-1 md:flex-none px-6 py-2.5 text-sm font-medium text-white bg-primary rounded-xl hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary shadow-sm transition-all flex items-center justify-center gap-2">
            <span class="material-symbols-outlined text-[20px]">edit</span>
            تعديل
        </a>
    </div>
</div>

<!-- Success Message -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="bg-green-50 border border-green-200 rounded-xl p-4 mb-6 flex items-center gap-3">
        <span class="material-symbols-outlined text-green-600">check_circle</span>
        <span class="text-green-800 font-medium">@TempData["SuccessMessage"]</span>
    </div>
}

<div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8">
    <!-- Main Content -->
    <div class="lg:col-span-8 flex flex-col gap-6">

        <!-- Usage Category Badge -->
        <div class="bg-surface-light rounded-2xl border border-border-light shadow-sm p-6">
            <div class="inline-flex items-center gap-2 px-4 py-2 @GetCategoryBadgeClass(Model.UsageCategory) font-bold rounded-xl">
                <span class="material-symbols-outlined text-[24px]">folder</span>
                @Model.UsageCategory
            </div>
        </div>

        <!-- Product Info -->
        <section class="bg-surface-light rounded-2xl border border-border-light shadow-sm p-6 lg:p-8">
            <h3 class="text-lg font-bold text-text-main mb-6 flex items-center gap-2 pb-4 border-b border-border-light">
                <span class="material-symbols-outlined text-primary bg-primary/10 p-1.5 rounded-lg">package</span>
                معلومات المنتج والاستخدام
            </h3>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                <!-- Product Name -->
                <div class="flex flex-col gap-2">
                    <label class="text-sm font-semibold text-text-secondary">المنتج</label>
                    <p class="text-base font-bold text-text-main break-words">
                        @Model.ProductName
                    </p>
                </div>

                <!-- Usage Date -->
                <div class="flex flex-col gap-2">
                    <label class="text-sm font-semibold text-text-secondary">تاريخ الاستخدام</label>
                    <p class="text-base font-bold text-text-main">
                        @Model.UsageDate.ToString("dd/MM/yyyy")
                    </p>
                </div>

                <!-- Category -->
                <div class="flex flex-col gap-2">
                    <label class="text-sm font-semibold text-text-secondary">الفئة</label>
                    <p class="text-base font-bold text-text-main">
                        @Model.UsageCategory
                    </p>
                </div>
            </div>
        </section>

        <!-- Usage Details -->
        <section class="bg-surface-light rounded-2xl border border-border-light shadow-sm p-6 lg:p-8">
            <h3 class="text-lg font-bold text-text-main mb-6 flex items-center gap-2 pb-4 border-b border-border-light">
                <span class="material-symbols-outlined text-primary bg-primary/10 p-1.5 rounded-lg">scale</span>
                تفاصيل الاستخدام
            </h3>

            <div class="space-y-6">
                <!-- Quantities -->
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                    <div class="flex flex-col gap-2">
                        <label class="text-sm font-semibold text-text-secondary">الكمية</label>
                        <p class="text-base font-bold text-text-main">@Model.Quantity</p>
                    </div>
                    <div class="flex flex-col gap-2">
                        <label class="text-sm font-semibold text-text-secondary">الوزن (كغ)</label>
                        <p class="text-base font-bold text-text-main">@Model.Weight.ToString("N2")</p>
                    </div>
                    <div class="flex flex-col gap-2">
                        <label class="text-sm font-semibold text-text-secondary">سعر الوحدة</label>
                        <p class="text-base font-bold text-text-main">@Model.UnitPrice.ToString("N2") جنيه</p>
                    </div>
                </div>

                <!-- Total Cost Highlight -->
                <div class="bg-primary/5 rounded-xl p-6 border border-primary/10 text-center">
                    <span class="block text-sm font-semibold text-text-secondary mb-2">التكلفة الإجمالية</span>
                    <div class="flex items-center justify-center gap-1 text-primary">
                        <span class="text-4xl font-bold tracking-tight">@Model.TotalCost.ToString("N2")</span>
                        <span class="text-sm font-bold mt-2">جنيه</span>
                    </div>
                </div>

                <!-- Stock Changes -->
                <div class="border-t border-border-light pt-6">
                    <h4 class="text-sm font-bold text-text-main mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined text-[20px] bg-blue-100 text-blue-600 p-1 rounded-lg">trending_down</span>
                        تغيير المخزون
                    </h4>
                    <div class="grid grid-cols-3 gap-4">
                        <div class="bg-blue-50 rounded-xl p-4 border border-blue-100 text-center">
                            <p class="text-xs font-semibold text-blue-600 uppercase mb-2">قبل الاستخدام</p>
                            <p class="text-3xl font-bold text-blue-600">@Model.StockQuantityBefore</p>
                        </div>
                        <div class="flex items-center justify-center">
                            <span class="material-symbols-outlined text-gray-400 text-3xl">arrow_downward</span>
                        </div>
                        <div class="bg-green-50 rounded-xl p-4 border border-green-100 text-center">
                            <p class="text-xs font-semibold text-green-600 uppercase mb-2">بعد الاستخدام</p>
                            <p class="text-3xl font-bold text-green-600">@Model.StockQuantityAfter</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!--  Notes -->
        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <section class="bg-surface-light rounded-2xl border border-border-light shadow-sm p-6 lg:p-8">
                <h3 class="text-lg font-bold text-text-main mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary bg-primary/10 p-1.5 rounded-lg">description</span>
                    ملاحظات
                </h3>
                <p class="text-sm text-text-secondary leading-relaxed bg-yellow-50 p-4 rounded-lg border border-yellow-200">
                    @Model.Notes
                </p>
            </section>
        }
    </div>

    <!-- Summary Sidebar -->
    <div class="lg:col-span-4 flex flex-col gap-6">
        <!-- Summary Card -->
        <section class="bg-surface-light rounded-2xl border border-border-light shadow-sm p-6 sticky top-6">
            <h3 class="text-lg font-bold text-text-main mb-6 flex items-center gap-2 pb-4 border-b border-border-light">
                <span class="material-symbols-outlined text-primary bg-primary/10 p-1.5 rounded-lg">summarize</span>
                ملخص البيانات
            </h3>

            <div class="space-y-5">
                <div class="flex items-center justify-between text-sm">
                    <span class="text-text-secondary font-medium">رقم المعرف</span>
                    <span class="font-bold text-text-main">#@Model.Id</span>
                </div>

                <div class="flex items-center justify-between text-sm">
                    <span class="text-text-secondary font-medium">نوع المنتج</span>
                    <span class="font-bold text-text-main">@(Model.ProductType == 1 ? "وحدات" : "وزن")</span>
                </div>

                <div class="flex items-center justify-between text-sm">
                    <span class="text-text-secondary font-medium">الكمية المستخدمة</span>
                    <span class="font-bold text-primary text-base">@Model.Weight كغ</span>
                </div>

                <div class="border-t-2 border-dashed border-border-light my-2"></div>

                <div class="flex items-center justify-between text-sm">
                    <span class="text-text-secondary font-medium">التكلفة الإجمالية</span>
                    <span class="font-bold text-primary text-base">@Model.TotalCost.ToString("N2") جنيه</span>
                </div>

                <div class="border-t-2 border-dashed border-border-light my-2"></div>

                <div class="flex items-center justify-between text-sm">
                    <span class="text-text-secondary font-medium">تاريخ التسجيل</span>
                    <span class="font-bold text-text-main text-xs">@Model.CreatedAt.ToString("dd/MM/yyyy")</span>
                </div>

                <div class="flex items-center justify-between text-sm">
                    <span class="text-text-secondary font-medium">الوقت</span>
                    <span class="font-bold text-text-main text-xs">@Model.CreatedAt.ToString("HH:mm")</span>
                </div>

                <div class="pt-4 space-y-3">

                    <a href="@Url.Action("Edit", new { id = Model.Id })" class="w-full py-3 px-6 bg-primary hover:bg-primary-dark text-white font-bold text-base rounded-xl shadow-lg shadow-primary/20 hover:shadow-primary/40 transition-all flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined">edit</span>
                        <span>تعديل السجل</span>
                    </a>

                    <button type="button" onclick="deleteUsage(@Model.Id)" class="w-full py-3 px-6 bg-red-600 hover:bg-red-700 text-white font-bold text-base rounded-xl shadow-lg shadow-red-600/20 hover:shadow-red-600/40 transition-all flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined">delete</span>
                        <span>حذف السجل</span>
                    </button>
                </div>
            </div>
        </section>

        <!-- Info Box -->
        <div class="bg-blue-50/50 rounded-2xl border border-blue-100 p-5 shadow-sm">
            <div class="flex items-start gap-3">
                <span class="material-symbols-outlined text-blue-600 mt-0.5 bg-blue-100 p-1 rounded-full text-[18px]">info</span>
                <div class="flex flex-col gap-1">
                    <h4 class="text-sm font-bold text-blue-900">ملاحظة مهمة</h4>
                    <p class="text-xs text-blue-700/80 leading-relaxed">
                        هذا السجل يعكس الاستخدام الداخلي للمنتج ولا يعتبر فاتورة بيع للعملاء. المخزون تم تقليله تلقائياً.
                    </p>
                </div>
            </div>
        </div>

        <!-- Audit Information -->
        <div class="bg-green-50/50 rounded-2xl border border-green-100 p-5 shadow-sm">
            <div class="flex items-start gap-3">
                <span class="material-symbols-outlined text-green-600 mt-0.5 bg-green-100 p-1 rounded-full text-[18px]">check_circle</span>
                <div class="flex flex-col gap-1">
                    <h4 class="text-sm font-bold text-green-900">تم التسجيل بنجاح</h4>
                    <p class="text-xs text-green-700/80 leading-relaxed">
                        في<br />
                        <span class="font-semibold">@Model.CreatedAt.ToString("dd/MM/yyyy - HH:mm")</span>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Form (Hidden) -->
<form id="deleteForm_@Model.Id" method="post" asp-action="Delete" asp-route-id="@Model.Id" style="display:none;">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script>
        function deleteUsage(id) {
            Swal.fire({
                title: 'هل أنت متأكد؟',
                text: "سيتم حذف السجل واستعادة المخزون إلى حالته السابقة",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#2a7f40',
                cancelButtonColor: '#d33',
                confirmButtonText: 'نعم، احذف',
                cancelButtonText: 'إلغاء'
            }).then((result) => {
                if (result.isConfirmed) {
                    const form = document.getElementById('deleteForm_' + id);
                    if (form) {
                        form.submit();
                    }
                }
            });
        }
    </script>
}