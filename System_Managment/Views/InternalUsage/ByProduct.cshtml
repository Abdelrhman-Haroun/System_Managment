@using BLL.ViewModels.InternalUsage
@model List<InternalUsageDetailsVM>

@{
    ViewData["Title"] = "إحصائيات استخدام المنتج";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var product = ViewBag.Product as DAL.Models.Product;
    var totalCost = (decimal)(ViewBag.TotalCost ?? 0);
    var totalQuantity = (decimal)(ViewBag.TotalQuantity ?? 0);

    string GetCategoryBadgeClass(string category) => category switch
    {
        "تغذية الحيوانات" => "bg-blue-100 text-blue-800 border-blue-200",
        "عمليات المزرعة" => "bg-orange-100 text-orange-800 border-orange-200",
        "العناية بالماشية" => "bg-red-100 text-red-800 border-red-200",
        "الصيانة" => "bg-purple-100 text-purple-800 border-purple-200",
        _ => "bg-gray-100 text-gray-800 border-gray-200"
    };
}

<!-- Header -->
<div class="mb-8 flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-4">
        <div class="size-12 text-primary bg-white rounded-xl shadow-sm border border-border-light p-2.5 flex items-center justify-center">
            <span class="material-symbols-outlined text-[28px]">bar_chart</span>
        </div>
        <div>
            <h1 class="text-2xl font-bold text-text-main tracking-tight">إحصائيات استخدام المنتج</h1>
            <p class="text-sm text-text-secondary mt-1">@(product?.Name ?? "المنتج")</p>
        </div>
    </div>
    <div class="flex gap-3 w-full md:w-auto">
        <a asp-action="Index"
           class="flex-1 md:flex-none px-6 py-2.5 text-sm font-medium text-text-secondary bg-white border border-border-light rounded-xl hover:bg-gray-50 hover:text-text-main focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary/20 transition-all text-center">
            رجوع للسجلات
        </a>
    </div>
</div>

<!-- Summary Cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6 mb-8">
    <!-- Product Name Card -->
    <div class="bg-white rounded-2xl shadow-sm border border-border-light p-5 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between mb-3">
            <span class="text-xs font-bold text-text-secondary uppercase tracking-wide">المنتج</span>
            <div class="bg-primary/10 p-2 rounded-lg">
                <span class="material-symbols-outlined text-primary text-[20px]">package</span>
            </div>
        </div>
        <p class="text-base font-bold text-text-main truncate" title="@(product?.Name ?? "غير معروف")">
            @(product?.Name ?? "غير معروف")
        </p>
    </div>

    <!-- Total Cost Card -->
    <div class="bg-white rounded-2xl shadow-sm border border-border-light p-5 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between mb-3">
            <span class="text-xs font-bold text-text-secondary uppercase tracking-wide">إجمالي التكلفة</span>
            <div class="bg-green-100 p-2 rounded-lg">
                <span class="material-symbols-outlined text-green-600 text-[20px]">payments</span>
            </div>
        </div>
        <p class="text-xl font-bold text-green-600">@totalCost.ToString("N2") <span class="text-sm">جنيه</span></p>
    </div>

    <!-- Total Weight Card -->
    <div class="bg-white rounded-2xl shadow-sm border border-border-light p-5 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between mb-3">
            <span class="text-xs font-bold text-text-secondary uppercase tracking-wide">إجمالي الوزن</span>
            <div class="bg-blue-100 p-2 rounded-lg">
                <span class="material-symbols-outlined text-blue-600 text-[20px]">scale</span>
            </div>
        </div>
        <p class="text-xl font-bold text-blue-600">@totalQuantity.ToString("N2") <span class="text-sm">كجم</span></p>
    </div>

    <!-- Records Count Card -->
    <div class="bg-white rounded-2xl shadow-sm border border-border-light p-5 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between mb-3">
            <span class="text-xs font-bold text-text-secondary uppercase tracking-wide">عدد السجلات</span>
            <div class="bg-purple-100 p-2 rounded-lg">
                <span class="material-symbols-outlined text-purple-600 text-[20px]">format_list_numbered</span>
            </div>
        </div>
        <p class="text-xl font-bold text-purple-600">@(Model?.Count ?? 0) <span class="text-sm">سجل</span></p>
    </div>
</div>

<!-- Main Content Grid -->
<div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8">

    <!-- Left Column: Table -->
    <div class="lg:col-span-8">
        <!-- Usage Records Table -->
        <div class="bg-white rounded-2xl shadow-sm border border-border-light overflow-hidden">
            <div class="bg-gradient-to-r from-primary to-primary-dark text-white p-6">
                <div class="flex items-center justify-between">
                    <h2 class="text-lg font-bold flex items-center gap-2">
                        <div class="bg-white/20 p-1.5 rounded-lg">
                            <span class="material-symbols-outlined text-[20px]">list</span>
                        </div>
                        سجلات الاستخدام
                    </h2>
                    <span class="text-sm font-medium bg-white/20 px-3 py-1.5 rounded-full">
                        @(Model?.Count ?? 0) سجل
                    </span>
                </div>
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="overflow-x-auto">
                    <table class="w-full min-w-[900px]">
                        <thead class="bg-gray-50 border-b border-border-light">
                            <tr>
                                <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">#</th>
                                <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الفئة</th>
                                <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الكمية</th>
                                <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الوزن</th>
                                <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">سعر الوحدة</th>
                                <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">التكلفة</th>
                                <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">التاريخ</th>
                                <th class="py-4 px-4 text-center text-xs font-bold text-text-secondary uppercase tracking-wider">الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border-light">
                            @{
                                var index = 1;
                            }
                            @foreach (var usage in Model.OrderByDescending(u => u.UsageDate))
                            {
                                <tr class="hover:bg-gray-50/50 transition-colors">
                                    <td class="py-4 px-4 text-sm font-bold text-text-secondary">@index</td>
                                    <td class="py-4 px-4 text-sm">
                                        <span class="inline-flex items-center px-2.5 py-1 text-xs font-bold rounded-lg border @GetCategoryBadgeClass(usage.UsageCategory)">
                                            @usage.UsageCategory
                                        </span>
                                    </td>
                                    <td class="py-4 px-4 text-sm font-medium text-text-main">
                                        @usage.Quantity.ToString("N2")
                                    </td>
                                    <td class="py-4 px-4 text-sm font-bold text-blue-600">
                                        @usage.Weight.ToString("N2") كجم
                                    </td>
                                    <td class="py-4 px-4 text-sm text-text-secondary">
                                        @usage.UnitPrice.ToString("N2") جنيه
                                    </td>
                                    <td class="py-4 px-4 text-sm font-bold text-green-600">
                                        @usage.TotalCost.ToString("N2") جنيه
                                    </td>
                                    <td class="py-4 px-4 text-sm text-text-secondary">
                                        @usage.UsageDate.ToString("dd/MM/yyyy")
                                    </td>
                                    <td class="py-4 px-4 text-center">
                                        <a href="@Url.Action("Details", new { id = usage.Id })"
                                           class="text-primary hover:text-primary-dark p-2 hover:bg-primary/10 rounded-lg transition-all inline-flex"
                                           title="عرض التفاصيل">
                                            <span class="material-symbols-outlined text-[20px]">visibility</span>
                                        </a>
                                    </td>
                                </tr>
                                index++;
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-12 text-center">
                    <span class="material-symbols-outlined text-gray-400 text-6xl mb-4 block">inventory_2</span>
                    <p class="text-text-secondary text-lg font-medium mb-2">لا توجد سجلات استخدام</p>
                    <p class="text-text-secondary text-sm mb-6">لم يتم تسجيل أي استخدام داخلي لهذا المنتج</p>
                    <a asp-action="Index" class="inline-block px-6 py-2.5 bg-primary hover:bg-primary-dark text-white font-bold rounded-xl transition-all shadow-sm hover:shadow-md">
                        العودة إلى السجلات
                    </a>
                </div>
            }
        </div>
    </div>

    <!-- Right Column: Statistics -->
    @if (Model != null && Model.Any())
    {
        <div class="lg:col-span-4 space-y-6">
            <!-- Usage by Category -->
            <div class="bg-white rounded-2xl shadow-sm border border-border-light p-6">
                <h3 class="text-lg font-bold text-text-main mb-6 flex items-center gap-2 pb-4 border-b border-border-light">
                    <div class="bg-primary/10 p-1.5 rounded-lg">
                        <span class="material-symbols-outlined text-primary text-[20px]">pie_chart</span>
                    </div>
                    الاستخدام حسب الفئة
                </h3>

                <div class="space-y-5">
                    @{
                        var grouped = Model.GroupBy(u => u.UsageCategory)
                        .Select(g => new
                        {
                            Category = g.Key,
                            Count = g.Count(),
                            TotalCost = g.Sum(u => u.TotalCost),
                            TotalQuantity = g.Sum(u => u.Weight)
                        })
                        .OrderByDescending(x => x.TotalCost)
                        .ToList();

                        var maxCost = grouped.Any() ? grouped.Max(x => x.TotalCost) : 1;
                    }

                    @foreach (var cat in grouped)
                    {
                        var percentage = maxCost > 0 ? (cat.TotalCost / maxCost * 100) : 0;

                        <div class="space-y-2">
                            <div class="flex items-center justify-between">
                                <span class="inline-flex items-center px-2.5 py-1 text-xs font-bold rounded-lg border @GetCategoryBadgeClass(cat.Category)">
                                    @cat.Category
                                </span>
                                <span class="text-sm font-bold text-text-main">@cat.TotalCost.ToString("N2") جنيه</span>
                            </div>
                            <div class="w-full bg-gray-200 rounded-full h-2 overflow-hidden">
                                <div class="bg-gradient-to-r from-primary to-primary-dark h-2 rounded-full transition-all duration-500"
                                     style="width: @(percentage)%"></div>
                            </div>
                            <div class="flex justify-between text-xs text-text-secondary">
                                <span>
                                    <span class="font-bold text-primary">@cat.Count</span> سجلات
                                </span>
                                <span>
                                    <span class="font-bold text-blue-600">@cat.TotalQuantity.ToString("N2")</span> كجم
                                </span>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Statistics Cards -->
            <div class="bg-white rounded-2xl shadow-sm border border-border-light p-6">
                <h3 class="text-lg font-bold text-text-main mb-6 flex items-center gap-2 pb-4 border-b border-border-light">
                    <div class="bg-primary/10 p-1.5 rounded-lg">
                        <span class="material-symbols-outlined text-primary text-[20px]">trending_up</span>
                    </div>
                    الإحصائيات التفصيلية
                </h3>

                <div class="space-y-4">
                    @{
                        var avgCost = Model.Any() ? Model.Average(u => u.TotalCost) : 0;
                        var avgQuantity = Model.Any() ? Model.Average(u => u.Weight) : 0;
                        var maxCostRecord = Model.Any() ? Model.Max(u => u.TotalCost) : 0;
                        var firstDate = Model.Any() ? Model.Min(u => u.UsageDate) : DateTime.MinValue;
                        var lastDate = Model.Any() ? Model.Max(u => u.UsageDate) : DateTime.MinValue;
                    }

                    <!-- Average Cost -->
                    <div class="bg-gradient-to-br from-blue-50 to-blue-100/50 rounded-xl p-4 border border-blue-200">
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-xs font-bold text-blue-800 uppercase tracking-wide">متوسط التكلفة</p>
                            <div class="bg-white p-1.5 rounded-lg">
                                <span class="material-symbols-outlined text-blue-600 text-[18px]">calculate</span>
                            </div>
                        </div>
                        <p class="text-2xl font-bold text-blue-600">@avgCost.ToString("N2")</p>
                        <p class="text-xs text-blue-600/70 mt-1">جنيه للسجل الواحد</p>
                    </div>

                    <!-- Average Weight -->
                    <div class="bg-gradient-to-br from-green-50 to-green-100/50 rounded-xl p-4 border border-green-200">
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-xs font-bold text-green-800 uppercase tracking-wide">متوسط الوزن</p>
                            <div class="bg-white p-1.5 rounded-lg">
                                <span class="material-symbols-outlined text-green-600 text-[18px]">scale</span>
                            </div>
                        </div>
                        <p class="text-2xl font-bold text-green-600">@avgQuantity.ToString("N2")</p>
                        <p class="text-xs text-green-600/70 mt-1">كجم للسجل الواحد</p>
                    </div>

                    <!-- Max Cost -->
                    <div class="bg-gradient-to-br from-purple-50 to-purple-100/50 rounded-xl p-4 border border-purple-200">
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-xs font-bold text-purple-800 uppercase tracking-wide">أعلى تكلفة</p>
                            <div class="bg-white p-1.5 rounded-lg">
                                <span class="material-symbols-outlined text-purple-600 text-[18px]">trending_up</span>
                            </div>
                        </div>
                        <p class="text-2xl font-bold text-purple-600">@maxCostRecord.ToString("N2")</p>
                        <p class="text-xs text-purple-600/70 mt-1">جنيه</p>
                    </div>

                    <!-- Date Range -->
                    @if (firstDate != DateTime.MinValue && lastDate != DateTime.MinValue)
                    {
                        <div class="bg-gradient-to-br from-orange-50 to-orange-100/50 rounded-xl p-4 border border-orange-200">
                            <div class="flex items-center justify-between mb-2">
                                <p class="text-xs font-bold text-orange-800 uppercase tracking-wide">فترة الاستخدام</p>
                                <div class="bg-white p-1.5 rounded-lg">
                                    <span class="material-symbols-outlined text-orange-600 text-[18px]">date_range</span>
                                </div>
                            </div>
                            <div class="space-y-1">
                                <p class="text-sm font-bold text-orange-600">
                                    من: @firstDate.ToString("dd/MM/yyyy")
                                </p>
                                <p class="text-sm font-bold text-orange-600">
                                    إلى: @lastDate.ToString("dd/MM/yyyy")
                                </p>
                            </div>
                            <p class="text-xs text-orange-600/70 mt-2">
                                @((lastDate - firstDate).Days + 1) يوم
                            </p>
                        </div>
                    }
                </div>
            </div>

            <!-- Info Box -->
            <div class="bg-blue-50/50 rounded-2xl border border-blue-100 p-5 shadow-sm">
                <div class="flex items-start gap-3">
                    <span class="material-symbols-outlined text-blue-600 mt-0.5 bg-blue-100 p-1 rounded-full text-[18px]">info</span>
                    <div class="flex flex-col gap-1">
                        <h4 class="text-sm font-bold text-blue-900">معلومة</h4>
                        <p class="text-xs text-blue-700/80 leading-relaxed">
                            هذه الإحصائيات توضح استخدام المنتج "@(product?.Name ?? "المنتج")" في جميع الأنشطة الداخلية للمزرعة.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>