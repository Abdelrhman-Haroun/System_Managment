@model IEnumerable<StoreInventoryItemVM>

@{
    ViewData["Title"] = "مخزون المخزن";
    var store = ViewBag.Store as Store;
    var fromDate = ViewBag.FromDate as DateTime?;
    var toDate = ViewBag.ToDate as DateTime?;
    var searchTerm = ViewBag.SearchTerm as string;
    var totalStockValue = (decimal)ViewBag.TotalStockValue;
    var totalProducts = (int)ViewBag.TotalProducts;
    var lowStockProducts = (int)ViewBag.LowStockProducts;
}

<div class="mb-8 flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-4">
        <div class="size-12 text-primary bg-white rounded-xl shadow-sm border border-border-light p-2.5 flex items-center justify-center">
            <span class="material-symbols-outlined text-[28px]">warehouse</span>
        </div>
        <div>
            <h1 class="text-2xl font-bold text-text-main tracking-tight">تقرير مخزون المخزن</h1>
            <p class="text-sm text-text-secondary mt-1">@store.Name</p>
        </div>
    </div>
    <div class="flex gap-3 w-full md:w-auto">
        <a asp-controller="Store" asp-action="Index"
           class="flex-1 md:flex-none px-6 py-2.5 text-sm font-medium text-text-secondary bg-white border border-border-light rounded-xl hover:bg-gray-50 transition-all text-center">
            رجوع
        </a>
        <button onclick="exportInventory()"
                class="flex-1 md:flex-none px-6 py-2.5 text-sm font-medium text-white bg-green-600 rounded-xl hover:bg-green-700 transition-all flex items-center justify-center gap-2">
            <span class="material-symbols-outlined text-[20px]">download</span>
            تصدير
        </button>
    </div>
</div>

<!-- Summary Cards -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
    <div class="bg-white rounded-2xl border border-border-light shadow-sm p-6">
        <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-semibold text-text-secondary">قيمة المخزون الإجمالية</span>
            <span class="material-symbols-outlined text-green-600 bg-green-100 p-2 rounded-lg">attach_money</span>
        </div>
        <div class="text-2xl font-bold text-text-main">@totalStockValue.ToString("N2")</div>
        <div class="text-xs text-text-secondary mt-1">جنيه مصري</div>
    </div>

    <div class="bg-white rounded-2xl border border-border-light shadow-sm p-6">
        <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-semibold text-text-secondary">عدد المنتجات</span>
            <span class="material-symbols-outlined text-blue-600 bg-blue-100 p-2 rounded-lg">inventory_2</span>
        </div>
        <div class="text-2xl font-bold text-text-main">@totalProducts</div>
        <div class="text-xs text-text-secondary mt-1">منتج</div>
    </div>

    <div class="bg-white rounded-2xl border border-border-light shadow-sm p-6">
        <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-semibold text-text-secondary">منتجات تحت الحد الأدنى</span>
            <span class="material-symbols-outlined text-red-600 bg-red-100 p-2 rounded-lg">warning</span>
        </div>
        <div class="text-2xl font-bold text-text-main">@lowStockProducts</div>
        <div class="text-xs text-text-secondary mt-1">منتج</div>
    </div>
</div>

<!-- Filter Section -->
<div class="bg-white rounded-2xl border border-border-light shadow-sm p-6 mb-6">
    <h3 class="text-lg font-bold text-text-main mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-primary">filter_alt</span>
        البحث والتصفية
    </h3>

    <form method="get" asp-action="Inventory" class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <input type="hidden" name="id" value="@store.Id" />

        <div>
            <label class="text-sm font-semibold text-text-secondary mb-2 block">بحث عن منتج</label>
            <input type="text" name="searchTerm" value="@searchTerm" placeholder="اسم المنتج أو الفئة..."
                   class="w-full h-11 rounded-xl border-border-light bg-background-light text-text-main focus:border-primary focus:ring-primary px-3" />
        </div>

        <div>
            <label class="text-sm font-semibold text-text-secondary mb-2 block">من تاريخ</label>
            <input type="date" name="fromDate" value="@fromDate?.ToString("yyyy-MM-dd")"
                   class="w-full h-11 rounded-xl border-border-light bg-background-light text-text-main focus:border-primary focus:ring-primary px-3" />
        </div>

        <div>
            <label class="text-sm font-semibold text-text-secondary mb-2 block">إلى تاريخ</label>
            <input type="date" name="toDate" value="@toDate?.ToString("yyyy-MM-dd")"
                   class="w-full h-11 rounded-xl border-border-light bg-background-light text-text-main focus:border-primary focus:ring-primary px-3" />
        </div>

        <div class="flex items-end gap-2">
            <button type="submit"
                    class="flex-1 h-11 px-6 bg-primary hover:bg-primary-dark text-white font-bold rounded-xl transition-all flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-[20px]">search</span>
                بحث
            </button>
            <a asp-action="Inventory" asp-route-id="@store.Id"
               class="h-11 px-4 bg-gray-200 hover:bg-gray-300 text-text-main font-bold rounded-xl transition-all flex items-center justify-center">
                <span class="material-symbols-outlined text-[20px]">refresh</span>
            </a>
        </div>
    </form>
</div>

<!-- Inventory Table -->
<div class="bg-white rounded-2xl border border-border-light shadow-sm overflow-hidden">
    @if (Model != null && Model.Any())
    {
        <div class="overflow-x-auto">
            <table class="w-full min-w-[1200px]">
                <thead class="bg-gray-50 border-b border-border-light">
                    <tr>
                        <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase">المنتج</th>
                        <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase">الفئة</th>
                        <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase">النوع</th>
                        <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase">المخزون الحالي</th>
                        <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase">إجمالي الوارد</th>
                        <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase">إجمالي الصادر</th>
                        <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase">متوسط سعر الشراء</th>
                        <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase">قيمة المخزون</th>
                        <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase">آخر حركة</th>
                        <th class="py-4 px-4 text-center text-xs font-bold text-text-secondary uppercase">الإجراءات</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border-light">
                    @foreach (var item in Model)
                    {
                        var stockClass = ProductTypeExtensions.IsLowStock(item.ProductType, item.CurrentStock)
                            ? "text-red-600"
                            : "text-text-main";

                        <tr class="hover:bg-gray-50/50 transition-colors">
                            <td class="py-4 px-4 text-sm font-medium text-text-main">
                                @item.ProductName
                            </td>
                            <td class="py-4 px-4 text-sm text-text-secondary">
                                @item.CategoryName
                            </td>
                            <td class="py-4 px-4 text-sm">
                                @if (ProductTypeExtensions.IsCountType(item.ProductType))
                                {
                                    <span class="inline-flex items-center gap-1 px-2 py-1 bg-blue-100 text-blue-800 text-xs font-bold rounded-full">
                                        <span class="material-symbols-outlined text-[14px]">counter_1</span>
                                        عددي
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1 px-2 py-1 bg-purple-100 text-purple-800 text-xs font-bold rounded-full">
                                        <span class="material-symbols-outlined text-[14px]">scale</span>
                                        وزني
                                    </span>
                                }
                            </td>
                            <td class="py-4 px-4 text-sm font-bold @stockClass">
                                @item.CurrentStock.ToString("N2")
                                @if (ProductTypeExtensions.IsLowStock(item.ProductType, item.CurrentStock))
                                {
                                    <span class="material-symbols-outlined text-red-600 text-[16px] ml-1">warning</span>
                                }
                            </td>
                            <td class="py-4 px-4 text-sm text-green-600 font-medium">
                                +@item.TotalIn.ToString("N2")
                            </td>
                            <td class="py-4 px-4 text-sm text-red-600 font-medium">
                                -@item.TotalOut.ToString("N2")
                            </td>
                            <td class="py-4 px-4 text-sm text-text-secondary">
                                @item.AveragePurchasePrice.ToString("N2") جنيه
                            </td>
                            <td class="py-4 px-4 text-sm font-bold text-primary">
                                @item.StockValue.ToString("N2") جنيه
                            </td>
                            <td class="py-4 px-4 text-sm text-text-secondary">
                                @if (item.LastTransactionDate.HasValue)
                                {
                                    @item.LastTransactionDate.Value.ToString("dd/MM/yyyy")
                                }
                                else
                                {
                                    <span class="text-gray-400">-</span>
                                }
                            </td>
                            <td class="py-4 px-4 text-center">
                                <div class="flex items-center justify-center gap-2">
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId"
                                       class="text-slate-600 hover:text-slate-800 p-2 hover:bg-slate-100 rounded-lg transition-all"
                                       title="عرض التفاصيل">
                                        <span class="material-symbols-outlined text-[20px]">visibility</span>
                                    </a>
                                    <a asp-controller="Product" asp-action="Transactions" asp-route-id="@item.ProductId"
                                       class="text-primary hover:text-primary-dark p-2 hover:bg-primary/10 rounded-lg transition-all"
                                       title="عرض الحركات">
                                        <span class="material-symbols-outlined text-[20px]">history</span>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="p-12 text-center">
            <span class="material-symbols-outlined text-gray-400 text-6xl mb-4">warehouse</span>
            <p class="text-text-secondary text-lg font-medium mb-2">لا توجد منتجات</p>
            <p class="text-text-secondary text-sm">لا يوجد منتجات في هذا المخزن</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        function exportInventory() {
            const storeId = @store.Id;
            const fromDate = '@fromDate?.ToString("yyyy-MM-dd")';
            const toDate = '@toDate?.ToString("yyyy-MM-dd")';

            let url = `/Store/ExportInventory?id=${storeId}`;
            if (fromDate) url += `&fromDate=${fromDate}`;
            if (toDate) url += `&toDate=${toDate}`;

            window.location.href = url;
        }
    </script>
}
