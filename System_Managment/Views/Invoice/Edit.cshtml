
@model UpdateInvoiceVM

@{
    ViewData["Title"] = "تعديل الفاتورة";
}

<div class="mb-6 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
    <div class="flex items-start gap-4">
        <div class="size-12 text-primary bg-white rounded-xl shadow-sm border border-border-light p-2.5 flex items-center justify-center">
            <span class="material-symbols-outlined text-[28px]">edit_note</span>
        </div>
        <div>
            <h1 class="text-2xl font-bold text-text-main tracking-tight">تعديل الفاتورة</h1>
        </div>
    </div>
    <div class="flex gap-3 w-full md:w-auto">
        <a asp-action="Index" class="flex-1 md:flex-none px-6 py-2.5 text-sm font-medium text-text-secondary bg-white border border-border-light rounded-xl hover:bg-gray-50 hover:text-text-main focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary/20 transition-all text-center">
            إلغاء
        </a>
    </div>
</div>

<form id="invoiceForm" method="post" asp-action="Edit" asp-route-id="@Model.Id">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8">
        <!-- Main Content -->
        <div class="lg:col-span-9 flex flex-col gap-6">

            <!-- Invoice Type Display (Read-only) -->
            <div class="bg-surface-light rounded-2xl border border-border-light shadow-sm p-6">
                @if (Model.InvoiceType == InvoiceTypes.Purchase)
                {
                    <div class="inline-flex items-center gap-2 px-4 py-2 bg-blue-100 text-blue-800 font-bold rounded-xl">
                        <span class="material-symbols-outlined text-[24px]">shopping_bag</span>
                        فاتورة مشتريات
                    </div>
                }
                else
                {
                    <div class="inline-flex items-center gap-2 px-4 py-2 bg-green-100 text-green-800 font-bold rounded-xl">
                        <span class="material-symbols-outlined text-[24px]">sell</span>
                        فاتورة مبيعات
                    </div>
                }
                <input type="hidden" asp-for="InvoiceType" />
            </div>

            <!-- Supplier Section (Purchase) -->
            @if (Model.InvoiceType == InvoiceTypes.Purchase)
            {
                <section class="bg-surface-light rounded-2xl border border-border-light shadow-sm p-6 lg:p-8">
                    <h3 class="text-lg font-bold text-text-main mb-6 flex items-center gap-2 pb-4 border-b border-border-light">
                        <span class="material-symbols-outlined text-primary bg-primary/10 p-1.5 rounded-lg">store</span>
                        بيانات المورد الأساسية
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="flex flex-col gap-2 md:col-span-2">
                            <label class="text-sm font-semibold text-text-main">المورد <span class="text-red-500">*</span></label>
                            <div class="relative">
                                <select asp-for="SupplierId" asp-items="@(new SelectList(ViewBag.Suppliers, "Id", "Name"))"
                                        class="w-full h-12 rounded-xl border-border-light bg-background-light text-text-main text-sm focus:border-primary focus:ring-primary pr-10 pl-3 transition-colors appearance-none">
                                    <option value="" disabled>اختر المورد...</option>
                                </select>
                                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-text-secondary">
                                    <span class="material-symbols-outlined text-[20px]">expand_more</span>
                                </div>
                                <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center px-3 text-primary/60">
                                    <span class="material-symbols-outlined text-[20px]">store</span>
                                </div>
                            </div>
                            <span asp-validation-for="SupplierId" class="text-red-600 text-sm"></span>
                        </div>

                        <div class="flex flex-col gap-2">
                            <label class="text-sm font-semibold text-text-main">تاريخ الفاتورة <span class="text-red-500">*</span></label>
                            <div class="relative">
                                <input asp-for="InvoiceDate" type="date"
                                       class="w-full h-12 rounded-xl border-border-light bg-background-light text-text-main text-sm focus:border-primary focus:ring-primary pl-10 text-right px-3" />
                                <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center px-3 text-primary/60">
                                    <span class="material-symbols-outlined text-[20px]">calendar_today</span>
                                </div>
                            </div>
                            <span asp-validation-for="InvoiceDate" class="text-red-600 text-sm"></span>
                        </div>

                        <div class="flex flex-col gap-2">
                            <label class="text-sm font-semibold text-text-main">رقم المرجع (اختياري)</label>
                            <div class="relative">
                                <input asp-for="ReferenceNumber" placeholder="مثال: INV-00123"
                                       class="w-full h-12 rounded-xl border-border-light bg-background-light text-text-main text-sm focus:border-primary focus:ring-primary placeholder:text-gray-400 pl-10 pr-3" />
                                <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center px-3 text-primary/60">
                                    <span class="material-symbols-outlined text-[20px]">tag</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            }

            <!-- Customer Section (Sales) -->
            @if (Model.InvoiceType == InvoiceTypes.Sales)
            {
                <section class="bg-surface-light rounded-2xl border border-border-light shadow-sm p-6 lg:p-8">
                    <h3 class="text-lg font-bold text-text-main mb-6 flex items-center gap-2 pb-4 border-b border-border-light">
                        <span class="material-symbols-outlined text-primary bg-primary/10 p-1.5 rounded-lg">person</span>
                        بيانات العميل الأساسية
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="flex flex-col gap-2 md:col-span-2">
                            <label class="text-sm font-semibold text-text-main">العميل <span class="text-red-500">*</span></label>
                            <div class="relative">
                                <select asp-for="CustomerId" asp-items="@(new SelectList(ViewBag.Customers, "Id", "Name"))"
                                        class="w-full h-12 rounded-xl border-border-light bg-background-light text-text-main text-sm focus:border-primary focus:ring-primary pr-10 pl-3 transition-colors appearance-none">
                                    <option value="" disabled>اختر العميل...</option>
                                </select>
                                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-text-secondary">
                                    <span class="material-symbols-outlined text-[20px]">expand_more</span>
                                </div>
                                <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center px-3 text-primary/60">
                                    <span class="material-symbols-outlined text-[20px]">person</span>
                                </div>
                            </div>
                            <span asp-validation-for="CustomerId" class="text-red-600 text-sm"></span>
                        </div>

                        <div class="flex flex-col gap-2">
                            <label class="text-sm font-semibold text-text-main">تاريخ الفاتورة <span class="text-red-500">*</span></label>
                            <div class="relative">
                                <input asp-for="InvoiceDate" type="date"
                                       class="w-full h-12 rounded-xl border-border-light bg-background-light text-text-main text-sm focus:border-primary focus:ring-primary pl-10 text-right px-3" />
                                <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center px-3 text-primary/60">
                                    <span class="material-symbols-outlined text-[20px]">calendar_today</span>
                                </div>
                            </div>
                            <span asp-validation-for="InvoiceDate" class="text-red-600 text-sm"></span>
                        </div>

                        <div class="flex flex-col gap-2">
                            <label class="text-sm font-semibold text-text-main">رقم المرجع (اختياري)</label>
                            <div class="relative">
                                <input asp-for="ReferenceNumber" placeholder="مثال: SAL-00987"
                                       class="w-full h-12 rounded-xl border-border-light bg-background-light text-text-main text-sm focus:border-primary focus:ring-primary placeholder:text-gray-400 pl-10 pr-3" />
                                <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center px-3 text-primary/60">
                                    <span class="material-symbols-outlined text-[20px]">tag</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            }

            <!-- Invoice Items -->
            <section class="bg-surface-light rounded-2xl border border-border-light shadow-sm p-6 lg:p-8">
                <div class="flex items-center justify-between mb-6 pb-4 border-b border-border-light">
                    <h3 class="text-lg font-bold text-text-main flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary bg-primary/10 p-1.5 rounded-lg">shopping_cart</span>
                        بنود الفاتورة
                    </h3>
                    <div class="text-xs font-semibold bg-primary/10 text-primary px-3 py-1.5 rounded-full border border-primary/20">
                        <span id="itemCount">0</span> بنود
                    </div>
                </div>

                <div class="mb-5 grid gap-3 rounded-2xl border border-primary/10 bg-primary/5 p-4 text-sm text-text-secondary lg:grid-cols-[1fr_auto] lg:items-center">
                    <p class="leading-7">
                        كل صف يعرض رصيد المنتج الحالي مع إجمالي البند.
                    </p>
                    <span class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1.5 font-bold text-primary border border-primary/10">
                        <span class="material-symbols-outlined text-[18px]">table_rows</span>
                        مراجعة البنود قبل الحفظ
                    </span>
                </div>

                <div class="overflow-hidden rounded-xl border border-border-light">
                    <div class="invoice-items-shell overflow-x-auto">
                        <table class="invoice-items-table w-full min-w-[980px] border-collapse bg-white">
                            <thead>
                                <tr class="bg-gray-50 border-b border-border-light">
                                    <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider w-[6%]">#</th>
                                    <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider w-[28%]">المنتج</th>
                                    <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider w-[12%]">الكمية</th>
                                    <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider w-[14%]">الوزن (كجم)</th>
                                    <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider w-[20%]">سعر الكيلو</th>
                                    <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider w-[14%]">الإجمالي</th>
                                    <th class="py-4 px-4 text-center text-xs font-bold text-text-secondary uppercase tracking-wider w-[6%]">إجراءات</th>
                                </tr>
                            </thead>
                            <tbody id="invoiceItemsBody" class="divide-y divide-border-light">
                                <!-- Items will be added here dynamically -->
                            </tbody>
                        </table>
                    </div>

                    <div class="bg-gray-50 p-3 border-t border-border-light">
                        <button type="button" id="addItemBtn" class="flex items-center gap-2 text-primary hover:text-primary-dark font-bold text-sm transition-colors py-2 px-4 rounded-lg hover:bg-white hover:shadow-sm border border-transparent hover:border-border-light w-full justify-center sm:justify-start sm:w-auto">
                            <span class="material-symbols-outlined text-[20px]">add_circle</span>
                            إضافة بند جديد
                        </button>
                    </div>
                </div>
            </section>

            <!-- Notes -->
            <section class="bg-surface-light rounded-2xl border border-border-light shadow-sm p-6 lg:p-8">
                <div class="mb-4 flex items-start justify-between gap-3">
                    <h3 class="text-lg font-bold text-text-main flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary bg-primary/10 p-1.5 rounded-lg">description</span>
                    ملاحظات إضافية
                    </h3>
                    <span class="rounded-full bg-amber-50 px-3 py-1 text-xs font-bold text-amber-700 border border-amber-200">
                        التسعير = الوزن × سعر الكيلو
                    </span>
                </div>
                <textarea asp-for="Notes" class="w-full rounded-xl border-border-light bg-background-light text-text-main text-sm focus:border-primary focus:ring-primary min-h-[120px] p-4 placeholder:text-gray-400 resize-y leading-relaxed"
                          placeholder="أضف أي ملاحظات إضافية حول الفاتورة هنا..."></textarea>
            </section>
        </div>

        <!-- Summary Sidebar -->
        <div class="lg:col-span-3 space-y-6">
            <!-- Sticky container for both blocks -->
            <div class="lg:sticky lg:top-6 lg:self-start">
                <!-- Summary Card -->
                <section class="bg-surface-light rounded-2xl border border-border-light shadow-sm p-6 mb-6">
                    <h3 class="text-lg font-bold text-text-main mb-6 flex items-center gap-2 pb-4 border-b border-border-light">
                        <span class="material-symbols-outlined text-primary bg-primary/10 p-1.5 rounded-lg">payments</span>
                        ملخص الفاتورة
                    </h3>

                    <div class="space-y-5">
                        <div class="flex items-center justify-between text-sm group">
                            <span class="text-text-secondary font-medium">الإجمالي الفرعي</span>
                            <span id="subtotalDisplay" class="font-bold text-text-main text-base">0.00 جنيه مصرى</span>
                        </div>

                        <div class="pt-2">
                            <label class="text-xs font-bold text-text-secondary mb-2 block uppercase tracking-wide">قيمة الخصم</label>
                            <div class="relative">
                                <input asp-for="DiscountAmount" id="discountInput" type="number" step="0.01" min="0"
                                       class="w-full h-11 rounded-xl border-border-light bg-background-light text-text-main text-lg font-medium focus:border-primary focus:ring-primary pr-3 pl-20 text-left transition-shadow"
                                       dir="ltr" placeholder="0.00" />
                                <span class="absolute left-3 top-3 text-xs text-text-secondary font-bold">جنيه مصرى</span>
                                <span class="absolute right-3 top-3 text-primary/60 material-symbols-outlined text-[20px]">local_offer</span>
                            </div>
                        </div>

                        <div class="pt-2">
                            <label class="text-xs font-bold text-text-secondary mb-2 block uppercase tracking-wide">قيمة الضريبة</label>
                            <div class="relative">
                                <input asp-for="TaxAmount" id="taxInput" type="number" step="0.01" min="0"
                                       class="w-full h-11 rounded-xl border-border-light bg-background-light text-text-main text-lg font-medium focus:border-primary focus:ring-primary pr-3 pl-20 text-left transition-shadow"
                                       dir="ltr" placeholder="0.00" />
                                <span class="absolute left-3 top-3 text-xs text-text-secondary font-bold">جنيه مصرى</span>
                                <span class="absolute right-3 top-3 text-primary/60 material-symbols-outlined text-[20px]">account_balance</span>
                            </div>
                        </div>

                        <div class="border-t-2 border-dashed border-border-light my-2"></div>

                        <div class="bg-primary/5 rounded-xl p-4 border border-primary/10 text-center">
                            <span class="block text-sm font-semibold text-text-secondary mb-1">المبلغ الإجمالي</span>
                            <div class="flex items-center justify-center gap-1 text-primary">
                                <span id="totalDisplay" class="text-3xl font-bold tracking-tight">0.00</span>
                                <span class="text-sm font-bold mt-2">جنيه مصرى</span>
                            </div>
                        </div>

                        <button type="submit" class="w-full py-4 px-6 bg-primary hover:bg-primary-dark text-white font-bold text-lg rounded-xl shadow-lg shadow-primary/20 hover:shadow-primary/40 transition-all transform active:scale-[0.98] flex items-center justify-center gap-3 mt-4">
                            <span>حفظ التعديلات</span>
                            <span class="material-symbols-outlined">save</span>
                        </button>

                    </div>
                </section>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        // Invoice items management
        let itemIndex = 0;
        let totalsFrame = null;
        const products = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.Products ?? new List<object>()));
        const existingItems = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Items));
        const itemBody = $('#invoiceItemsBody');
        const productMap = new Map(products.map(product => [String(product.Id), product]));
        const currencyFormatter = new Intl.NumberFormat('ar-EG', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        });

        // Initialize
        $(document).ready(function() {
            ensureDateInputsDefaultToToday();

            // Load existing items
            existingItems.forEach(item => {
                addInvoiceItem(item);
            });

            // Event listeners
            $('#addItemBtn').on('click', () => addInvoiceItem());
            $('#discountInput, #taxInput').on('input', scheduleTotalsCalculation);
            itemBody.on('input', '.item-quantity, .item-price, .item-weight', scheduleTotalsCalculation);
            itemBody.on('change', '.item-product', function() {
                updateRowMetadata($(this).closest('tr'));
                scheduleTotalsCalculation();
            });
            itemBody.on('click', '.remove-item', function() {
                removeInvoiceItem($(this).closest('tr'));
            });

            // Initial calculation
            calculateTotals();
        });

        function ensureDateInputsDefaultToToday() {
            const today = new Date().toISOString().split('T')[0];
            $('input[type="date"]').each(function() {
                if (!$(this).val()) {
                    $(this).val(today);
                }
            });
        }

        function addInvoiceItem(existingItem = null) {
            const productOptions = products.map(p =>
                `<option value="${p.Id}" ${existingItem && existingItem.ProductId == p.Id ? 'selected' : ''}>${p.Name}</option>`
            ).join('');

            const row = `
                <tr class="group hover:bg-gray-50/50 transition-colors item-row" data-index="${itemIndex}">
                    <td data-label="#" class="py-4 px-4 align-top">
                        <div class="item-row-number inline-flex size-9 items-center justify-center rounded-xl bg-primary/10 font-bold text-primary">1</div>
                    </td>
                    <td data-label="المنتج" class="py-4 px-4 align-top">
                        <div class="relative">
                            <select name="Items[${itemIndex}].ProductId" class="item-product w-full rounded-lg border-border-light text-sm text-text-main focus:border-primary focus:ring-primary py-2.5 bg-white pr-8 pl-3" required>
                                <option value="">اختر المنتج...</option>
                                ${productOptions}
                            </select>
                            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-text-secondary">
                                <span class="material-symbols-outlined text-[18px]">category</span>
                            </div>
                        </div>
                        <div class="item-stock mt-2 text-xs font-medium text-text-secondary">اختر منتجاً لعرض الرصيد الحالي</div>
                    </td>
                    <td data-label="الكمية" class="py-4 px-4 align-top">
                        <input name="Items[${itemIndex}].Quantity" type="number" min="1" value="${existingItem ? existingItem.Quantity : 1}" inputmode="numeric"
                               class="item-quantity w-full rounded-lg border-border-light text-sm text-text-main focus:border-primary focus:ring-primary py-2.5 px-3 text-center bg-white" required />
                    </td>
                    <td data-label="الوزن (كجم)" class="py-4 px-4 align-top">
                        <input name="Items[${itemIndex}].Weight" type="number" step="0.01" min="0.01" value="${existingItem ? existingItem.Weight : 1}" inputmode="decimal"
                               class="item-weight w-full rounded-lg border-border-light text-sm text-text-main focus:border-primary focus:ring-primary py-2.5 px-3 text-center bg-white" />
                    </td>
                    <td data-label="سعر الكيلو" class="py-4 px-4 align-top">
                        <div class="relative min-w-[12rem]">
                            <input name="Items[${itemIndex}].UnitPrice" type="number" step="0.01" min="0.01" value="${existingItem ? existingItem.UnitPrice : ''}" inputmode="decimal"
                                   class="item-price w-full rounded-lg border-border-light text-sm text-text-main focus:border-primary focus:ring-primary py-2.5 pr-3 pl-20 bg-white" placeholder="ادخل السعر" required />
                            <span class="absolute left-2.5 top-2.5 text-xs font-medium text-text-secondary">جنيه مصرى</span>
                        </div>
                    </td>
                    <td data-label="الإجمالي" class="py-4 px-4 align-top">
                        <div class="item-total rounded-xl border border-primary/10 bg-primary/5 px-3 py-3 text-center text-sm font-bold text-primary">0.00 جنيه</div>
                    </td>
                    <td data-label="إجراءات" class="py-4 px-4 text-center align-top">
                        <button type="button" class="remove-item text-gray-400 hover:text-red-600 hover:bg-red-50 transition-all p-2 rounded-lg">
                            <span class="material-symbols-outlined text-[20px]">delete_outline</span>
                        </button>
                    </td>
                </tr>
            `;

            itemBody.append(row);

            itemIndex++;
            updateItemCount();
            updateRowMetadata(itemBody.find('.item-row').last());
            scheduleTotalsCalculation();
        }

        function removeInvoiceItem($row) {
            if ($('.item-row').length > 1) {
                $row.remove();
                updateItemCount();
                scheduleTotalsCalculation();
            } else {
                Swal.fire('تنبيه', 'يجب أن يحتوي الفاتورة على بند واحد على الأقل', 'warning');
            }
        }

        function updateItemCount() {
            const rows = $('.item-row');
            const count = rows.length;
            $('#itemCount').text(count);
            rows.each(function(index) {
                $(this).find('.item-row-number').text(index + 1);
            });
        }

        function updateRowMetadata($row) {
            const product = productMap.get(String($row.find('.item-product').val()));
            const $stock = $row.find('.item-stock');

            if (!product) {
                $stock.text('اختر منتجاً لعرض الرصيد الحالي');
                return;
            }

            const stockUnit = Number(product.ProductType) === 1 ? 'قطعة' : 'كجم';
            const stockValue = Number(product.StockQuantity || 0).toLocaleString('ar-EG', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });

            $stock.text(`الرصيد الحالي: ${stockValue} ${stockUnit}`);
        }

        function scheduleTotalsCalculation() {
            if (totalsFrame !== null) {
                window.cancelAnimationFrame(totalsFrame);
            }

            totalsFrame = window.requestAnimationFrame(function() {
                totalsFrame = null;
                calculateTotals();
            });
        }

        function formatCurrency(value, suffix) {
            return `${currencyFormatter.format(value)} ${suffix}`;
        }

        function calculateTotals() {
            let subtotal = 0;

            $('.item-row').each(function() {
                const weight = parseFloat($(this).find('.item-weight').val()) || 0;
                const price = parseFloat($(this).find('.item-price').val()) || 0;
                const rowTotal = weight * price;
                $(this).find('.item-total').text(formatCurrency(rowTotal, 'جنيه'));
                subtotal += rowTotal;
            });

            // Get discount and tax
            const discount = parseFloat($('#discountInput').val()) || 0;
            const tax = parseFloat($('#taxInput').val()) || 0;

            // Calculate total
            const total = Math.max(subtotal - discount + tax, 0);

            // Update displays
            $('#subtotalDisplay').text(formatCurrency(subtotal, 'جنيه مصرى'));
            $('#totalDisplay').text(currencyFormatter.format(total));
        }

        // Form submission
        $('#invoiceForm').on('submit', function(e) {
            e.preventDefault();

            // Validate items
            if ($('.item-row').length === 0) {
                Swal.fire('خطأ', 'يجب إضافة بند واحد على الأقل', 'error');
                return;
            }

            // Validate product selection
            let hasEmptyProduct = false;
            $('.item-product').each(function() {
                if (!$(this).val()) {
                    hasEmptyProduct = true;
                }
            });

            if (hasEmptyProduct) {
                Swal.fire('خطأ', 'يرجى اختيار المنتج لجميع البنود', 'error');
                return;
            }

            let hasInvalidWeight = false;
            $('.item-weight').each(function() {
                if ((parseFloat($(this).val()) || 0) <= 0) {
                    hasInvalidWeight = true;
                }
            });

            if (hasInvalidWeight) {
                Swal.fire('خطأ', 'يرجى إدخال وزن أكبر من صفر لكل بند لأن التسعير يعتمد على الوزن', 'error');
                return;
            }

            let hasInvalidPrice = false;
            $('.item-price').each(function() {
                if ((parseFloat($(this).val()) || 0) <= 0) {
                    hasInvalidPrice = true;
                }
            });

            if (hasInvalidPrice) {
                Swal.fire('خطأ', 'يرجى إدخال سعر صحيح لكل بند في الفاتورة', 'error');
                return;
            }

            // Submit form
            const formData = $(this).serialize();

            $.ajax({
                url: $(this).attr('action'),
                type: 'POST',
                data: formData,
                success: function(response) {
                    if (response.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'تم بنجاح!',
                            text: response.message || 'تم تحديث الفاتورة بنجاح',
                            confirmButtonText: 'حسناً'
                        }).then(() => {
                            window.location.href = response.redirectUrl || '@Url.Action("Index")';
                        });
                    } else {
                        Swal.fire('خطأ', response.message || 'حدث خطأ أثناء تحديث الفاتورة', 'error');
                    }
                },
                error: function(xhr) {
                    let msg = 'حدث خطأ أثناء الاتصال بالخادم';
                    if (xhr.responseJSON && xhr.responseJSON.message) {
                        msg = xhr.responseJSON.message;
                    }
                    Swal.fire('خطأ', msg, 'error');
                }
            });
        });
    </script>

    <style>
        @@media (max-width: 1023.98px) {
            .invoice-items-shell {
                overflow-x: visible;
            }

            .invoice-items-table {
                min-width: 100%;
            }

            .invoice-items-table thead {
                display: none;
            }

            .invoice-items-table,
            .invoice-items-table tbody,
            .invoice-items-table tr,
            .invoice-items-table td {
                display: block;
                width: 100%;
            }

            .invoice-items-table tr {
                padding: 1rem;
                border-bottom: 1px solid #e5e7eb;
                background: #fff;
            }

            .invoice-items-table td {
                padding: 0.5rem 0;
                border: 0;
                text-align: right;
            }

            .invoice-items-table td::before {
                content: attr(data-label);
                display: block;
                margin-bottom: 0.35rem;
                color: #64748b;
                font-size: 0.75rem;
                font-weight: 700;
            }

            .invoice-items-table td[data-label="إجراءات"] {
                padding-top: 0.25rem;
            }
        }
    </style>
}
