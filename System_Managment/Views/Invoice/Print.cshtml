@model InvoiceDetailsVM

@{
    ViewData["Title"] = $"طباعة الفاتورة - {Model.InvoiceNumber}";
    Layout = null; // No layout for print
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        @@media print {
            .no-print {
                display: none !important;
            }

            .page-break {
                page-break-after: always;
            }

            body {
                print-color-adjust: exact;
                -webkit-print-color-adjust: exact;
            }
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            font-size: 12px;
            line-height: 1.4;
            color: #333;
        }

        .invoice-container {
            width: 210mm; /* A4 width */
            margin: 0 auto;
            background: white;
        }

        .invoice-copy {
            padding: 15mm;
            min-height: 148.5mm; /* Half A4 height */
            border: 2px dashed #ccc;
            position: relative;
        }

        .copy-label {
            position: absolute;
            top: 10px;
            left: 10px;
            background: #f0f0f0;
            padding: 5px 15px;
            border-radius: 5px;
            font-weight: bold;
            font-size: 11px;
            color: #666;
        }

        /* Header */
        .invoice-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 3px solid #2a7f40;
        }

        .company-info {
            flex: 1;
        }

        .company-logo {
            max-width: 120px;
            max-height: 80px;
            margin-bottom: 10px;
        }

        .company-name {
            font-size: 22px;
            font-weight: bold;
            color: #2a7f40;
            margin-bottom: 5px;
        }

        .company-details {
            font-size: 10px;
            color: #666;
            line-height: 1.6;
        }

        .invoice-title {
            text-align: center;
            flex: 1;
        }

            .invoice-title h1 {
                font-size: 24px;
                color: #2a7f40;
                margin-bottom: 5px;
            }

        .invoice-type-badge {
            display: inline-block;
            padding: 5px 20px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
        }

        .badge-purchase {
            background: #dbeafe;
            color: #1e40af;
        }

        .badge-sales {
            background: #dcfce7;
            color: #166534;
        }

        /* Invoice Info Grid */
        .invoice-info {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 20px;
            background: #f9fafb;
            padding: 15px;
            border-radius: 8px;
        }

        .info-group label {
            font-size: 10px;
            color: #666;
            font-weight: 600;
            display: block;
            margin-bottom: 3px;
        }

        .info-group .value {
            font-size: 12px;
            color: #333;
            font-weight: 500;
        }

        /* Items Table */
        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
            font-size: 11px;
        }

            .items-table thead {
                background: #2a7f40;
                color: white;
            }

            .items-table th {
                padding: 8px;
                text-align: right;
                font-weight: 600;
                font-size: 10px;
            }

            .items-table tbody tr {
                border-bottom: 1px solid #e5e7eb;
            }

                .items-table tbody tr:nth-child(even) {
                    background: #f9fafb;
                }

            .items-table td {
                padding: 8px;
                text-align: right;
            }

        .text-center {
            text-align: center !important;
        }

        .text-left {
            text-align: left !important;
        }

        /* Totals */
        .totals-section {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 20px;
        }

        .totals-box {
            width: 300px;
            border: 2px solid #e5e7eb;
            border-radius: 8px;
            overflow: hidden;
        }

        .total-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 15px;
            border-bottom: 1px solid #e5e7eb;
        }

            .total-row:last-child {
                border-bottom: none;
            }

            .total-row.grand-total {
                background: #2a7f40;
                color: white;
                font-weight: bold;
                font-size: 14px;
            }

        .total-label {
            font-weight: 600;
            font-size: 11px;
        }

        .total-value {
            font-weight: bold;
            font-size: 12px;
        }

        /* Footer */
        .invoice-footer {
            margin-top: 30px;
            padding-top: 15px;
            border-top: 2px solid #e5e7eb;
        }

        .notes-section {
            margin-bottom: 20px;
        }

            .notes-section h4 {
                font-size: 11px;
                font-weight: 600;
                margin-bottom: 5px;
                color: #666;
            }

        .notes-content {
            font-size: 10px;
            color: #666;
            background: #f9fafb;
            padding: 10px;
            border-radius: 5px;
            min-height: 40px;
        }

        .signatures {
            display: flex;
            justify-content: space-between;
            margin-top: 40px;
        }

        .signature-box {
            text-align: center;
            flex: 1;
        }

        .signature-line {
            border-top: 2px solid #333;
            width: 200px;
            margin: 40px auto 5px auto;
        }

        .signature-label {
            font-size: 11px;
            font-weight: 600;
            color: #666;
        }

        /* Print Button */
        .print-button {
            position: fixed;
            top: 20px;
            left: 20px;
            background: #2a7f40;
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            z-index: 1000;
        }

            .print-button:hover {
                background: #236835;
            }
    </style>
</head>
<body>
    <!-- Print Button -->
    <button onclick="window.print()" class="print-button no-print">
        🖨️ طباعة
    </button>

    <div class="invoice-container">
        <!-- COPY 1: Company Copy -->
        <div class="invoice-copy">
            <div class="copy-label">نسخة الشركة</div>

            @await Html.PartialAsync("_InvoicePrintContent", Model)
        </div>

        <!-- Page Break -->
        <div class="page-break"></div>

        <!-- COPY 2: Accountant Copy -->
        <div class="invoice-copy">
            <div class="copy-label">نسخة المحاسب</div>

            @await Html.PartialAsync("_InvoicePrintContent", Model)
        </div>
    </div>

    <script>
        // Auto-print on load (optional)
        // window.onload = function() { window.print(); }
    </script>
</body>
</html>