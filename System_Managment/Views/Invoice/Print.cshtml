@model InvoiceDetailsVM

@{
    ViewData["Title"] = $"طباعة الفاتورة - {Model.InvoiceNumber}";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        @@page {
            size: A4 portrait;
            margin: 8mm;
        }

        * {
            box-sizing: border-box;
        }

        html, body {
            margin: 0;
            padding: 0;
        }

        body {
            font-family: "Cairo", "Segoe UI", sans-serif;
            background: #eef3f1;
            color: #0f172a;
        }

        .print-toolbar {
            position: fixed;
            top: 16px;
            left: 16px;
            z-index: 20;
            display: flex;
            gap: 10px;
        }

        .print-toolbar button {
            border: none;
            border-radius: 999px;
            padding: 10px 16px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 10px 25px rgba(15, 23, 42, 0.14);
        }

        .print-action {
            background: #2a7f40;
            color: #fff;
        }

        .close-action {
            background: #fff;
            color: #0f172a;
        }

        .report-shell {
            width: min(100%, 194mm);
            margin: 0 auto;
            padding: 10mm 0 12mm;
        }

        .report-paper {
            width: 100%;
            background: #fff;
            border-radius: 18px;
            box-shadow: 0 24px 60px rgba(15, 23, 42, 0.1);
            padding: 8mm;
        }

        @@media print {
            body {
                background: #fff;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }

            .print-toolbar {
                display: none !important;
            }

            .report-shell {
                width: auto;
                margin: 0;
                padding: 0;
            }

            .report-paper {
                border-radius: 0;
                box-shadow: none;
                padding: 0;
            }
        }
    </style>
</head>
<body>
    <div class="print-toolbar">
        <button type="button" class="print-action" onclick="window.print()">طباعة</button>
        <button type="button" class="close-action" onclick="window.close()">إغلاق</button>
    </div>

    <main class="report-shell">
        <section class="report-paper">
            @await Html.PartialAsync("_InvoicePrintContentPartial", Model)
        </section>
    </main>
</body>
</html>
