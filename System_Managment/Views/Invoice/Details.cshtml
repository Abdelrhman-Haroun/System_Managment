
@model InvoiceDetailsVM

@{
    ViewData["Title"] = "تفاصيل الفاتورة";
}

<div class="mb-8 flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-4">
        <div class="size-12 text-primary bg-white rounded-xl shadow-sm border border-border-light p-2.5 flex items-center justify-center">
            <span class="material-symbols-outlined text-[28px]">receipt_long</span>
        </div>
        <div>
            <h1 class="text-2xl font-bold text-text-main tracking-tight">تفاصيل الفاتورة</h1>
            <p class="text-sm text-text-secondary mt-1">@Model.InvoiceNumber</p>
        </div>
    </div>
    <div class="flex gap-3 w-full md:w-auto">
        <a asp-action="Index" class="flex-1 md:flex-none px-6 py-2.5 text-sm font-medium text-text-secondary bg-white border border-border-light rounded-xl hover:bg-gray-50 hover:text-text-main focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary/20 transition-all text-center">
            رجوع
        </a>
        <a asp-action="Print" asp-route-id="@Model.Id" target="_blank"
           class="flex-1 md:flex-none px-6 py-2.5 text-sm font-medium text-white bg-purple-600 rounded-xl hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 shadow-sm transition-all flex items-center justify-center gap-2">
            <span class="material-symbols-outlined text-[20px]">print</span>
            طباعة
        </a>
        <a asp-action="TransactionHistory" asp-route-id="@Model.Id" class="flex-1 md:flex-none px-6 py-2.5 text-sm font-medium text-white bg-blue-600 rounded-xl hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 shadow-sm transition-all flex items-center justify-center gap-2">
            <span class="material-symbols-outlined text-[20px]">history</span>
            عرض السجل
        </a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="flex-1 md:flex-none px-6 py-2.5 text-sm font-medium text-white bg-primary rounded-xl hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary shadow-sm transition-all flex items-center justify-center gap-2">
            <span class="material-symbols-outlined text-[20px]">edit</span>
            تعديل
        </a>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8">
    <!-- Main Content -->
    <div class="lg:col-span-8 flex flex-col gap-6">

        <!-- Invoice Type Badge -->
        <div class="bg-surface-light rounded-2xl border border-border-light shadow-sm p-6">
            @if (Model.InvoiceType == InvoiceTypes.Purchase)
            {
                <div class="inline-flex items-center gap-2 px-4 py-2 bg-blue-100 text-blue-800 font-bold rounded-xl">
                    <span class="material-symbols-outlined text-[24px]">shopping_bag</span>
                    فاتورة مشتريات
                </div>
            }
            else
            {
                <div class="inline-flex items-center gap-2 px-4 py-2 bg-green-100 text-green-800 font-bold rounded-xl">
                    <span class="material-symbols-outlined text-[24px]">sell</span>
                    فاتورة مبيعات
                </div>
            }
        </div>

        <!-- Customer/Supplier Info -->
        <section class="bg-surface-light rounded-2xl border border-border-light shadow-sm p-6 lg:p-8">
            <h3 class="text-lg font-bold text-text-main mb-6 flex items-center gap-2 pb-4 border-b border-border-light">
                <span class="material-symbols-outlined text-primary bg-primary/10 p-1.5 rounded-lg">
                    @(Model.InvoiceType == InvoiceTypes.Purchase ? "store" : "person")
                </span>
                @(Model.InvoiceType == InvoiceTypes.Purchase ? "بيانات المورد" : "بيانات العميل")
            </h3>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                <!-- 1. Customer/Supplier Name -->
                <div class="flex flex-col gap-2">
                    <label class="text-sm font-semibold text-text-secondary">
                        @(Model.InvoiceType == InvoiceTypes.Purchase ? "المورد" : "العميل")
                    </label>
                    <p class="text-base font-bold text-text-main break-words">
                        @Model.CustomerOrSupplierName
                    </p>
                </div>

                <!-- 2. Invoice Date -->
                <div class="flex flex-col gap-2">
                    <label class="text-sm font-semibold text-text-secondary">تاريخ الفاتورة</label>
                    <p class="text-base font-bold text-text-main">
                        @Model.InvoiceDate.ToString("dd/MM/yyyy")
                    </p>
                </div>

                <!-- 3. Reference Number -->
                @if (!string.IsNullOrEmpty(Model.ReferenceNumber))
                {
                    <div class="flex flex-col gap-2">
                        <label class="text-sm font-semibold text-text-secondary">رقم المرجع</label>
                        <p class="text-base font-bold text-text-main">
                            @Model.ReferenceNumber
                        </p>
                    </div>
                }
            </div>
        </section>

        <!-- Invoice Items -->
        <section class="bg-surface-light rounded-2xl border border-border-light shadow-sm p-6 lg:p-8">
            <div class="flex items-center justify-between mb-6 pb-4 border-b border-border-light">
                <h3 class="text-lg font-bold text-text-main flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary bg-primary/10 p-1.5 rounded-lg">shopping_cart</span>
                    بنود الفاتورة
                </h3>
                <div class="text-xs font-semibold bg-primary/10 text-primary px-3 py-1.5 rounded-full border border-primary/20">
                    @Model.Items.Count بنود
                </div>
            </div>

            <div class="overflow-hidden rounded-xl border border-border-light">
                <div class="overflow-x-auto">
                    <table class="w-full min-w-[700px] border-collapse bg-white">
                        <thead>
                            <tr class="bg-gray-50 border-b border-border-light">
                                <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">#</th>
                                <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">المنتج</th>
                                <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الكمية</th>
                                <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الوزن (كجم)</th>
                                <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">سعر الكيلو</th>
                                <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الإجمالي</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border-light">
                            @{
                                var index = 1;
                            }
                            @foreach (var item in Model.Items)
                            {
                                <tr class="hover:bg-gray-50/50 transition-colors">
                                    <td class="py-4 px-4 text-sm font-bold text-text-secondary">@index</td>
                                    <td class="py-4 px-4 text-sm font-medium text-text-main">@item.ProductName</td>
                                    <td class="py-4 px-4 text-sm text-text-secondary">@item.Quantity</td>
                                    <td class="py-4 px-4 text-sm text-text-secondary">@item.Weight.ToString("N2")</td>
                                    <td class="py-4 px-4 text-sm font-medium text-text-main">@item.UnitPrice.ToString("N2") جنيه</td>
                                    <td class="py-4 px-4 text-sm font-bold text-primary">@item.TotalPrice.ToString("N2") جنيه</td>
                                </tr>
                                index++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <!-- Notes -->
        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <section class="bg-surface-light rounded-2xl border border-border-light shadow-sm p-6 lg:p-8">
                <h3 class="text-lg font-bold text-text-main mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary bg-primary/10 p-1.5 rounded-lg">description</span>
                    ملاحظات
                </h3>
                <p class="text-sm text-text-secondary leading-relaxed">@Model.Notes</p>
            </section>
        }
    </div>

    <!-- Summary Sidebar -->
    <div class="lg:col-span-4 flex flex-col gap-6">
        <section class="bg-surface-light rounded-2xl border border-border-light shadow-sm p-6 sticky top-6">
            <h3 class="text-lg font-bold text-text-main mb-6 flex items-center gap-2 pb-4 border-b border-border-light">
                <span class="material-symbols-outlined text-primary bg-primary/10 p-1.5 rounded-lg">payments</span>
                ملخص الفاتورة
            </h3>

            <div class="space-y-5">
                <div class="flex items-center justify-between text-sm">
                    <span class="text-text-secondary font-medium">الإجمالي الفرعي</span>
                    <span class="font-bold text-text-main text-base">@Model.SubTotal.ToString("N2") جنيه مصرى</span>
                </div>

                @if (Model.DiscountAmount > 0)
                {
                    <div class="flex items-center justify-between text-sm">
                        <span class="text-text-secondary font-medium">الخصم</span>
                        <span class="font-bold text-red-600 text-base">- @Model.DiscountAmount.ToString("N2") جنيه مصرى</span>
                    </div>
                }

                @if (Model.TaxAmount > 0)
                {
                    <div class="flex items-center justify-between text-sm">
                        <span class="text-text-secondary font-medium">الضريبة</span>
                        <span class="font-bold text-text-main text-base">@Model.TaxAmount.ToString("N2") جنيه مصرى</span>
                    </div>
                }

                <div class="border-t-2 border-dashed border-border-light my-2"></div>

                <div class="bg-primary/5 rounded-xl p-4 border border-primary/10 text-center">
                    <span class="block text-sm font-semibold text-text-secondary mb-1">المبلغ الإجمالي</span>
                    <div class="flex items-center justify-center gap-1 text-primary">
                        <span class="text-3xl font-bold tracking-tight">@Model.TotalAmount.ToString("N2")</span>
                        <span class="text-sm font-bold mt-2">جنيه مصرى</span>
                    </div>
                </div>

                <div class="pt-4 space-y-3">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="w-full py-3 px-6 bg-primary hover:bg-primary-dark text-white font-bold text-base rounded-xl shadow-lg shadow-primary/20 hover:shadow-primary/40 transition-all flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined">edit</span>
                        <span>تعديل الفاتورة</span>
                    </a>

                    <button type="button" onclick="deleteInvoice(@Model.Id)" class="w-full py-3 px-6 bg-red-600 hover:bg-red-700 text-white font-bold text-base rounded-xl shadow-lg shadow-red-600/20 hover:shadow-red-600/40 transition-all flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined">delete</span>
                        <span>حذف الفاتورة</span>
                    </button>
                </div>
            </div>
        </section>

        <div class="bg-blue-50/50 rounded-2xl border border-blue-100 p-5 shadow-sm">
            <div class="flex items-start gap-3">
                <span class="material-symbols-outlined text-blue-600 mt-0.5 bg-blue-100 p-1 rounded-full text-[18px]">info</span>
                <div class="flex flex-col gap-1">
                    <h4 class="text-sm font-bold text-blue-900">معلومات التسعير</h4>
                    <p class="text-xs text-blue-700/80 leading-relaxed">
                        إجمالي كل بند = الوزن × سعر الكيلو.<br />
                        تم إنشاء هذه الفاتورة في <span class="font-semibold">@Model.CreatedAt.ToString("dd/MM/yyyy - hh:mm tt")</span>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Form (Hidden) -->
<form id="deleteForm" method="post" asp-action="Delete" asp-route-id="@Model.Id" style="display: none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />
</form>

@section Scripts {
    <script>
        function deleteInvoice(id) {
            Swal.fire({
                title: 'هل أنت متأكد؟',
                text: "سيتم حذف الفاتورة وإعادة المخزون إلى حالته السابقة",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#2a7f40',
                cancelButtonColor: '#d33',
                confirmButtonText: 'نعم، احذف',
                cancelButtonText: 'إلغاء'
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#deleteForm').submit();
                }
            });
        }
    </script>
}
