@using BLL.ViewModels.Transactions

@{
    ViewData["Title"] = "سجل المعاملات";
    var invoice = ViewBag.Invoice as InvoiceDetailsVM;
    var productTransactions = ViewBag.ProductTransactions as IEnumerable<ProductTransactionVM> ?? Enumerable.Empty<ProductTransactionVM>();
    var customerTransactions = ViewBag.CustomerTransactions as IEnumerable<CustomerTransactionVM> ?? Enumerable.Empty<CustomerTransactionVM>();
    var supplierTransactions = ViewBag.SupplierTransactions as IEnumerable<SupplierTransactionVM> ?? Enumerable.Empty<SupplierTransactionVM>();
}

<div class="mb-8 flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-4">
        <div class="size-12 text-primary bg-white rounded-xl shadow-sm border border-border-light p-2.5 flex items-center justify-center">
            <span class="material-symbols-outlined text-[28px]">history</span>
        </div>
        <div>
            <h1 class="text-2xl font-bold text-text-main tracking-tight">سجل المعاملات</h1>
            <p class="text-sm text-text-secondary mt-1">فاتورة رقم: @invoice?.InvoiceNumber</p>
        </div>
    </div>
    <div class="flex gap-3 w-full md:w-auto">
        <a asp-action="Details" asp-route-id="@invoice?.Id" class="flex-1 md:flex-none px-6 py-2.5 text-sm font-medium text-text-secondary bg-white border border-border-light rounded-xl hover:bg-gray-50 hover:text-text-main focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary/20 transition-all text-center">
            رجوع للفاتورة
        </a>
    </div>
</div>

<!-- Invoice Summary Card -->
@if (invoice != null)
{
    <div class="bg-surface-light rounded-2xl border border-border-light shadow-sm p-6 mb-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <div>
                <label class="text-xs font-semibold text-text-secondary uppercase">نوع الفاتورة</label>
                @if (invoice.InvoiceType == "Purchases")
                {
                    <p class="text-sm font-bold text-blue-600 mt-1">فاتورة مشتريات</p>
                }
                else
                {
                    <p class="text-sm font-bold text-green-600 mt-1">فاتورة مبيعات</p>
                }
            </div>
            <div>
                <label class="text-xs font-semibold text-text-secondary uppercase">العميل/المورد</label>
                <p class="text-sm font-bold text-text-main mt-1">@invoice.CustomerOrSupplierName</p>
            </div>
            <div>
                <label class="text-xs font-semibold text-text-secondary uppercase">التاريخ</label>
                <p class="text-sm font-bold text-text-main mt-1">@invoice.InvoiceDate.ToString("dd/MM/yyyy")</p>
            </div>
            <div>
                <label class="text-xs font-semibold text-text-secondary uppercase">المبلغ الإجمالي</label>
                <p class="text-sm font-bold text-primary mt-1">@invoice.TotalAmount.ToString("N2") جنيه</p>
            </div>
        </div>
    </div>
}

<!-- Product Transactions -->
@if (productTransactions.Any())
{
    <section class="bg-surface-light rounded-2xl border border-border-light shadow-sm p-6 lg:p-8 mb-6">
        <div class="flex items-center justify-between mb-6 pb-4 border-b border-border-light">
            <h3 class="text-lg font-bold text-text-main flex items-center gap-2">
                <span class="material-symbols-outlined text-primary bg-primary/10 p-1.5 rounded-lg">inventory_2</span>
                معاملات المنتجات
            </h3>
            <div class="text-xs font-semibold bg-primary/10 text-primary px-3 py-1.5 rounded-full border border-primary/20">
                @productTransactions.Count() معاملة
            </div>
        </div>

        <div class="overflow-hidden rounded-xl border border-border-light">
            <div class="overflow-x-auto">
                <table class="w-full min-w-[900px] border-collapse bg-white">
                    <thead>
                        <tr class="bg-gray-50 border-b border-border-light">
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">المنتج</th>
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">النوع</th>
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">العملية</th>
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الكمية قبل</th>
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">التغيير</th>
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الوزن</th>
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الكمية بعد</th>
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">سعر الوحدة</th>
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الإجمالي</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border-light">
                        @foreach (var transaction in productTransactions)
                        {
                            <tr class="hover:bg-gray-50/50 transition-colors">
                                <td class="py-4 px-4 text-sm font-medium text-text-main">@transaction.ProductName</td>
                                <td class="py-4 px-4 text-sm">
                                    @if (transaction.ProductType == 1)
                                    {
                                        <span class="inline-flex items-center gap-1 px-2 py-1 bg-blue-100 text-blue-800 text-xs font-bold rounded-full">
                                            <span class="material-symbols-outlined text-[14px]">counter_1</span>
                                            عددي
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1 px-2 py-1 bg-purple-100 text-purple-800 text-xs font-bold rounded-full">
                                            <span class="material-symbols-outlined text-[14px]">scale</span>
                                            وزني
                                        </span>
                                    }
                                </td>
                                <td class="py-4 px-4 text-sm">
                                    @if (transaction.TransactionType == "Purchases")
                                    {
                                        <span class="inline-flex items-center gap-1 px-2 py-1 bg-green-100 text-green-800 text-xs font-bold rounded-full">
                                            <span class="material-symbols-outlined text-[14px]">add</span>
                                            إضافة
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1 px-2 py-1 bg-red-100 text-red-800 text-xs font-bold rounded-full">
                                            <span class="material-symbols-outlined text-[14px]">remove</span>
                                            خصم
                                        </span>
                                    }
                                </td>
                                <td class="py-4 px-4 text-sm text-text-secondary">@transaction.QuantityBefore.ToString("N2")</td>
                                <td class="py-4 px-4 text-sm font-bold @(transaction.TransactionType == "Purchases" ? "text-green-600" : "text-red-600")">
                                    @(transaction.TransactionType == "Purchases" ? "+" : "-")@Math.Abs(transaction.QuantityChanged).ToString("N2")
                                </td>
                                <td class="py-4 px-4 text-sm text-text-secondary">@transaction.WeightChanged.ToString("N2") كجم</td>
                                <td class="py-4 px-4 text-sm font-medium text-text-main">@transaction.QuantityAfter.ToString("N2")</td>
                                <td class="py-4 px-4 text-sm text-text-secondary">@transaction.UnitPrice.ToString("N2") جنيه</td>
                                <td class="py-4 px-4 text-sm font-bold text-primary">@transaction.TotalAmount.ToString("N2") جنيه</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </section>
}

<!-- Customer Transactions -->
@if (customerTransactions.Any())
{
    <section class="bg-surface-light rounded-2xl border border-border-light shadow-sm p-6 lg:p-8 mb-6">
        <div class="flex items-center justify-between mb-6 pb-4 border-b border-border-light">
            <h3 class="text-lg font-bold text-text-main flex items-center gap-2">
                <span class="material-symbols-outlined text-primary bg-primary/10 p-1.5 rounded-lg">person</span>
                معاملات العميل
            </h3>
            <div class="text-xs font-semibold bg-primary/10 text-primary px-3 py-1.5 rounded-full border border-primary/20">
                @customerTransactions.Count() معاملة
            </div>
        </div>

        <div class="overflow-hidden rounded-xl border border-border-light">
            <div class="overflow-x-auto">
                <table class="w-full border-collapse bg-white">
                    <thead>
                        <tr class="bg-gray-50 border-b border-border-light">
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">العميل</th>
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">نوع العملية</th>
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الرصيد قبل</th>
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">المبلغ</th>
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الرصيد بعد</th>
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الوصف</th>
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">التاريخ</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border-light">
                        @foreach (var transaction in customerTransactions)
                        {
                            <tr class="hover:bg-gray-50/50 transition-colors">
                                <td class="py-4 px-4 text-sm font-medium text-text-main">@transaction.CustomerName</td>
                                <td class="py-4 px-4 text-sm">
                                    <span class="inline-flex items-center gap-1 px-2 py-1 bg-blue-100 text-blue-800 text-xs font-bold rounded-full">
                                        مبيعات
                                    </span>
                                </td>
                                <td class="py-4 px-4 text-sm text-text-secondary">@transaction.BalanceBefore.ToString("N2") جنيه</td>
                                <td class="py-4 px-4 text-sm font-bold text-green-600">+@transaction.AmountChanged.ToString("N2") جنيه</td>
                                <td class="py-4 px-4 text-sm font-medium text-text-main">@transaction.BalanceAfter.ToString("N2") جنيه</td>
                                <td class="py-4 px-4 text-sm text-text-secondary">@transaction.Description</td>
                                <td class="py-4 px-4 text-sm text-text-secondary">@transaction.TransactionDate.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </section>
}

<!-- Supplier Transactions -->
@if (supplierTransactions.Any())
{
    <section class="bg-surface-light rounded-2xl border border-border-light shadow-sm p-6 lg:p-8 mb-6">
        <div class="flex items-center justify-between mb-6 pb-4 border-b border-border-light">
            <h3 class="text-lg font-bold text-text-main flex items-center gap-2">
                <span class="material-symbols-outlined text-primary bg-primary/10 p-1.5 rounded-lg">store</span>
                معاملات المورد
            </h3>
            <div class="text-xs font-semibold bg-primary/10 text-primary px-3 py-1.5 rounded-full border border-primary/20">
                @supplierTransactions.Count() معاملة
            </div>
        </div>

        <div class="overflow-hidden rounded-xl border border-border-light">
            <div class="overflow-x-auto">
                <table class="w-full border-collapse bg-white">
                    <thead>
                        <tr class="bg-gray-50 border-b border-border-light">
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">المورد</th>
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">نوع العملية</th>
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الرصيد قبل</th>
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">المبلغ</th>
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الرصيد بعد</th>
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الوصف</th>
                            <th class="py-4 px-4 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">التاريخ</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border-light">
                        @foreach (var transaction in supplierTransactions)
                        {
                            <tr class="hover:bg-gray-50/50 transition-colors">
                                <td class="py-4 px-4 text-sm font-medium text-text-main">@transaction.SupplierName</td>
                                <td class="py-4 px-4 text-sm">
                                    <span class="inline-flex items-center gap-1 px-2 py-1 bg-purple-100 text-purple-800 text-xs font-bold rounded-full">
                                       مشتريات
                                    </span>
                                </td>
                                <td class="py-4 px-4 text-sm text-text-secondary">@transaction.BalanceBefore.ToString("N2") جنيه</td>
                                <td class="py-4 px-4 text-sm font-bold text-green-600">+@transaction.AmountChanged.ToString("N2") جنيه</td>
                                <td class="py-4 px-4 text-sm font-medium text-text-main">@transaction.BalanceAfter.ToString("N2") جنيه</td>
                                <td class="py-4 px-4 text-sm text-text-secondary">@transaction.Description</td>
                                <td class="py-4 px-4 text-sm text-text-secondary">@transaction.TransactionDate.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </section>
}

<!-- Empty State -->
@if (!productTransactions.Any() && !customerTransactions.Any() && !supplierTransactions.Any())
{
    <div class="bg-surface-light rounded-2xl border border-border-light shadow-sm p-12 text-center">
        <span class="material-symbols-outlined text-gray-400 text-6xl mb-4">history</span>
        <p class="text-text-secondary text-lg font-medium mb-2">لا توجد معاملات مسجلة</p>
        <p class="text-text-secondary text-sm">لم يتم تسجيل أي معاملات لهذه الفاتورة حتى الآن</p>
    </div>
}