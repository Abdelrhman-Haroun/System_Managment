@{
    ViewData["Title"] = "الرئيسية";
}

<section class="mb-8 rounded-[2rem] bg-gradient-to-l from-primary via-primary to-emerald-700 p-8 text-white shadow-xl">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl">
            <p class="mb-3 text-sm font-semibold text-white/80">نظام إدارة مزرعة الماشية</p>
            <h1 class="text-3xl font-black leading-tight lg:text-4xl">لوحة تشغيل يومية لإدارة الفواتير والمخزون والحركة المالية</h1>
            <p class="mt-4 text-sm leading-7 text-white/85 lg:text-base">
                من هنا تبدأ البيع والشراء، تسجل المدفوعات والمصروفات، تتابع أرصدة العملاء والموردين، وتصل سريعاً إلى كل الأقسام الأساسية.
            </p>
        </div>
        <div class="grid grid-cols-2 gap-3 text-sm">
            <div class="rounded-2xl border border-white/15 bg-white/10 px-4 py-3 backdrop-blur">
                <div class="text-white/75">الوصول</div>
                <div class="mt-1 text-lg font-bold">شاشة واحدة</div>
            </div>
            <div class="rounded-2xl border border-white/15 bg-white/10 px-4 py-3 backdrop-blur">
                <div class="text-white/75">الهدف</div>
                <div class="mt-1 text-lg font-bold">تشغيل أسرع</div>
            </div>
        </div>
    </div>
</section>

<section class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-4">
    <a asp-controller="Invoice" asp-action="Index" class="group rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
        <div class="mb-4 flex size-12 items-center justify-center rounded-2xl bg-emerald-100 text-emerald-700">
            <span class="material-symbols-outlined">receipt_long</span>
        </div>
        <h2 class="text-lg font-bold text-slate-900">إدارة الفواتير</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">إنشاء فواتير المبيعات والمشتريات ومراجعة التفاصيل والسجل والطباعة من مكان واحد.</p>
    </a>

    <a asp-controller="Payment" asp-action="Index" class="group rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
        <div class="mb-4 flex size-12 items-center justify-center rounded-2xl bg-emerald-100 text-emerald-700">
            <span class="material-symbols-outlined">payments</span>
        </div>
        <h2 class="text-lg font-bold text-slate-900">المدفوعات</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">سجل موحد لمدفوعات العملاء والموردين والموظفين والمصروفات مع تتبع السبب والرصيد لكل جهة.</p>
    </a>

    <a asp-controller="Product" asp-action="Index" class="group rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
        <div class="mb-4 flex size-12 items-center justify-center rounded-2xl bg-blue-100 text-blue-700">
            <span class="material-symbols-outlined">inventory_2</span>
        </div>
        <h2 class="text-lg font-bold text-slate-900">المنتجات والمخزون</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">متابعة الأصناف حسب الوزن أو العدد مع تفاصيل الحركة والمخزون الحالي والاستخدام الداخلي.</p>
    </a>

    <a asp-controller="Store" asp-action="Index" class="group rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
        <div class="mb-4 flex size-12 items-center justify-center rounded-2xl bg-amber-100 text-amber-700">
            <span class="material-symbols-outlined">warehouse</span>
        </div>
        <h2 class="text-lg font-bold text-slate-900">المخازن</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">عرض المخازن والمخزون ونقاط النقص بسرعة مع إمكانية التنقل المباشر إلى حركة المنتجات.</p>
    </a>

    <a asp-controller="InternalUsage" asp-action="Index" class="group rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
        <div class="mb-4 flex size-12 items-center justify-center rounded-2xl bg-rose-100 text-rose-700">
            <span class="material-symbols-outlined">agriculture</span>
        </div>
        <h2 class="text-lg font-bold text-slate-900">الاستخدام الداخلي</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">تسجيل استهلاك المزرعة مع خصم المخزون والرجوع إلى السجلات والتكلفة حسب المنتج أو الفئة.</p>
    </a>

    <a asp-controller="Employees" asp-action="Index" class="group rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
        <div class="mb-4 flex size-12 items-center justify-center rounded-2xl bg-violet-100 text-violet-700">
            <span class="material-symbols-outlined">badge</span>
        </div>
        <h2 class="text-lg font-bold text-slate-900">الموظفون</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">الدخول إلى إدارة الموظفين ومنها الوصول إلى الأنواع والحضور والرواتب من شاشة واحدة.</p>
    </a>

    <a asp-controller="Customer" asp-action="Index" class="group rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
        <div class="mb-4 flex size-12 items-center justify-center rounded-2xl bg-sky-100 text-sky-700">
            <span class="material-symbols-outlined">people</span>
        </div>
        <h2 class="text-lg font-bold text-slate-900">العملاء</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">إدارة بيانات العملاء والانتقال السريع إلى الحركة الخاصة بهم.</p>
    </a>

    <a asp-controller="Supplier" asp-action="Index" class="group rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
        <div class="mb-4 flex size-12 items-center justify-center rounded-2xl bg-orange-100 text-orange-700">
            <span class="material-symbols-outlined">local_shipping</span>
        </div>
        <h2 class="text-lg font-bold text-slate-900">الموردون</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">متابعة الموردين والمعاملات المرتبطة بهم من نفس القسم.</p>
    </a>
    <a asp-controller="Account" asp-action="Index" class="group rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
        <div class="mb-4 flex size-12 items-center justify-center rounded-2xl bg-amber-100 text-amber-700">
            <span class="material-symbols-outlined">manage_accounts</span>
        </div>
        <h2 class="text-lg font-bold text-slate-900">المستخدمون</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">إدارة حسابات الدخول والصلاحيات الأساسية للنظام.</p>
    </a>
</section>

<section class="mt-8 grid grid-cols-1 gap-5 lg:grid-cols-2">
    <div class="rounded-3xl border border-emerald-200 bg-gradient-to-l from-emerald-50 to-white p-6 shadow-sm">
        <div class="flex items-center justify-between gap-4">
            <div>
                <h3 class="text-lg font-bold text-slate-900">إجراءات سريعة</h3>
                <p class="mt-2 text-sm leading-7 text-slate-600">ابدأ العملية الأساسية مباشرة بدل الدخول إلى القوائم ثم البحث عن الصفحة المناسبة.</p>
            </div>
            <div class="flex size-12 items-center justify-center rounded-2xl bg-emerald-100 text-emerald-700">
                <span class="material-symbols-outlined">bolt</span>
            </div>
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-2">
            <a asp-controller="Invoice" asp-action="Create" class="flex items-center justify-between rounded-2xl border border-slate-200 bg-white px-4 py-4 text-sm font-bold text-slate-800 transition hover:-translate-y-0.5 hover:border-emerald-300 hover:shadow-md">
                <span class="flex items-center gap-3"><span class="material-symbols-outlined text-emerald-600">add_card</span>إنشاء فاتورة</span>
                <span class="material-symbols-outlined text-slate-400">arrow_forward</span>
            </a>
            <a asp-controller="Payment" asp-action="Index" class="flex items-center justify-between rounded-2xl border border-slate-200 bg-white px-4 py-4 text-sm font-bold text-slate-800 transition hover:-translate-y-0.5 hover:border-emerald-300 hover:shadow-md">
                <span class="flex items-center gap-3"><span class="material-symbols-outlined text-emerald-600">payments</span>إضافة دفعة</span>
                <span class="material-symbols-outlined text-slate-400">arrow_forward</span>
            </a>
            <a asp-controller="InternalUsage" asp-action="Create" class="flex items-center justify-between rounded-2xl border border-slate-200 bg-white px-4 py-4 text-sm font-bold text-slate-800 transition hover:-translate-y-0.5 hover:border-rose-300 hover:shadow-md">
                <span class="flex items-center gap-3"><span class="material-symbols-outlined text-rose-600">post_add</span>تسجيل استخدام داخلي</span>
                <span class="material-symbols-outlined text-slate-400">arrow_forward</span>
            </a>
            <a asp-controller="Product" asp-action="Index" class="flex items-center justify-between rounded-2xl border border-slate-200 bg-white px-4 py-4 text-sm font-bold text-slate-800 transition hover:-translate-y-0.5 hover:border-blue-300 hover:shadow-md">
                <span class="flex items-center gap-3"><span class="material-symbols-outlined text-blue-600">inventory</span>إدارة المنتجات</span>
                <span class="material-symbols-outlined text-slate-400">arrow_forward</span>
            </a>
            <a asp-controller="Customer" asp-action="Index" class="flex items-center justify-between rounded-2xl border border-slate-200 bg-white px-4 py-4 text-sm font-bold text-slate-800 transition hover:-translate-y-0.5 hover:border-sky-300 hover:shadow-md">
                <span class="flex items-center gap-3"><span class="material-symbols-outlined text-sky-600">person_search</span>إدارة العملاء</span>
                <span class="material-symbols-outlined text-slate-400">arrow_forward</span>
            </a>
            <a asp-controller="Supplier" asp-action="Index" class="flex items-center justify-between rounded-2xl border border-slate-200 bg-white px-4 py-4 text-sm font-bold text-slate-800 transition hover:-translate-y-0.5 hover:border-orange-300 hover:shadow-md">
                <span class="flex items-center gap-3"><span class="material-symbols-outlined text-orange-600">delivery_truck_speed</span>إدارة الموردين</span>
                <span class="material-symbols-outlined text-slate-400">arrow_forward</span>
            </a>
            <a asp-controller="Employees" asp-action="Index" class="flex items-center justify-between rounded-2xl border border-slate-200 bg-white px-4 py-4 text-sm font-bold text-slate-800 transition hover:-translate-y-0.5 hover:border-violet-300 hover:shadow-md">
                <span class="flex items-center gap-3"><span class="material-symbols-outlined text-violet-600">groups</span>قسم الموظفين</span>
                <span class="material-symbols-outlined text-slate-400">arrow_forward</span>
            </a>
            <a asp-controller="Attendance" asp-action="Index" class="flex items-center justify-between rounded-2xl border border-slate-200 bg-white px-4 py-4 text-sm font-bold text-slate-800 transition hover:-translate-y-0.5 hover:border-cyan-300 hover:shadow-md">
                <span class="flex items-center gap-3"><span class="material-symbols-outlined text-cyan-600">event_available</span>تسجيل حضور</span>
                <span class="material-symbols-outlined text-slate-400">arrow_forward</span>
            </a>
            <a asp-controller="Salaries" asp-action="Index" class="flex items-center justify-between rounded-2xl border border-slate-200 bg-white px-4 py-4 text-sm font-bold text-slate-800 transition hover:-translate-y-0.5 hover:border-lime-300 hover:shadow-md">
                <span class="flex items-center gap-3"><span class="material-symbols-outlined text-lime-600">payments</span>الرواتب</span>
                <span class="material-symbols-outlined text-slate-400">arrow_forward</span>
            </a>
            <a asp-controller="EmployeeType" asp-action="Index" class="flex items-center justify-between rounded-2xl border border-slate-200 bg-white px-4 py-4 text-sm font-bold text-slate-800 transition hover:-translate-y-0.5 hover:border-fuchsia-300 hover:shadow-md">
                <span class="flex items-center gap-3"><span class="material-symbols-outlined text-fuchsia-600">badge</span>أنواع الموظفين</span>
                <span class="material-symbols-outlined text-slate-400">arrow_forward</span>
            </a>
            <a asp-controller="Account" asp-action="Index" class="flex items-center justify-between rounded-2xl border border-slate-200 bg-white px-4 py-4 text-sm font-bold text-slate-800 transition hover:-translate-y-0.5 hover:border-amber-300 hover:shadow-md">
                <span class="flex items-center gap-3"><span class="material-symbols-outlined text-amber-600">group_add</span>إدارة المستخدمين</span>
                <span class="material-symbols-outlined text-slate-400">arrow_forward</span>
            </a>
            <a asp-controller="PaymentMethod" asp-action="Index" class="flex items-center justify-between rounded-2xl border border-slate-200 bg-white px-4 py-4 text-sm font-bold text-slate-800 transition hover:-translate-y-0.5 hover:border-indigo-300 hover:shadow-md">
                <span class="flex items-center gap-3"><span class="material-symbols-outlined text-indigo-600">account_balance_wallet</span>وسائل الدفع</span>
                <span class="material-symbols-outlined text-slate-400">arrow_forward</span>
            </a>
        </div>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="text-lg font-bold text-slate-900">ما الذي يمكن إنجازه الآن؟</h3>
        <ul class="mt-4 space-y-3 text-sm text-slate-600">
            <li class="flex items-center gap-3"><span class="material-symbols-outlined text-emerald-600">check_circle</span><span>تسجيل فواتير المشتريات والمبيعات ومراجعة طباعتها</span></li>
            <li class="flex items-center gap-3"><span class="material-symbols-outlined text-emerald-600">check_circle</span><span>إدارة المنتجات والفئات والعملاء والموردين</span></li>
            <li class="flex items-center gap-3"><span class="material-symbols-outlined text-emerald-600">check_circle</span><span>تسجيل مدفوعات العملاء والموردين والموظفين والمصروفات مع متابعة الرصيد</span></li>
            <li class="flex items-center gap-3"><span class="material-symbols-outlined text-emerald-600">check_circle</span><span>مراقبة المخزون الحالي والحدود المنخفضة داخل المخازن</span></li>
            <li class="flex items-center gap-3"><span class="material-symbols-outlined text-emerald-600">check_circle</span><span>الدخول السريع إلى قسم الموظفين ثم إدارة الحضور والرواتب والأنواع من داخله</span></li>
        </ul>

        <div class="mt-6 rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-4 text-sm leading-7 text-slate-600">
            الواجهة الرئيسية أصبحت نقطة وصول سريعة لكل الأقسام الأساسية، مع روابط مباشرة للعمليات اليومية والأقسام المساندة.
        </div>
    </div>
</section>
