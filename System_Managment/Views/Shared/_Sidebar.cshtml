@{
    var IsActive = (Func<string, bool>)ViewData["IsActive"]!;
}

<aside class="sticky top-0 h-screen w-66 bg-neutral-card border-l border-neutral-border hidden lg:flex flex-col justify-between shadow-sm">
    <div class="flex flex-1 flex-col overflow-y-auto py-4 px-4">

        <!-- Logo -->
        <div class="flex items-center gap-3 px-2 mb-8">
            <div class="bg-center bg-no-repeat aspect-square bg-cover rounded-full size-12 ring-4 ring-primary/20"
                 style="background-image: url('@Url.Content("~/Files/images/logo.jpg")');"></div>
            <h1 class="text-lg font-black text-primary">مزرعة آل سالم</h1>
        </div>

        <nav class="flex flex-col gap-1">

            <!-- Dashboard -->
            <a asp-controller="Home" asp-action="Index"
               class="nav-link flex items-center gap-4 px-4 py-3 rounded-lg active">
                <span class="material-symbols-outlined">dashboard</span>
                <span class="font-medium">لوحة التحكم</span>
            </a>

            <!-- Customers -->
            <details class="group nav-section" @(IsActive("/customer") ? "open" : "")>
                <summary class="nav-link flex items-center justify-between gap-4 px-4 py-3 rounded-lg cursor-pointer list-none">
                    <div class="flex items-center gap-4">
                        <span class="material-symbols-outlined">people</span>
                        <span class="font-medium">إدارة العملاء</span>
                    </div>
                    <span class="material-symbols-outlined dropdown-icon">expand_more</span>
                </summary>
                <div class="dropdown-menu">
                    <a asp-controller="Customer" asp-action="Index"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/customer/index") || (IsActive("/customer") && !IsActive("/customer/create") && !IsActive("/customer/rating")) ? "active" : "")">
                        قائمة العملاء
                    </a>
                    <a asp-controller="Customer" asp-action="Rating"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/customer/rating") ? "active" : "")">
                        تقييم العملاء
                    </a>
                </div>
            </details>

            <!-- Suppliers -->
            <details class="group nav-section" @(IsActive("/supplier") ? "open" : "")>
                <summary class="nav-link flex items-center justify-between gap-4 px-4 py-3 rounded-lg cursor-pointer list-none">
                    <div class="flex items-center gap-4">
                        <span class="material-symbols-outlined">local_shipping</span>
                        <span class="font-medium">إدارة الموردين</span>
                    </div>
                    <span class="material-symbols-outlined dropdown-icon">expand_more</span>
                </summary>
                <div class="dropdown-menu">
                    <a asp-controller="Supplier" asp-action="Index"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/supplier/index") || (IsActive("/supplier") && !IsActive("/supplier/create") && !IsActive("/supplier/orders")) ? "active" : "")">
                        قائمة الموردين
                    </a>
                    <a asp-controller="Supplier" asp-action="Orders"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/supplier/orders") ? "active" : "")">
                        طلبات التوريد
                    </a>
                </div>
            </details>

            <!-- Products -->
            <details class="group nav-section" @(IsActive("/product") || IsActive("/productcategory") ? "open" : "")>
                <summary class="nav-link flex items-center justify-between gap-4 px-4 py-3 rounded-lg cursor-pointer list-none">
                    <div class="flex items-center gap-4">
                        <span class="material-symbols-outlined">inventory</span>
                        <span class="font-medium">إدارة المنتجات</span>
                    </div>
                    <span class="material-symbols-outlined dropdown-icon">expand_more</span>
                </summary>
                <div class="dropdown-menu">
                    <a asp-controller="Product" asp-action="Index"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/product/index") || (IsActive("/product") && !IsActive("/product/create") && !IsActive("/productcategory")) ? "active" : "")">
                        قائمة المنتجات
                    </a>
                    <a asp-controller="ProductCategory" asp-action="Index"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/productcategory/index") ? "active" : "")">
                        فئات المنتجات
                    </a>
                </div>
            </details>

            <!-- Stores -->
            <details class="group nav-section" @(IsActive("/store") ? "open" : "")>
                <summary class="nav-link flex items-center justify-between gap-4 px-4 py-3 rounded-lg cursor-pointer list-none">
                    <div class="flex items-center gap-4">
                        <span class="material-symbols-outlined">warehouse</span>
                        <span class="font-medium">إدارة المخازن</span>
                    </div>
                    <span class="material-symbols-outlined dropdown-icon">expand_more</span>
                </summary>
                <div class="dropdown-menu">
                    <a asp-controller="Store" asp-action="Index"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/store/index") ? "active" : "")">قائمة المخازن</a>
                    <a asp-controller="Store" asp-action="Movements"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/stock/movements") ? "active" : "")">حركات المخزون</a>
                    <a asp-controller="Store" asp-action="Count"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/inventory/count") ? "active" : "")">الجرد</a>
                    <a asp-controller="Store" asp-action="Levels"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/stock/levels") ? "active" : "")">مستويات التخزين</a>
                </div>
            </details>

            <!-- Invoices -->
            <details class="group nav-section" @(IsActive("/invoices") ? "open" : "")>
                <summary class="nav-link flex items-center justify-between gap-4 px-4 py-3 rounded-lg cursor-pointer list-none">
                    <div class="flex items-center gap-4">
                        <span class="material-symbols-outlined">receipt</span>
                        <span class="font-medium">الفواتير</span>
                    </div>
                    <span class="material-symbols-outlined dropdown-icon">expand_more</span>
                </summary>
                <div class="dropdown-menu">
                    <a asp-controller="Invoices" asp-action="Sales"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/invoices/sales") ? "active" : "")">فواتير البيع</a>
                    <a asp-controller="Invoices" asp-action="Purchases"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/invoices/purchases") ? "active" : "")">فواتير الشراء</a>
                    <a asp-controller="Invoices" asp-action="Create"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/invoices/create") ? "active" : "")">إنشاء فاتورة</a>
                    <a asp-controller="Invoices" asp-action="Pending"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/invoices/pending") ? "active" : "")">الفواتير المعلقة</a>
                </div>
            </details>

            <!-- Payments -->
            <details class="group nav-section" @(IsActive("/payments") ? "open" : "")>
                <summary class="nav-link flex items-center justify-between gap-4 px-4 py-3 rounded-lg cursor-pointer list-none">
                    <div class="flex items-center gap-4">
                        <span class="material-symbols-outlined">payments</span>
                        <span class="font-medium">المدفوعات</span>
                    </div>
                    <span class="material-symbols-outlined dropdown-icon">expand_more</span>
                </summary>
                <div class="dropdown-menu">
                    <a asp-controller="Payments" asp-action="Create"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/payments/create") ? "active" : "")">تسجيل دفعة</a>
                    <a asp-controller="Payments" asp-action="Index"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/payments/index") ? "active" : "")">سجل المدفوعات</a>
                    <a asp-controller="Payments" asp-action="Due"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/payments/due") ? "active" : "")">الحسابات المستحقة</a>
                    <a asp-controller="Payments" asp-action="Late"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/payments/late") ? "active" : "")">المتأخرات</a>
                </div>
            </details>

            <!-- Employees -->
            <details class="group nav-section" @(IsActive("/employees|/salaries|/attendance") ? "open" : "")>
                <summary class="nav-link flex items-center justify-between gap-4 px-4 py-3 rounded-lg cursor-pointer list-none">
                    <div class="flex items-center gap-4">
                        <span class="material-symbols-outlined">work</span>
                        <span class="font-medium">إدارة الموظفين</span>
                    </div>
                    <span class="material-symbols-outlined dropdown-icon">expand_more</span>
                </summary>
                <div class="dropdown-menu">
                    <a asp-controller="Employees" asp-action="Index"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/employees") ? "active" : "")">قائمة الموظفين</a>
                    <a asp-controller="Employees" asp-action="Create"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/employees/create") ? "active" : "")">إضافة موظف</a>
                    <a asp-controller="Salaries" asp-action="Index"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/salaries") ? "active" : "")">الرواتب</a>
                    <a asp-controller="Attendance" asp-action="Index"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/attendance") ? "active" : "")">الحضور والغياب</a>
                </div>
            </details>

            <!-- Reports -->
            <details class="group nav-section" @(IsActive("/reports") ? "open" : "")>
                <summary class="nav-link flex items-center justify-between gap-4 px-4 py-3 rounded-lg cursor-pointer list-none">
                    <div class="flex items-center gap-4">
                        <span class="material-symbols-outlined">assessment</span>
                        <span class="font-medium">التقارير</span>
                    </div>
                    <span class="material-symbols-outlined dropdown-icon">expand_more</span>
                </summary>
                <div class="dropdown-menu">
                    <a asp-controller="Reports" asp-action="Financial"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/reports/financial") ? "active" : "")">التقارير المالية</a>
                    <a asp-controller="Reports" asp-action="Sales"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/reports/sales") ? "active" : "")">تقارير المبيعات</a>
                    <a asp-controller="Reports" asp-action="Purchases"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/reports/purchases") ? "active" : "")">تقارير المشتريات</a>
                    <a asp-controller="Reports" asp-action="Analytics"
                       class="dropdown-link block px-6 py-2.5 text-sm @(IsActive("/reports/analytics") ? "active" : "")">التحليلات</a>
                </div>
            </details>

        </nav>
    </div>

    <!-- Bottom -->
    <div class="border-t border-neutral-border px-4 py-4">
        <form asp-controller="Account" asp-action="Logout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="flex w-full items-center gap-4 px-4 py-3 rounded-lg text-red-600 hover:bg-red-500/10">
                <span class="material-symbols-outlined">logout</span>
                <span class="font-medium">تسجيل الخروج</span>
            </button>
        </form>
    </div>
</aside>
