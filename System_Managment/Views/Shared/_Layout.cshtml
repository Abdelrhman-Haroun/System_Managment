
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - مزرعة آل سالم</title>
    @* for favicon *@
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" sizes="96x96" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="MyWebSite" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet">

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <style type="text/tailwindcss">
        body {
            font-family: 'Cairo', sans-serif;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24
        }
        /* لإظهار الـ dropdown بحرية خارج الـ overflow */
        details[open] > div.dropdown-menu {
            position: fixed !important;
            z-index: 50;
        }
    </style>

    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#2a7f40",
                        "background-light": "#f1f5f9",
                        "background-dark": "#1a251e",
                        secondary: "#D2B48C",
                        "neutral-bg": "#F8F9FA",
                        "neutral-card": "#FFFFFF",
                        "neutral-text": "#343A40",
                        "neutral-border": "#E9ECEF",
                    },
                    fontFamily: { display: ["Cairo", "sans-serif"] },
                    borderRadius: { DEFAULT: "0.5rem", lg: "0.75rem", xl: "1rem", full: "9999px" },
                },
            },
        }
    </script>
</head>
<body class="font-display bg-background-light text-neutral-text">

    <div class="flex min-h-screen w-full">

        <!-- Sidebar (Desktop Only) -->
        <aside class="sticky top-0 h-screen w-64 bg-neutral-card border-l border-neutral-border hidden lg:flex flex-col justify-between">
            <div class="flex flex-1 flex-col overflow-y-auto py-4">

                <!-- Logo + Farm Name (مرة واحدة فقط) -->
                <div class="flex items-center gap-3 px-6 mb-8">
                    <div class="bg-center bg-no-repeat aspect-square bg-cover rounded-full size-12 ring-4 ring-primary/20"
                         style='background-image: url("@Url.Content("~/Files/images/logo.jpg")")'></div>
                    <h1 class="text-xl font-black text-primary">مزرعة آل سالم</h1>
                </div>

                <!-- Navigation -->
                <nav class="flex flex-col gap-1 px-4">

                    <a asp-controller="Home" asp-action="Index"
                       class="flex items-center gap-4 px-4 py-3 rounded-lg bg-primary/10 text-primary font-bold">
                        <span class="material-symbols-outlined">dashboard</span>
                        لوحة التحكم
                    </a>

                    <!-- إدارة المحاصيل -->
                    <details class="group">
                        <summary class="flex items-center justify-between gap-4 px-4 py-3 rounded-lg text-neutral-text/70 hover:bg-neutral-bg cursor-pointer list-none">
                            <div class="flex items-center gap-4">
                                <span class="material-symbols-outlined">grass</span>
                                <span class="font-medium">إدارة المحاصيل</span>
                            </div>
                            <span class="material-symbols-outlined text-lg transition-transform group-open:-rotate-180">expand_more</span>
                        </summary>
                        <div class="dropdown-menu mt-1 mr-10 space-y-1 bg-neutral-card border border-neutral-border rounded-lg shadow-lg py-2">
                            <a asp-controller="Crops" asp-action="Index" class="block px-6 py-2.5 text-sm text-neutral-text/70 hover:bg-neutral-bg">قائمة المحاصيل</a>
                            <a asp-controller="Crops" asp-action="Add" class="block px-6 py-2.5 text-sm text-neutral-text/70 hover:bg-neutral-bg">إضافة محصول</a>
                            <a asp-controller="Crops" asp-action="Seasons" class="block px-6 py-2.5 text-sm text-neutral-text/70 hover:bg-neutral-bg">المواسم الزراعية</a>
                            <a asp-controller="Crops" asp-action="Irrigation" class="block px-6 py-2.5 text-sm text-neutral-text/70 hover:bg-neutral-bg">جدول الري</a>
                        </div>
                    </details>

                    <!-- الثروة الحيوانية -->
                    <details class="group">
                        <summary class="flex items-center justify-between gap-4 px-4 py-3 rounded-lg text-neutral-text/70 hover:bg-neutral-bg cursor-pointer list-none">
                            <div class="flex items-center gap-4">
                                <span class="material-symbols-outlined">pets</span>
                                <span class="font-medium">الثروة الحيوانية</span>
                            </div>
                            <span class="material-symbols-outlined text-lg transition-transform group-open:-rotate-180">expand_more</span>
                        </summary>
                        <div class="dropdown-menu mt-1 mr-10 space-y-1 bg-neutral-card border border-neutral-border rounded-lg shadow-lg py-2">
                            <a asp-controller="Animals" asp-action="Index" class="block px-6 py-2.5 text-sm text-neutral-text/70 hover:bg-neutral-bg">جميع الحيوانات</a>
                            <a asp-controller="Animals" asp-action="Cows" class="block px-6 py-2.5 text-sm text-neutral-text/70 hover:bg-neutral-bg">الأبقار</a>
                            <a asp-controller="Animals" asp-action="Sheep" class="block px-6 py-2.5 text-sm text-neutral-text/70 hover:bg-neutral-bg">الأغنام</a>
                            <a asp-controller="Animals" asp-action="Poultry" class="block px-6 py-2.5 text-sm text-neutral-text/70 hover:bg-neutral-bg">الدواجن</a>
                            <a asp-controller="Animals" asp-action="Vaccinations" class="block px-6 py-2.5 text-sm text-neutral-text/70 hover:bg-neutral-bg">التطعيمات</a>
                        </div>
                    </details>

                    <!-- باقي الأقسام بنفس النمط (المخزون، المعدات، التقارير) -->
                    <!-- ... أضفها بنفس الكود أعلاه ... -->

                </nav>
            </div>

            <!-- Bottom Links -->
            <div class="border-t border-neutral-border px-4 py-4 space-y-2">
                <a asp-controller="Settings" asp-action="Index" class="flex items-center gap-4 px-4 py-3 rounded-lg hover:bg-neutral-bg text-neutral-text/70">
                    <span class="material-symbols-outlined">settings</span>
                    الإعدادات
                </a>
                <form asp-controller="Account" asp-action="Logout" method="post" class="inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="flex w-full items-center gap-4 px-4 py-3 rounded-lg text-red-600 hover:bg-red-500/10 transition-all duration-200 text-left">
                        <span class="material-symbols-outlined text-xl">logout</span>
                        <span>تسجيل الخروج</span>
                    </button>
                </form>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="flex flex-1 flex-col">
            <!-- Header النظيف جدًا -->
            <header class="sticky top-0 z-50 flex items-center justify-end px-6 py-4 bg-background-light/90 backdrop-blur-sm border-b border-neutral-border">
                <div class="flex items-center gap-4">
                    @await Html.PartialAsync("_UserLoginInfo")
                </div>
            </header>

            <!-- Mobile Header (زر القائمة + اسم المزرعة) -->
            <header class="sticky top-0 z-40 flex items-center justify-between px-6 py-4 bg-primary text-white lg:hidden">
                <button id="mobile-menu-btn" class="p-2 rounded-lg hover:bg-primary/80 transition">
                    <span class="material-symbols-outlined text-2xl">menu</span>
                </button>
                <h1 class="text-xl font-bold">مزرعة آل سالم</h1>
                <div class="w-10"></div> <!-- للتوازن -->
            </header>

            <!-- Page Content -->
            <main class="flex-1 p-6 lg:p-8">
                <div class="mx-auto w-full max-w-7xl">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>