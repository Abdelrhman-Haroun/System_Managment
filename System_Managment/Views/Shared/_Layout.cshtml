<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - مزرعة آل سالم</title>

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <style type="text/tailwindcss">
        body {
            font-family: 'Cairo', sans-serif;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .nav-link,
        .dropdown-link {
            transition: all 0.2s ease;
        }

        .nav-link:hover,
        .dropdown-link:hover {
            background-color: #f1f5f9;
            color: #2a7f40;
        }

        .nav-link.active,
        .dropdown-link.active {
            background-color: rgba(42, 127, 64, 0.1);
            color: #2a7f40;
            font-weight: 700;
        }

        .nav-disabled {
            opacity: 0.55;
            cursor: not-allowed;
        }

        .mobile-menu.hidden {
            transform: translateX(-100%);
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
        }
    </style>

    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#2a7f40",
                        secondary: "#D2B48C",
                        "background-light": "#f1f5f9",
                        "neutral-card": "#ffffff",
                        "neutral-text": "#1f2937",
                        "neutral-border": "#e5e7eb"
                    },
                    fontFamily: {
                        display: ["Cairo", "sans-serif"]
                    }
                }
            }
        };
    </script>
</head>
<body class="font-display bg-background-light text-neutral-text">
    @inject IHttpContextAccessor HttpContextAccessor
    @{
        var path = HttpContextAccessor.HttpContext?.Request.Path.ToString().ToLowerInvariant() ?? string.Empty;
        bool IsActive(string fragment) => path.StartsWith(fragment, StringComparison.OrdinalIgnoreCase);
    }

    <div class="flex min-h-screen w-full max-w-full overflow-x-clip">
        <aside class="sticky top-0 hidden h-screen w-72 shrink-0 flex-col justify-between border-l border-neutral-border bg-neutral-card shadow-sm lg:flex">
            <div class="flex flex-1 flex-col overflow-y-auto px-4 py-4">
                <div class="mb-8 flex items-center gap-3 px-2">
                    <div class="size-12 rounded-full bg-cover bg-center ring-4 ring-primary/20" style="background-image: url('@Url.Content("~/Files/images/logo.jpg")');"></div>
                    <div>
                        <h1 class="text-lg font-black text-primary">مزرعة آل سالم</h1>
                        <p class="text-xs text-slate-500">نظام الإدارة والمحاسبة</p>
                    </div>
                </div>

                <nav class="flex flex-col gap-1 text-sm">
                    <a asp-controller="Home" asp-action="Index" class="nav-link @(IsActive("/home") ? "active" : string.Empty) flex items-center gap-4 rounded-lg px-4 py-3">
                        <span class="material-symbols-outlined">dashboard</span>
                        <span>لوحة التحكم</span>
                    </a>
                    <a asp-controller="Customer" asp-action="Index" class="nav-link @(IsActive("/customer") ? "active" : string.Empty) flex items-center gap-4 rounded-lg px-4 py-3">
                        <span class="material-symbols-outlined">people</span>
                        <span>العملاء</span>
                    </a>
                    <a asp-controller="Supplier" asp-action="Index" class="nav-link @(IsActive("/supplier") ? "active" : string.Empty) flex items-center gap-4 rounded-lg px-4 py-3">
                        <span class="material-symbols-outlined">local_shipping</span>
                        <span>الموردون</span>
                    </a>
                    <a asp-controller="Product" asp-action="Index" class="nav-link @(IsActive("/product") && !IsActive("/productcategory") ? "active" : string.Empty) flex items-center gap-4 rounded-lg px-4 py-3">
                        <span class="material-symbols-outlined">inventory</span>
                        <span>المنتجات</span>
                    </a>
                    <a asp-controller="ProductCategory" asp-action="Index" class="nav-link @(IsActive("/productcategory") ? "active" : string.Empty) flex items-center gap-4 rounded-lg px-4 py-3">
                        <span class="material-symbols-outlined">category</span>
                        <span>فئات المنتجات</span>
                    </a>
                    <a asp-controller="Store" asp-action="Index" class="nav-link @(IsActive("/store") ? "active" : string.Empty) flex items-center gap-4 rounded-lg px-4 py-3">
                        <span class="material-symbols-outlined">warehouse</span>
                        <span>المخازن</span>
                    </a>
                    <a asp-controller="Invoice" asp-action="Index" class="nav-link @(IsActive("/invoice") ? "active" : string.Empty) flex items-center gap-4 rounded-lg px-4 py-3">
                        <span class="material-symbols-outlined">receipt</span>
                        <span>الفواتير</span>
                    </a>
                    <a asp-controller="InternalUsage" asp-action="Index" class="nav-link @(IsActive("/internalusage") ? "active" : string.Empty) flex items-center gap-4 rounded-lg px-4 py-3">
                        <span class="material-symbols-outlined">agriculture</span>
                        <span>الاستخدام الداخلي</span>
                    </a>
                    <a asp-controller="Account" asp-action="Index" class="nav-link @(IsActive("/account") && !IsActive("/account/login") && !IsActive("/account/forgotpassword") && !IsActive("/account/resetpassword") ? "active" : string.Empty) flex items-center gap-4 rounded-lg px-4 py-3">
                        <span class="material-symbols-outlined">manage_accounts</span>
                        <span>المستخدمون</span>
                    </a>
                </nav>

                <div class="mt-8 rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-4 text-sm text-slate-600">
                    <div class="mb-2 flex items-center gap-2 font-bold text-slate-700">
                        <span class="material-symbols-outlined text-base">construction</span>
                        <span>الأقسام المؤجلة</span>
                    </div>
                    <p>المدفوعات والموظفون والتقارير والإعدادات العامة أُزيلت من التنقل مؤقتًا حتى لا تظهر روابط مكسورة قبل تنفيذها.</p>
                </div>
            </div>

            <div class="space-y-2 border-t border-neutral-border px-4 py-4">
                <a asp-controller="Account" asp-action="ChangePassword" class="nav-link @(IsActive("/account/changepassword") ? "active" : string.Empty) flex items-center gap-4 rounded-lg px-4 py-3">
                    <span class="material-symbols-outlined">password</span>
                    <span>تغيير كلمة المرور</span>
                </a>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="flex w-full items-center gap-4 rounded-lg px-4 py-3 text-red-600 hover:bg-red-50">
                        <span class="material-symbols-outlined">logout</span>
                        <span>تسجيل الخروج</span>
                    </button>
                </form>
            </div>
        </aside>

        <div class="flex min-w-0 flex-1 flex-col">
            <header class="sticky top-0 z-40 hidden items-center justify-end border-b border-neutral-border bg-background-light/90 px-6 py-4 backdrop-blur-sm lg:flex">
                @await Html.PartialAsync("_UserLoginInfo")
            </header>

            <header class="sticky top-0 z-40 flex items-center justify-between bg-primary px-4 py-4 text-white lg:hidden">
                <button id="mobile-menu-btn" class="rounded-lg p-2 hover:bg-primary/80" type="button" onclick="toggleMobileMenu()">
                    <span class="material-symbols-outlined text-2xl">menu</span>
                </button>
                <h1 class="text-lg font-bold">مزرعة آل سالم</h1>
                <span class="w-10"></span>
            </header>

            <main class="min-h-screen min-w-0 flex-1 overflow-x-hidden bg-gray-50/60">
                <div class="mx-auto w-full min-w-0 max-w-screen-2xl px-3 py-4 sm:px-5 sm:py-6 lg:px-8 xl:px-10">
                    <div id="app-tempdata-alerts"
                         data-success="@TempData["Success"]"
                         data-error="@TempData["Error"]"
                         data-success-message="@TempData["SuccessMessage"]"
                         data-error-message="@TempData["ErrorMessage"]"
                         hidden></div>

                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <div id="mobile-sidebar" class="mobile-menu fixed inset-0 z-50 hidden lg:hidden">
        <div class="flex h-full">
            <aside class="w-[min(20rem,85vw)] overflow-y-auto border-l border-neutral-border bg-neutral-card px-4 py-4 shadow-lg">
                <div class="mb-6 flex items-center gap-3 px-2">
                    <div class="size-12 rounded-full bg-cover bg-center ring-4 ring-primary/20" style="background-image: url('@Url.Content("~/Files/images/logo.jpg")');"></div>
                    <div>
                        <h2 class="text-lg font-black text-primary">مزرعة آل سالم</h2>
                        <p class="text-xs text-slate-500">الأقسام الجاهزة فقط</p>
                    </div>
                </div>

                <nav class="flex flex-col gap-1 text-sm">
                    <a asp-controller="Home" asp-action="Index" class="nav-link @(IsActive("/home") ? "active" : string.Empty) flex items-center gap-4 rounded-lg px-4 py-3" onclick="closeMobileMenu()">لوحة التحكم</a>
                    <a asp-controller="Customer" asp-action="Index" class="nav-link @(IsActive("/customer") ? "active" : string.Empty) flex items-center gap-4 rounded-lg px-4 py-3" onclick="closeMobileMenu()">العملاء</a>
                    <a asp-controller="Supplier" asp-action="Index" class="nav-link @(IsActive("/supplier") ? "active" : string.Empty) flex items-center gap-4 rounded-lg px-4 py-3" onclick="closeMobileMenu()">الموردون</a>
                    <a asp-controller="Product" asp-action="Index" class="nav-link @(IsActive("/product") && !IsActive("/productcategory") ? "active" : string.Empty) flex items-center gap-4 rounded-lg px-4 py-3" onclick="closeMobileMenu()">المنتجات</a>
                    <a asp-controller="ProductCategory" asp-action="Index" class="nav-link @(IsActive("/productcategory") ? "active" : string.Empty) flex items-center gap-4 rounded-lg px-4 py-3" onclick="closeMobileMenu()">فئات المنتجات</a>
                    <a asp-controller="Store" asp-action="Index" class="nav-link @(IsActive("/store") ? "active" : string.Empty) flex items-center gap-4 rounded-lg px-4 py-3" onclick="closeMobileMenu()">المخازن</a>
                    <a asp-controller="Invoice" asp-action="Index" class="nav-link @(IsActive("/invoice") ? "active" : string.Empty) flex items-center gap-4 rounded-lg px-4 py-3" onclick="closeMobileMenu()">الفواتير</a>
                    <a asp-controller="InternalUsage" asp-action="Index" class="nav-link @(IsActive("/internalusage") ? "active" : string.Empty) flex items-center gap-4 rounded-lg px-4 py-3" onclick="closeMobileMenu()">الاستخدام الداخلي</a>
                    <a asp-controller="Account" asp-action="Index" class="nav-link @(IsActive("/account") ? "active" : string.Empty) flex items-center gap-4 rounded-lg px-4 py-3" onclick="closeMobileMenu()">المستخدمون</a>
                </nav>
            </aside>
            <button type="button" class="flex-1 bg-black/40" onclick="closeMobileMenu()"></button>
        </div>
    </div>

    <script>
        function toggleMobileMenu() {
            const menu = document.getElementById('mobile-sidebar');
            const isHidden = menu.classList.contains('hidden');
            menu.classList.toggle('hidden', !isHidden);
            document.body.classList.toggle('overflow-hidden', isHidden);
        }

        function closeMobileMenu() {
            document.getElementById('mobile-sidebar').classList.add('hidden');
            document.body.classList.remove('overflow-hidden');
        }
    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
