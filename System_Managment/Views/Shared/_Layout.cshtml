<!DOCTYPE html>
<html class="light" dir="rtl" lang="ar">
<head>
    @* for favicon *@
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" sizes="96x96" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="MyWebSite" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>مزرعة آل سالم - @ViewData["Title"]</title>

    <!-- Bootstrap CSS (REQUIRED for modal functionality) -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/System_Managment.styles.css" asp-append-version="true" />

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

    <!-- Tailwind CSS with Custom Configuration -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "custom": "#2a7f40",
                        "accent": "#F5DEB3",
                        "background-light": "#F8F8F8",
                        "background-dark": "#152111",
                        "text-light": "#333333",
                        "text-dark": "#F8F8F8",
                        "action-red": "#D32F2F",
                        "action-blue": "#1976D2",
                        "card-dark": "#1F2937",
                    },
                    fontFamily: {
                        "display": ["Tajawal", "Cairo", "sans-serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.5rem",
                        "lg": "0.75rem",
                        "xl": "1rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
</head>

<body class="bg-background-light dark:bg-background-dark font-display" x-data="{ isMenuOpen: false }">

    <!-- Header -->
    <header class="flex items-center justify-between bg-custom p-3 sticky top-0 z-30 shadow-lg">
        <div class="flex items-center gap-2">
            <button x-on:click="isMenuOpen = !isMenuOpen" class="p-2 md:hidden">
                <span class="material-symbols-outlined text-white">menu</span>
            </button>
            <h1 class="text-white text-xl font-bold">مزرعة آل سالم</h1>
        </div>
        @if (User.Identity?.IsAuthenticated == true)
        {
            @await Html.PartialAsync("_UserLoginInfo")
        }
    </header>

    <!-- Mobile Menu -->
    <div x-on:click.away="isMenuOpen = false"
         class="fixed inset-y-0 right-0 z-40 w-64 bg-white dark:bg-card-dark shadow-lg md:hidden"
         style="display: none;"
         x-show="isMenuOpen"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-end="transform translate-x-0"
         x-transition:enter-start="transform translate-x-full"
         x-transition:leave="transition ease-in duration-300"
         x-transition:leave-end="transform -translate-x-full"
         x-transition:leave-start="transform translate-x-0">
        <div class="p-4">
            <nav class="flex flex-col space-y-2">
                <a class="flex items-center gap-2 p-3 text-sm font-medium border-b-2 border-custom text-custom dark:text-secondary dark:border-secondary" asp-controller="Home" asp-action="Index">
                    <span class="material-symbols-outlined">home</span>الرئيسية
                </a>
                <a class="flex items-center gap-2 p-3 text-sm font-medium border-b-2 border-transparent hover:border-custom/50 hover:text-custom dark:hover:text-secondary dark:hover:border-secondary/50 transition-colors" asp-controller="Customers" asp-action="Index">
                    <span class="material-symbols-outlined">group</span>العملاء
                </a>
                <a class="flex items-center gap-2 p-3 text-sm font-medium border-b-2 border-transparent hover:border-custom/50 hover:text-custom dark:hover:text-secondary dark:hover:border-secondary/50 transition-colors" asp-controller="Suppliers" asp-action="Index">
                    <span class="material-symbols-outlined">local_shipping</span>الموردين
                </a>
                <a class="flex items-center gap-2 p-3 text-sm font-medium border-b-2 border-transparent hover:border-custom/50 hover:text-custom dark:hover:text-secondary dark:hover:border-secondary/50 transition-colors" asp-controller="Products" asp-action="Index">
                    <span class="material-symbols-outlined">category</span>الأصناف
                </a>
                <a class="flex items-center gap-2 p-3 text-sm font-medium border-b-2 border-transparent hover:border-custom/50 hover:text-custom dark:hover:text-secondary dark:hover:border-secondary/50 transition-colors" asp-controller="Warehouses" asp-action="Index">
                    <span class="material-symbols-outlined">warehouse</span>المخازن
                </a>
                <a class="flex items-center gap-2 p-3 text-sm font-medium border-b-2 border-transparent hover:border-custom/50 hover:text-custom dark:hover:text-secondary dark:hover:border-secondary/50 transition-colors" asp-controller="Employees" asp-action="Index">
                    <span class="material-symbols-outlined">engineering</span>العمال
                </a>
                <a class="flex items-center gap-2 p-3 text-sm font-medium border-b-2 border-transparent hover:border-custom/50 hover:text-custom dark:hover:text-secondary dark:hover:border-secondary/50 transition-colors" asp-controller="Transactions" asp-action="Index">
                    <span class="material-symbols-outlined">receipt_long</span>المعاملات
                </a>
                <a class="flex items-center gap-2 p-3 text-sm font-medium border-b-2 border-transparent hover:border-custom/50 hover:text-custom dark:hover:text-secondary dark:hover:border-secondary/50 transition-colors" asp-controller="Reports" asp-action="Index">
                    <span class="material-symbols-outlined">bar_chart</span>الإحصائيات والتقارير
                </a>
                <a class="flex items-center gap-2 p-3 text-sm font-medium border-b-2 border-transparent hover:border-custom/50 hover:text-custom dark:hover:text-secondary dark:hover:border-secondary/50 transition-colors" asp-controller="Account" asp-action="Index">
                    <span class="material-symbols-outlined">people</span>المستخدمين
                </a>
                <a class="flex items-center gap-2 p-3 text-sm font-medium border-b-2 border-transparent hover:border-custom/50 hover:text-custom dark:hover:text-secondary dark:hover:border-secondary/50 transition-colors" asp-controller="Settings" asp-action="Index">
                    <span class="material-symbols-outlined">settings</span>الإعدادات
                </a>
            </nav>
        </div>
    </div>

    <!-- Mobile Menu Overlay -->
    <div class="fixed inset-0 bg-black/30 z-30 md:hidden" style="display: none;" x-show="isMenuOpen"></div>

    <!-- Desktop Navigation -->
    <nav class="bg-white dark:bg-card-dark shadow-md sticky top-[72px] z-20 overflow-x-auto hidden md:block">
        <div class="flex space-x-4 px-4 whitespace-nowrap">
            <a class="flex items-center gap-2 p-3 text-sm font-medium border-b-2 border-custom text-custom dark:text-secondary dark:border-secondary" asp-controller="Home" asp-action="Index">
                <span class="material-symbols-outlined">home</span>الرئيسية
            </a>
            <a class="flex items-center gap-2 p-3 text-sm font-medium border-b-2 border-transparent hover:border-custom/50 hover:text-custom dark:hover:text-secondary dark:hover:border-secondary/50 transition-colors" asp-controller="Customers" asp-action="Index">
                <span class="material-symbols-outlined">group</span>العملاء
            </a>
            <a class="flex items-center gap-2 p-3 text-sm font-medium border-b-2 border-transparent hover:border-custom/50 hover:text-custom dark:hover:text-secondary dark:hover:border-secondary/50 transition-colors" asp-controller="Suppliers" asp-action="Index">
                <span class="material-symbols-outlined">local_shipping</span>الموردين
            </a>
            <a class="flex items-center gap-2 p-3 text-sm font-medium border-b-2 border-transparent hover:border-custom/50 hover:text-custom dark:hover:text-secondary dark:hover:border-secondary/50 transition-colors" asp-controller="Products" asp-action="Index">
                <span class="material-symbols-outlined">category</span>الأصناف
            </a>
            <a class="flex items-center gap-2 p-3 text-sm font-medium border-b-2 border-transparent hover:border-custom/50 hover:text-custom dark:hover:text-secondary dark:hover:border-secondary/50 transition-colors" asp-controller="Warehouses" asp-action="Index">
                <span class="material-symbols-outlined">warehouse</span>المخازن
            </a>
            <a class="flex items-center gap-2 p-3 text-sm font-medium border-b-2 border-transparent hover:border-custom/50 hover:text-custom dark:hover:text-secondary dark:hover:border-secondary/50 transition-colors" asp-controller="Employees" asp-action="Index">
                <span class="material-symbols-outlined">engineering</span>العمال
            </a>
            <a class="flex items-center gap-2 p-3 text-sm font-medium border-b-2 border-transparent hover:border-custom/50 hover:text-custom dark:hover:text-secondary dark:hover:border-secondary/50 transition-colors" asp-controller="Transactions" asp-action="Index">
                <span class="material-symbols-outlined">receipt_long</span>المعاملات
            </a>
            <a class="flex items-center gap-2 p-3 text-sm font-medium border-b-2 border-transparent hover:border-custom/50 hover:text-custom dark:hover:text-secondary dark:hover:border-secondary/50 transition-colors" asp-controller="Reports" asp-action="Index">
                <span class="material-symbols-outlined">bar_chart</span>الإحصائيات والتقارير
            </a>
            <a class="flex items-center gap-2 p-3 text-sm font-medium border-b-2 border-transparent hover:border-custom/50 hover:text-custom dark:hover:text-secondary dark:hover:border-secondary/50 transition-colors" asp-controller="Account" asp-action="Index">
                <span class="material-symbols-outlined">people</span>المستخدمين
            </a>
            <a class="flex items-center gap-2 p-3 text-sm font-medium border-b-2 border-transparent hover:border-custom/50 hover:text-custom dark:hover:text-secondary dark:hover:border-secondary/50 transition-colors" asp-controller="Settings" asp-action="Index">
                <span class="material-symbols-outlined">settings</span>الإعدادات
            </a>
        </div>
    </nav>

    <!-- Main Content Area -->
    <div class="container-fluid">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- Scripts - Load Order is Critical -->
    <!-- 1. jQuery (Must be first - required by Bootstrap and validation) -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <!-- 2. Bootstrap Bundle (includes Popper.js - required for modals) -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- 3. jQuery Validation (for form validation) -->
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>

    <!-- 4. Custom Site Scripts -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- 5. Alpine.js (for mobile menu and UI interactions) -->
    <script defer src="https://cdn.jsdelivr.net/gh/alpinejs/alpine@v2.x.x/dist/alpine.min.js"></script>

    <!-- 6. Page-specific Scripts (from child views) -->
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>