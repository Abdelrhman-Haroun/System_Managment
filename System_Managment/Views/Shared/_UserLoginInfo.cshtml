@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@inject IUrlHelper UrlHelper

@{
    string userName = "زائر";
    string userRole = "غير محدد";
    string profilePictureUrl = "/Files/images/alter.png";

    string ResolveProfilePicture(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
            return "/Files/images/alter.png";

        if (path.StartsWith("/Files/", StringComparison.OrdinalIgnoreCase))
            return path;

        if (path.StartsWith("/uploads/", StringComparison.OrdinalIgnoreCase))
            return "/Files" + path;

        return path.StartsWith("/") ? path : "/" + path;
    }

    if (User.Identity?.IsAuthenticated == true)
    {
        var user = await UserManager.GetUserAsync(User);
        if (user != null)
        {
            userName = user.FullName ?? User.Identity?.Name ?? "مستخدم";

            // إذا كان لدى المستخدم صورة شخصية → نستخدمها، وإلا الصورة الافتراضية
            profilePictureUrl = ResolveProfilePicture(user.ProfilePicture);

            // جلب أول دور للمستخدم
            var roles = await UserManager.GetRolesAsync(user);
            var role = roles.FirstOrDefault() ?? "موظف";

            userRole = role switch
            {
                "SuperAdmin" => "مسؤول",
                "Admin" => "مشرف",
                _ => "موظف"
            };
        }
    }

    // تحويل المسارات إلى مسارات صحيحة يفهمها المتصفح (حتى في onerror)
    var resolvedProfilePic = Url.Content(profilePictureUrl);
    var defaultImage = Url.Content("~/Files/images/alter.png");
}

<div class="flex items-center gap-3">
    <div class="text-right hidden sm:block">
        <p class="text-sm font-bold text-neutral-text">@userName</p>
        <p class="text-xs text-neutral-text/60">@userRole</p>
    </div>

    <div class="relative">
        <img src="@resolvedProfilePic"
             alt="صورة @userName"
             class="h-10 w-10 rounded-full object-cover border-2 border-primary/30 shadow-sm"
             onerror="this.onerror=null; this.src='@defaultImage'"
             loading="lazy" />
    </div>
</div>
