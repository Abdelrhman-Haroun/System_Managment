@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager

@{
    string userName = "زائر";
    string userRole = "غير محدد";
    string profilePictureUrl = "uploads/alter.png"; // صورة افتراضية
    if (User.Identity?.IsAuthenticated == true)
    {
        var user = await UserManager.GetUserAsync(User);
        if (user != null)
        {
            userName = user.FullName ?? User.Identity.Name ?? "مستخدم";
            profilePictureUrl = !string.IsNullOrEmpty(user.ProfilePicture)
                ? user.ProfilePicture
                : "uploads/alter.png";

            // جلب الدور (Role) الأول للمستخدم
            var roles = await UserManager.GetRolesAsync(user);
            userRole = roles.FirstOrDefault() ?? "مستخدم";
            if (userRole == "SuperAdmin")
                userRole = "مسؤول";
            else if (userRole == "Admin")
                userRole = "مشرف";
            else
                userRole = "موظف";
        }
    }
}

<div class="flex items-center gap-3">
    <div class="text-right hidden sm:block">
        <p class="text-sm font-bold text-neutral-text">@userName</p>
        <p class="text-xs text-neutral-text/60">@userRole</p>
    </div>
    <div class="relative">
        <img src="~/files/@profilePictureUrl"
             alt="صورة @userName"
             class="h-10 w-10 rounded-full object-cover border-2 border-primary/30 shadow-sm"
             onerror="this.src='~/files/uploads/alter.png'" />
    </div>
</div>