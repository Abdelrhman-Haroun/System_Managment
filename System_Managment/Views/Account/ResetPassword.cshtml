@using BLL.ViewModels.Account
@model ResetPasswordVM

@{
    Layout = null;
}

<!DOCTYPE html>
<html class="light" dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>مزرعة آل سالم - إعادة تعيين كلمة المرور</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

    @* for favicon *@
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" sizes="96x96" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="MyWebSite" />
    <link rel="manifest" href="/site.webmanifest" />

    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#2a7f40",
                        "background-light": "#f6f8f6",
                        "background-dark": "#152111"
                    },
                    fontFamily: {
                        "display": ["Public Sans", "Noto Sans", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" }
                }
            }
        }
    </script>

</head>
<body class="font-display">
    <div class="relative flex w-full flex-col bg-background-light dark:bg-background-dark group/design-root overflow-x-hidden">

        <div class="relative z-10 flex flex-col h-full">
            <main class="flex-grow px-4">
                <div class="flex flex-col items-center pt-8">
                    <h1 class="text-stone-900 dark:text-stone-100 tracking-tight text-3xl font-bold leading-tight text-center pb-3">إعادة تعيين كلمة المرور</h1>
                    <p class="text-stone-600 dark:text-stone-400 text-base font-normal leading-normal pb-8 text-center max-w-sm">أدخل بريدك الإلكتروني وكلمة المرور الجديدة لإعادة تعيينها.</p>
                </div>
                <form asp-action="ResetPassword" method="post" class="flex flex-col gap-4 w-full max-w-md mx-auto">
                    @Html.AntiForgeryToken()
                    <input asp-for="UserId" type="hidden" />
                    <input asp-for="Code" type="hidden" />
                    <div class="flex flex-col w-full">
                        <label class="flex flex-col">
                            <span asp-validation-for="Email" class="text-lg" style="color:#FF0000"></span>
                            <p class="text-lg font-medium pb-2 text-text-light dark:text-text-dark">البريد الإلكتروني</p>
                            <div class="flex w-full flex-1 items-stretch rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800">
                                <input asp-for="Email" class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-r-lg bg-transparent text-text-light dark:text-text-dark focus:outline-none focus:ring-0 border-0 h-14 placeholder:text-gray-400 dark:placeholder:text-gray-500 p-4" placeholder="البريد الإلكتروني" type="email" />
                                <div class="flex items-center justify-center pl-4 text-gray-500">
                                    <span class="material-symbols-outlined">mail</span>
                                </div>
                            </div>
                        </label>
                    </div>
                    <div class="flex flex-col w-full">
                        <label class="flex flex-col">
                            <span asp-validation-for="Password" class="text-lg" style="color:#FF0000"></span>
                            <p class="text-lg font-medium pb-2 text-text-light dark:text-text-dark">كلمة المرور</p>
                            <div class="flex w-full flex-1 items-stretch rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800">
                                <input asp-for="Password" class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-r-lg bg-transparent text-text-light dark:text-text-dark focus:outline-none focus:ring-0 border-0 h-14 placeholder:text-gray-400 dark:placeholder:text-gray-500 p-4" placeholder="كلمة المرور" type="password" />
                                <div class="flex items-center justify-center pl-4 text-gray-500 cursor-pointer">
                                    <span class="material-symbols-outlined">visibility_off</span>
                                </div>
                            </div>
                        </label>
                    </div>
                    <div class="flex flex-col w-full">
                        <label class="flex flex-col">
                            <span asp-validation-for="ConfirmPassword" class="text-lg" style="color:#FF0000"></span>
                            <p class="text-lg font-medium pb-2 text-text-light dark:text-text-dark">تأكيد كلمة المرور</p>
                            <div class="flex w-full flex-1 items-stretch rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800">
                                <input asp-for="ConfirmPassword" class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-r-lg bg-transparent text-text-light dark:text-text-dark focus:outline-none focus:ring-0 border-0 h-14 placeholder:text-gray-400 dark:placeholder:text-gray-500 p-4" placeholder="تأكيد كلمة المرور" type="password" />
                                <div class="flex items-center justify-center pl-4 text-gray-500">
                                    <span class="material-symbols-outlined">lock</span>
                                </div>
                            </div>
                        </label>
                    </div>
                    <div class="flex flex-col items-center mt-8 space-y-4 px-4 pb-8 w-full max-w-md mx-auto">
                        <button type="submit" class="flex items-center justify-center w-full h-14 px-6 bg-primary text-white rounded-lg text-lg font-bold shadow-sm hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 dark:focus:ring-offset-background-dark transition-colors duration-200">إعادة تعيين</button>
                    </div>
                </form>
            </main>
        </div>
    </div>
    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>



