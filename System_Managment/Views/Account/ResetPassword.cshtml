@using BLL.ViewModels.Account
@model ResetPasswordVM

@{
    ViewData["Title"] = "إعادة تعيين كلمة المرور";
    Layout = null;
}

<!DOCTYPE html>
<html class="light" dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - مزرعة آل سالم</title>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&family=Noto+Sans+Arabic:wght@400;500;700&family=Material+Symbols+Outlined&display=swap" rel="stylesheet">

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#2a7f40",
                        "background-light": "#f6f8f7",
                        "background-dark": "#141e17",
                        "text-light": "#121613",
                        "text-dark": "#e3e8e5",
                        "subtext-light": "#6a8170",
                        "subtext-dark": "#8c9f91",
                        "border-light": "#dde3df",
                        "border-dark": "#3d4b41",
                    },
                    fontFamily: {
                        display: ['Inter', 'sans-serif']
                    },
                    borderRadius: {
                        DEFAULT: "0.5rem",
                        lg: "0.75rem",
                        xl: "1rem",
                        full: "9999px"
                    },
                },
            },
        }
    </script>

    <style>
        .form-input-container:focus-within {
            border-color: #2a7f40 !important;
            box-shadow: 0 0 0 3px rgba(42, 127, 64, 0.15);
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="font-display bg-background-light dark:bg-background-dark text-text-light dark:text-text-dark min-h-screen flex items-center justify-center p-4">

    <div class="w-full max-w-md">
        <div class="mb-8 text-center">
            <h1 class="text-3xl font-bold tracking-tight">إعادة تعيين كلمة المرور</h1>
            <p class="mt-2 text-subtext-light dark:text-subtext-dark">أدخل بريدك الإلكتروني وكلمة المرور الجديدة لإعادة تعيينها.</p>
        </div>

        <div class="rounded-xl border border-border-light dark:border-border-dark bg-white dark:bg-[#1a261e] p-8 shadow-sm">
            <form asp-action="ResetPassword" method="post" class="space-y-6">
                @Html.AntiForgeryToken()
                <input asp-for="UserId" type="hidden" />
                <input asp-for="Code" type="hidden" />

                <!-- Email -->
                <div>
                    <label asp-for="Email" class="mb-2 block text-sm font-medium"></label>
                    <div class="relative">
                        <input asp-for="Email"
                               class="block h-12 w-full rounded-lg border border-border-light dark:border-border-dark bg-background-light dark:bg-background-dark px-4 placeholder:text-subtext-light dark:placeholder:text-subtext-dark focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none transition"
                               placeholder="you@example.com" />
                        <span asp-validation-for="Email" class="text-red-600 text-xs mt-1 block"></span>
                    </div>
                </div>

                <!-- New Password -->
                <div>
                    <label asp-for="Password" class="mb-2 block text-sm font-medium"></label>
                    <div class="form-input-container relative flex items-center rounded-lg border border-border-light dark:border-border-dark bg-background-light dark:bg-background-dark">
                        <span class="absolute inset-y-0 right-3 flex items-center text-subtext-light dark:text-subtext-dark pointer-events-none">
                            <span class="material-symbols-outlined text-xl">lock</span>
                        </span>
                        <input asp-for="Password"
                               type="password"
                               id="new-password"
                               class="h-12 w-full border-0 bg-transparent px-4 pr-12 text-text-light dark:text-text-dark placeholder:text-subtext-light dark:placeholder:text-subtext-dark focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none transition"
                               placeholder="••••••••" />
                        <button type="button" id="toggle-new-pass"
                                class="absolute inset-y-0 left-3 flex items-center text-subtext-light dark:text-subtext-dark hover:text-primary focus:outline-none">
                            <span class="material-symbols-outlined text-xl" id="new-pass-icon">visibility_off</span>
                        </button>
                  
                    </div>
                    <span asp-validation-for="Password" class="text-red-600 text-xs mt-1 block"></span>
                </div>

                <!-- Confirm Password -->
                <div>
                    <label asp-for="ConfirmPassword" class="mb-2 block text-sm font-medium"></label>
                    <div class="form-input-container relative flex items-center rounded-lg border border-border-light dark:border-border-dark bg-background-light dark:bg-background-dark">
                        <span class="absolute inset-y-0 right-3 flex items-center text-subtext-light dark:text-subtext-dark pointer-events-none">
                            <span class="material-symbols-outlined text-xl">lock</span>
                        </span>
                        <input asp-for="ConfirmPassword"
                               type="password"
                               id="confirm-password"
                               class="h-12 w-full border-0 bg-transparent px-4 pr-12 text-text-light dark:text-text-dark placeholder:text-subtext-light dark:placeholder:text-subtext-dark focus:outline-none"
                               placeholder="••••••••" />
                        <button type="button" id="toggle-confirm-pass"
                                class="absolute inset-y-0 left-3 flex items-center text-subtext-light dark:text-subtext-dark hover:text-primary focus:outline-none">
                            <span class="material-symbols-outlined text-xl" id="confirm-pass-icon">visibility_off</span>
                        </button>
                        
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-red-600 text-xs mt-1 block"></span>
                </div>

                <!-- Submit -->
                <div class="pt-4">
                    <button type="submit"
                            class="flex h-12 w-full items-center justify-center rounded-lg bg-primary px-5 text-base font-bold text-white hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary/50 transition">
                        إعادة تعيين كلمة المرور
                    </button>
                </div>

                <!-- Validation Summary -->
                <div class="text-center">
                    <span asp-validation-summary="All" class="text-red-600 text-sm font-medium"></span>
                </div>
            </form>
        </div>
    </div>

    <!-- Password Toggle Script (شغال 100% بدون Layout) -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // New Password
            document.getElementById("toggle-new-pass").addEventListener("click", function () {
                const field = document.getElementById("new-password");
                const icon = document.getElementById("new-pass-icon");
                if (field.type === "password") {
                    field.type = "text";
                    icon.textContent = "visibility";
                } else {
                    field.type = "password";
                    icon.textContent = "visibility_off";
                }
            });

            // Confirm Password
            document.getElementById("toggle-confirm-pass").addEventListener("click", function () {
                const field = document.getElementById("confirm-password");
                const icon = document.getElementById("confirm-pass-icon");
                if (field.type === "password") {
                    field.type = "text";
                    icon.textContent = "visibility";
                } else {
                    field.type = "password";
                    icon.textContent = "visibility_off";
                }
            });
        });
    </script>

    <!-- Client-side Validation -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>