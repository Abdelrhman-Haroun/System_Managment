@{
    Layout = null;
}

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>مزرعة آل سالم - تم رفض الوصول</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

    @* Match login page styles *@
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "custom": "#2a7f40",
                        "background-light": "#F7FDF3",
                        "background-dark": "#152111",
                        "earthy-green": "#3A5F0B",
                        "sandy-beige": "#F5DEB3",
                        "vibrant-orange": "#FFA500",
                        "dark-grey": "#333333",
                        "light-gray": "#D1D5DB",
                        "white-smoke": "#F5F5F5"
                    },
                    fontFamily: {
                        "display": ["Public Sans"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    fontSize: {
                        "lg": "1.125rem",
                        "xl": "1.25rem",
                        "2xl": "1.5rem"
                    }
                },
            },
        }
    </script>

    <style>
        body {
            font-family: 'Public Sans', sans-serif;
            font-weight: bold;
        }
    </style>
</head>

<body class="bg-light-green-bg text-dark-grey font-display">
    <div class="relative flex h-screen w-full flex-col items-center justify-center bg-light-green-bg overflow-hidden p-4">

        <!-- Lock Icon -->
        <div class="flex justify-center mb-6">
            <div class="w-28 h-28 bg-red-100 rounded-full flex items-center justify-center">
                <span class="material-symbols-outlined text-5xl text-red-600">lock</span>
            </div>
        </div>

        <!-- Title -->
        <h1 class="text-dark-grey text-[36px] font-bold leading-tight text-center mb-3">
            تم رفض الوصول
        </h1>

        <!-- Message -->
        <p class="text-dark-grey text-lg font-medium text-center max-w-md leading-relaxed px-4">
            حسابك غير نشط حاليًا أو تم إغلاقه.
            يرجى التواصل مع الدعم الفني أو مسؤول النظام لإعادة تفعيل حسابك.
        </p>

        <!-- Support Button -->
        <div class="w-full max-w-md px-4 mt-8">
            <button class="w-full h-14 bg-custom text-white rounded-lg text-xl font-bold hover:bg-opacity-90 transition-colors">
                تواصل مع الدعم الفني
            </button>
        </div>

        <!-- Back to Login -->
        <a asp-action="Login" asp-controller="Account" class="mt-4">
            <p class="text-custom text-lg font-medium underline hover:text-earthy-green transition">
                العودة لتسجيل الدخول
            </p>
        </a>

    </div>
</body>
</html>
