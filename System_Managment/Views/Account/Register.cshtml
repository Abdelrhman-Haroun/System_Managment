@model RegisterationVM

@{
    ViewData["Title"] = "إنشاء حساب جديد";
}

<div class="max-w-7xl mx-auto space-y-8">
    <!-- Back Button and Title -->
    <div class="flex items-center gap-4 mb-6">
        <a asp-action="Index" class="flex items-center justify-center size-11 rounded-xl border border-slate-300 dark:border-slate-700 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
            <span class="material-symbols-outlined">arrow_forward</span>
        </a>
        <div>
            <h1 class="text-4xl font-black text-slate-900 dark:text-white tracking-tight">إنشاء حساب جديد</h1>
            <p class="text-slate-600 dark:text-slate-400 mt-2 text-lg">أدخل التفاصيل أدناه لإنشاء حساب مستخدم جديد</p>
        </div>
    </div>

    <!-- Registration Card -->
    <div class="bg-white dark:bg-slate-800/50 rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden shadow-sm">
        <form id="registerForm" asp-action="Register" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="grid md:grid-cols-2">
                <!-- Form Section (Left Side) -->
                <div class="flex flex-col items-center justify-center p-8 sm:p-12 order-2 md:order-1">
                    <div class="w-full flex flex-col gap-y-5">

                        <!-- Full Name Field -->
                        <div class="relative">
                            <span class="material-symbols-outlined pointer-events-none absolute top-1/2 left-4 -translate-y-1/2 text-slate-500 dark:text-slate-400">person</span>
                            <input asp-for="FullName"
                                   class="form-input peer block h-14 w-full rounded-xl border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-800/70 py-3 pl-12 pr-4 text-base text-slate-900 dark:text-white focus:border-primary focus:ring-4 focus:ring-primary/20 transition-all placeholder-transparent"
                                   id="full-name"
                                   placeholder="الاسم الكامل"
                                   type="text" />
                            <label for="full-name"
                                   class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-slate-500 dark:text-slate-400 transition-all duration-200
                                          peer-placeholder-shown:top-1/2 peer-placeholder-shown:-translate-y-1/2 peer-placeholder-shown:text-base
                                          peer-focus:top-2.5 peer-focus:text-xs peer-focus:text-primary
                                          peer-[&:not(:placeholder-shown)]:top-2.5 peer-[&:not(:placeholder-shown)]:text-xs">
                                الاسم الكامل
                            </label>
                            <span asp-validation-for="FullName" class="text-red-600 text-sm mt-1 block"></span>
                        </div>

                        <!-- Email Field -->
                        <div class="relative">
                            <span class="material-symbols-outlined pointer-events-none absolute top-1/2 left-4 -translate-y-1/2 text-slate-500 dark:text-slate-400">mail</span>
                            <input asp-for="Email"
                                   class="form-input peer block h-14 w-full rounded-xl border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-800/70 py-3 pl-12 pr-4 text-base text-slate-900 dark:text-white focus:border-primary focus:ring-4 focus:ring-primary/20 transition-all placeholder-transparent"
                                   id="email"
                                   placeholder="البريد الإلكتروني"
                                   type="email" />
                            <label for="email"
                                   class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-slate-500 dark:text-slate-400 transition-all duration-200
                                          peer-placeholder-shown:top-1/2 peer-placeholder-shown:-translate-y-1/2 peer-placeholder-shown:text-base
                                          peer-focus:top-2.5 peer-focus:text-xs peer-focus:text-primary
                                          peer-[&:not(:placeholder-shown)]:top-2.5 peer-[&:not(:placeholder-shown)]:text-xs">
                                البريد الإلكتروني
                            </label>
                            <span asp-validation-for="Email" class="text-red-600 text-sm mt-1 block"></span>
                        </div>

                        <!-- Phone Field -->
                        <div class="relative">
                            <span class="material-symbols-outlined pointer-events-none absolute top-1/2 left-4 -translate-y-1/2 text-slate-500 dark:text-slate-400">phone</span>
                            <input asp-for="PhoneNumber"
                                   class="form-input peer block h-14 w-full rounded-xl border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-800/70 py-3 pl-12 pr-4 text-base text-slate-900 dark:text-white focus:border-primary focus:ring-4 focus:ring-primary/20 transition-all placeholder-transparent"
                                   id="phone"
                                   dir="rtl"
                                   placeholder="رقم الهاتف"
                                   type="tel" />
                            <label for="phone"
                                   class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-slate-500 dark:text-slate-400 transition-all duration-200
                                          peer-placeholder-shown:top-1/2 peer-placeholder-shown:-translate-y-1/2 peer-placeholder-shown:text-base
                                          peer-focus:top-2.5 peer-focus:text-xs peer-focus:text-primary
                                          peer-[&:not(:placeholder-shown)]:top-2.5 peer-[&:not(:placeholder-shown)]:text-xs">
                                رقم الهاتف
                            </label>
                            <span asp-validation-for="PhoneNumber" class="text-red-600 text-sm mt-1 block"></span>
                        </div>

                        <!-- Password Field -->
                        <div class="relative">
                            <input asp-for="Password"
                                   class="form-input peer block h-14 w-full rounded-xl border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-800/70 py-3 pl-12 pr-4 text-base text-slate-900 dark:text-white focus:border-primary focus:ring-4 focus:ring-primary/20 transition-all placeholder-transparent"
                                   id="password"
                                   placeholder="كلمة المرور"
                                   type="password" />
                            <label for="password"
                                   class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-slate-500 dark:text-slate-400 transition-all duration-200
                                          peer-placeholder-shown:top-1/2 peer-placeholder-shown:-translate-y-1/2 peer-placeholder-shown:text-base
                                          peer-focus:top-2.5 peer-focus:text-xs peer-focus:text-primary
                                          peer-[&:not(:placeholder-shown)]:top-2.5 peer-[&:not(:placeholder-shown)]:text-xs">
                                كلمة المرور
                            </label>
                            <button class="absolute top-1/2 left-4 -translate-y-1/2 text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-300 z-10" type="button" onclick="togglePasswordVisibility('password', this)">
                                <span class="material-symbols-outlined">visibility_off</span>
                            </button>
                            <span asp-validation-for="Password" class="text-red-600 text-sm mt-1 block"></span>
                        </div>

                        <!-- Confirm Password Field -->
                        <div class="relative">
                            <input asp-for="ConfirmPassword"
                                   class="form-input peer block h-14 w-full rounded-xl border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-800/70 py-3 pl-12 pr-4 text-base text-slate-900 dark:text-white focus:border-primary focus:ring-4 focus:ring-primary/20 transition-all placeholder-transparent"
                                   id="confirm-password"
                                   placeholder="تأكيد كلمة المرور"
                                   type="password" />
                            <label for="confirm-password"
                                   class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-slate-500 dark:text-slate-400 transition-all duration-200
                                          peer-placeholder-shown:top-1/2 peer-placeholder-shown:-translate-y-1/2 peer-placeholder-shown:text-base
                                          peer-focus:top-2.5 peer-focus:text-xs peer-focus:text-primary
                                          peer-[&:not(:placeholder-shown)]:top-2.5 peer-[&:not(:placeholder-shown)]:text-xs">
                                تأكيد كلمة المرور
                            </label>
                            <button class="absolute top-1/2 left-4 -translate-y-1/2 text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-300 z-10" type="button" onclick="togglePasswordVisibility('confirm-password', this)">
                                <span class="material-symbols-outlined">visibility_off</span>
                            </button>
                            <span asp-validation-for="ConfirmPassword" class="text-red-600 text-sm mt-1 block"></span>
                        </div>

                        <!-- User Role Field -->
                        <div class="relative">
                            <select asp-for="UserRole"
                                    class="form-select peer block h-14 w-full rounded-xl border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-800/70 pt-6 pb-1 pl-12 pr-4 text-base text-slate-900 dark:text-white focus:border-primary focus:ring-4 focus:ring-primary/20 transition-all"
                                    style="appearance: none; -webkit-appearance: none; -moz-appearance: none; background-image: none;"
                                    id="user-role">
                                <option value="" disabled selected></option>
                                <option value="SuperAdmin">مسؤول النظام</option>
                                <option value="Admin">مشرف</option>
                                <option value="Employee">موظف</option>
                            </select>
                            <label for="user-role" class="pointer-events-none absolute top-2.5 right-4 text-xs text-slate-500 dark:text-slate-400">
                                درجة المستخدم
                            </label>
                            <span class="material-symbols-outlined pointer-events-none absolute top-1/2 left-4 -translate-y-1/2 text-slate-500 dark:text-slate-400">keyboard_arrow_down</span>
                            <span asp-validation-for="UserRole" class="text-red-600 text-sm mt-1 block"></span>
                        </div>

                        <!-- Submit and Cancel Buttons -->
                        <div class="pt-4 flex gap-3">
                            <button class="flex h-14 flex-1 items-center justify-center rounded-xl bg-primary px-6 text-base font-bold text-white shadow-lg hover:shadow-xl hover:bg-primary/90 transition-all" type="submit">
                                <span class="material-symbols-outlined ml-2">check</span>
                                إنشاء حساب
                            </button>
                            <a asp-action="Index" class="flex h-14 items-center justify-center rounded-xl border-2 border-slate-300 dark:border-slate-700 px-6 text-base font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-all">
                                إلغاء
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Profile Picture Section (Right Side) -->
                <div class="flex flex-col items-center justify-center p-8 sm:p-12 bg-slate-50 dark:bg-slate-900/30 border-b md:border-b-0 md:border-r border-slate-200 dark:border-slate-700 order-1 md:order-2">
                    <div class="flex w-full flex-col items-center gap-6 text-center">
                        <p class="text-2xl font-bold text-slate-900 dark:text-white">صورة شخصية</p>
                        <div class="relative group">
                            <label class="relative cursor-pointer" for="ProfilePicture">
                                <div id="profile-picture-preview" class="h-48 w-48 rounded-full bg-white dark:bg-slate-800 flex items-center justify-center border-4 border-slate-200 dark:border-slate-700 shadow-xl overflow-hidden">
                                    <img id="preview-image" class="hidden w-full h-full object-cover" src="" alt="Profile picture preview" />
                                    <span id="default-icon" class="material-symbols-outlined text-7xl text-slate-400 dark:text-slate-600">person</span>
                                </div>
                                <div class="absolute bottom-2 left-2 flex h-14 w-14 items-center justify-center rounded-full bg-primary text-white shadow-lg ring-4 ring-white dark:ring-slate-800 transition-transform group-hover:scale-110">
                                    <span class="material-symbols-outlined text-3xl">photo_camera</span>
                                </div>
                                <input asp-for="ProfilePicture" class="sr-only" id="ProfilePicture" type="file" accept="image/*" />
                            </label>
                        </div>
                        <p class="max-w-xs text-sm text-slate-600 dark:text-slate-400">انقر لتحميل صورة شخصية. يُفضل استخدام صورة مربعة بحجم 500×500 بكسل</p>
                        <span asp-validation-for="ProfilePicture" class="text-red-600 text-sm"></span>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts{
    <script>
        // Photo preview functionality
        document.getElementById('ProfilePicture').addEventListener('change', function (event) {
            const file = event.target.files[0];
            const previewImage = document.getElementById('preview-image');
            const defaultIcon = document.getElementById('default-icon');

            if (file) {
                
                // Read and display the image
                const reader = new FileReader();
                reader.onload = function (e) {
                    previewImage.src = e.target.result;
                    previewImage.classList.remove('hidden');
                    defaultIcon.classList.add('hidden');
                };
                reader.onerror = function() {
                    alert('حدث خطأ أثناء قراءة الصورة');
                    event.target.value = '';
                };
                reader.readAsDataURL(file);
            } else {
                // No file selected - reset to default
                previewImage.src = '';
                previewImage.classList.add('hidden');
                defaultIcon.classList.remove('hidden');
            }
        });

        // Toggle password visibility
        function togglePasswordVisibility(inputId, button) {
            const input = document.getElementById(inputId);
            const icon = button.querySelector('.material-symbols-outlined');

            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = 'visibility';
            } else {
                input.type = 'password';
                icon.textContent = 'visibility_off';
            }
        }

        let msg = @Html.Raw(Json.Serialize(TempData["SuccessMessage"]));
        if (msg) {
            Swal.fire({
                icon: 'success',
                title: 'تم بنجاح',
                text: msg,
                confirmButtonText: 'حسناً'
            }).then(() => {
                window.location.href = '/Account/Index';
            });}
    </script>
}

   
@{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}





