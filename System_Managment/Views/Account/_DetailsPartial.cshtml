@model ApplicationUser

@{
    var roleName = ViewBag.UserRole as string ?? "غير محدد";
    var displayRole = roleName switch
    {
        "SuperAdmin" => "مسؤول النظام",
        "Admin" => "مشرف",
        "Employee" => "موظف",
        _ => "غير محدد"
    };

    var createdAt = ViewBag.CreatedAt != null
        ? ((DateTime)ViewBag.CreatedAt).ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("ar-EG"))
        : "غير معروف";

    var fileName = string.IsNullOrEmpty(Model.ProfilePicture)
                         ? "~/files/images/alter.png"
                         : Model.ProfilePicture.TrimStart('/');

    var profileImage = Url.Content("~/files/" + fileName);
}

<div class="w-full max-w-2xl mx-auto bg-white dark:bg-[#1c2c21] rounded-2xl shadow-2xl overflow-hidden">
    <!-- Header -->
    <div class="flex items-center justify-between p-6 border-b border-gray-200 dark:border-gray-700">
        <h2 class="text-2xl font-bold text-[#121613] dark:text-white">ملف المستخدم</h2>
        <button type="button" class="closeDialog p-3 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
            <span class="material-symbols-outlined text-2xl">close</span>
        </button>
    </div>

    <div class="p-8">
        <!-- Profile Image & Role -->
        <div class="flex flex-col items-center text-center mb-10">
            <div class="relative mb-6">
                <div class="w-32 h-32 rounded-full ring-8 ring-white dark:ring-[#1c2c21] shadow-2xl overflow-hidden bg-gray-100"
                     style="background-image: url('@profileImage'); background-size: cover; background-position: center;">
                </div>
                <div class="absolute bottom-0 left-0 flex h-12 w-12 items-center justify-center rounded-full bg-primary text-white shadow-lg ring-4 ring-white dark:ring-slate-800 transition-transform group-hover:scale-110">
                    <span class="material-symbols-outlined text-3xl">photo_camera</span>
                </div>
            </div>

            <h3 class="text-2xl font-bold text-[#121613] dark:text-white break-words">@Model.FullName</h3>
            <span class="inline-flex items-center px-4 py-2 mt-2 rounded-full text-sm font-bold bg-primary/10 text-primary">
                @displayRole
            </span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Personal Information -->
            <div class="space-y-5">
                <h4 class="text-lg font-bold text-[#121613] dark:text-white pb-3 border-b border-gray-200 dark:border-gray-700">
                    المعلومات الشخصية
                </h4>

                <div class="flex items-center gap-4 p-4 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-all">
                    <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary flex-shrink-0">
                        <span class="material-symbols-outlined">person</span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm text-gray-500 dark:text-gray-400">اسم المستخدم</p>
                        <p class="font-semibold text-[#121613] dark:text-white break-words overflow-wrap-anywhere">
                            @Model.FullName
                        </p>
                    </div>
                </div>

                <div class="flex items-center gap-4 p-4 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-all">
                    <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary flex-shrink-0">
                        <span class="material-symbols-outlined">mail</span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm text-gray-500 dark:text-gray-400">البريد الإلكتروني</p>
                        <p class="font-semibold text-[#121613] dark:text-white font-mono text-sm break-words overflow-wrap-anywhere">
                            @Model.Email
                        </p>
                    </div>
                </div>

                <div class="flex items-center gap-4 p-4 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-all">
                    <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary flex-shrink-0">
                        <span class="material-symbols-outlined">phone</span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm text-gray-500 dark:text-gray-400">رقم الهاتف</p>
                        <p class="font-semibold text-[#121613] dark:text-white break-words overflow-wrap-anywhere">
                            @Model.PhoneNumber
                        </p>
                    </div>
                </div>
            </div>

            <!-- Account Information -->
            <div class="space-y-5">
                <h4 class="text-lg font-bold text-[#121613] dark:text-white pb-3 border-b border-gray-200 dark:border-gray-700">
                    معلومات الحساب
                </h4>

                <div class="flex items-center gap-4 p-4 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-all">
                    <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary flex-shrink-0">
                        <span class="material-symbols-outlined">badge</span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm text-gray-500 dark:text-gray-400">رقم المستخدم</p>
                        <p class="font-mono text-xs text-[#121613] dark:text-gray-300 break-words overflow-wrap-anywhere">
                            @Model.Id
                        </p>
                    </div>
                </div>

                <div class="flex items-center gap-4 p-4 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-all">
                    <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary flex-shrink-0">
                        <span class="material-symbols-outlined">event</span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm text-gray-500 dark:text-gray-400">تاريخ الإنشاء</p>
                        <p class="font-semibold text-[#121613] dark:text-white break-words overflow-wrap-anywhere">
                            @createdAt
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
