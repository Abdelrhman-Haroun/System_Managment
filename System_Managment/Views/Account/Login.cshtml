@using BLL.ViewModels.Account
@model LoginVM
@{
    Layout = null;
}

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>مزرعة آل سالم - تسجيل الدخول</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;700&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />


    @* for favicon *@
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" sizes="96x96" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="MyWebSite" />
    <link rel="manifest" href="/site.webmanifest" />

    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "custom": "#2a7f40",
                        "background-light": "#F7FDF3",
                        "background-dark": "#152111",
                        "earthy-green": "#3A5F0B",
                        "sandy-beige": "#F5DEB3",
                        "vibrant-orange": "#FFA500",
                        "dark-grey": "#333333",
                        "light-gray": "#D1D5DB",
                        "custom": "#3A5F0B",
                        "light-green-bg": "#F7FDF3",
                        "white-smoke": "#F5F5F5"
                    },
                    fontFamily: {
                        "display": ["Public Sans"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    fontSize: {
                        "base": "1rem", // Default size
                        "lg": "1.125rem", // Slightly larger base
                        "xl": "1.25rem", // For headings or emphasis
                        "2xl": "1.5rem" // For larger text if needed
                    }
                },
            },
        }
    </script>

    <style>
        :root {
            --checkbox-tick-svg: url('data:image/svg+xml,%3csvg viewBox=%270 0 16 16%27 fill=%27%233A5F0B%27 xmlns=%27http://www.w3.org/2000/svg%27%3e%3cpath d=%27M12.207 4.793a1 1 0 010 1.414l-5 5a1 1 0 01-1.414 0l-2-2a1 1 0 011.414-1.414L6.5 9.086l4.293-4.293a1 1 0 011.414 0z%27/%3e%3c/svg%3e');
        }

        body {
            font-weight: bold;
            font-size: 1.125rem; /* Slightly larger base font size */
        }
    </style>
</head>
<body class="bg-light-green-bg font-display text-dark-grey text-lg mt-4">
    <div class="relative flex h-auto  w-full flex-col items-center justify-center bg-light-green-bg group/design-root overflow-x-hidden p-4" style='font-family: "Public Sans", "Noto Sans", sans-serif;'>
        <div class="w-full max-w-md space-y-6">
            <div class="flex justify-center">
                <div class="w-32 h-32 bg-custom rounded-full flex items-center justify-center">
                    <!-- Increased to w-32 h-32 (128x128px) -->
                    <img src="~/Files/images/logo.jpg" alt="شعار مزرعة آل سالم" class="w-full h-full object-cover rounded-full" /> <!-- Adjusted to fill the circle -->
                </div>
            </div>
            <h1 class="text-dark-grey tracking-light text-[36px] font-bold leading-tight text-center">تسجيل الدخول</h1>
            <div class="space-y-4">
                <form method="post">
                    <div class="flex max-w-[480px] flex-wrap items-end gap-4 mb-3">
                        <label class="flex flex-col min-w-40 flex-1">
                            <span asp-validation-for="Email" class="text-lg" style="color:#FF0000"></span>
                            <p class="text-dark-grey text-lg font-medium leading-normal pb-2">اسم المستخدم / البريد الإلكتروني</p>
                            <input asp-for="Email" class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-lg text-dark-grey text-lg focus:outline-0 focus:ring-2 focus:ring-custom border border-light-gray bg-white h-14 placeholder:text-gray-400 p-4 font-medium leading-normal" placeholder="ادخل اسم المستخدم او البريد الالكتروني" />
                        </label>
                    </div>
                    <div class="flex max-w-[480px] flex-wrap items-end gap-4 mb-3">
                        <label class="flex flex-col min-w-40 flex-1">
                            <span asp-validation-for="Password" class="text-lg" style="color:#FF0000"></span>
                            <p class="text-dark-grey text-lg font-medium leading-normal pb-2">كلمة المرور</p>
                            <input asp-for="Password" class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-lg text-dark-grey text-lg focus:outline-0 focus:ring-2 focus:ring-custom border border-light-gray bg-white h-14 placeholder:text-gray-400 p-4 font-medium leading-normal" placeholder="************" type="password" />
                        </label>
                    </div>
                    <div class="flex items-center justify-between mb-3">
                        <label class="flex gap-x-3 items-center">
                            <input asp-for="RememberMe" class="h-5 w-5 rounded border-gray-300 dark:border-gray-600 bg-transparent checked:bg-custom checked:border-custom focus:ring-0 focus:ring-offset-0 focus:border-gray-300 dark:focus:border-gray-600 focus:outline-none appearance-none" type="checkbox" />
                            <p class="text-dark-grey text-lg font-medium leading-normal">تذكرني</p>
                        </label>
                        <a asp-area="" asp-controller="Account" asp-action="ForgotPassword" class="text-lg font-medium text-custom hover:underline">نسيت كلمة المرور؟</a>
                    </div>
                    <button type="submit" style="background-color:rgb(42, 127, 64)" class="w-full text-white h-14 rounded-lg text-xl font-bold hover:bg-opacity-90 transition-colors">
                        دخول
                    </button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}