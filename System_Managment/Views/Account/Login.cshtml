@using BLL.ViewModels.Account
@model LoginVM

@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl" class="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - مزرعة آل سالم</title>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;700;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet">

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 1, 'wght' 300, 'GRAD' 0, 'opsz' 24
        }
    </style>

    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#2a7f40",
                        "background-light": "#f8fafa",
                        "background-dark": "#141e17",
                    },
                    fontFamily: { display: ["Cairo", "sans-serif"] },
                    borderRadius: { DEFAULT: "0.5rem", lg: "0.75rem", xl: "1rem", full: "9999px" },
                },
            },
        }
    </script>
</head>
<body class="font-display bg-background-light">

    <div class="grid h-auto w-full lg:grid-cols-2">

        <!-- Login Form -->
        <div class="flex items-center justify-center p-6 sm:p-8 lg:p-12">
            <div class="w-full max-w-md">
                <div class="mb-8 text-center">

                    <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-primary/10">
                        <img src="~/Files/images/logo.jpg" alt="شعار مزرعة آل سالم" class="w-full h-full object-cover rounded-full" /> 
                    </div>

                    <h1 class="text-3xl sm:text-4xl font-bold text-slate-900">مرحباً بعودتك</h1>
                    <p class="mt-2 text-slate-600">سجل الدخول للوصول إلى لوحة التحكم</p>
                </div>

                <form asp-controller="Account" asp-action="Login" method="post" class="space-y-6">
                    @Html.AntiForgeryToken()

                    <!-- Username / Email -->
                    <div class="space-y-2">
                        <label asp-for="Email" class="text-sm font-medium text-slate-700"></label>
                        <div class="relative">
                            <span class="absolute inset-y-0 right-0 flex items-center pr-3.5 text-slate-400">
                                <span class="material-symbols-outlined">person</span>
                            </span>
                            <input asp-for="Email" class="w-full rounded-lg border border-slate-300 bg-white py-3 pl-4 pr-12 text-slate-900 placeholder:text-slate-400 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"
                                   placeholder="اسم المستخدم أو البريد الإلكتروني" />
                            <span asp-validation-for="Email" class="text-red-600 text-xs mt-1"></span>
                        </div>
                    </div>

                    <!-- Password -->
                    <div class="space-y-2">
                        <label asp-for="Password" class="text-sm font-medium text-slate-700"></label>
                        <div class="relative">
                            <!-- حقل كلمة المرور -->
                            <input asp-for="Password"
                                   type="password"
                                   id="password-field"
                                   class="w-full rounded-lg border border-slate-300 bg-white py-3 px-12 text-slate-900 placeholder:text-slate-400 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"
                                   placeholder="••••••••" />

                            <!-- أيقونة القفل (يمين تمامًا في RTL) -->
                            <div class="absolute inset-y-0 right-3 flex items-center pointer-events-none text-slate-400">
                                <span class="material-symbols-outlined text-xl">lock</span>
                            </div>

                            <!-- زر العين (يسار تمامًا في RTL) -->
                            <button type="button"
                                    id="toggle-password"
                                    class="absolute inset-y-0 left-3 flex items-center text-slate-500 hover:text-slate-700 focus:outline-none">
                                <span class="material-symbols-outlined text-xl" id="eye-icon">visibility</span>
                            </button>

                            <span asp-validation-for="Password" class="text-red-600 text-xs mt-1 block"></span>
                        </div>
                    </div>

                    <!-- Remember Me + Forgot Password -->
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <input asp-for="RememberMe" class="h-4 w-4 rounded border-slate-300 text-primary focus:ring-primary" />
                            <label asp-for="RememberMe" class="text-sm text-slate-600"></label>
                        </div>
                        <a asp-controller="Account" asp-action="ForgotPassword" class="text-sm font-medium text-primary hover:underline">
                            نسيت كلمة المرور؟
                        </a>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit"
                            class="w-full rounded-lg bg-primary py-3.5 font-semibold text-white hover:bg-primary/90 focus:outline-none focus:ring-4 focus:ring-primary/30 transition">
                        تسجيل الدخول
                    </button>

                    <!-- Validation Summary (اختياري - يظهر أخطاء عامة) -->
                    <div class="mt-4">
                        <span asp-validation-summary="All" class="text-red-600 text-sm"></span>
                    </div>
                </form>
            </div>
        </div>

        <!-- Right Side Image -->
        <div class="relative hidden lg:block">
            <img src="~/Files/images/farm Photo.jpg" alt="مزرعة خضراء" class="h-full w-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
            <div class="absolute bottom-0 start-0 p-10 text-white">
                <h2 class="text-4xl font-bold mb-3">إدارة مزرعتك باحترافية</h2>
                <p class="text-lg opacity-90 max-w-lg">
                    نظام متكامل لإدارة المحاصيل والثروة الحيوانية والمخزون والتقارير في مكان واحد.
                </p>
            </div>
        </div>
    </div>

    <!-- Client-side Validation Scripts (مهم جدًا للـ Tag Helpers) -->
    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
    <script>
        // انتظر حتى يتحمل الـ DOM كامل
        document.addEventListener("DOMContentLoaded", function () {
            const passwordField = document.getElementById("password-field");
            const toggleButton = document.getElementById("toggle-password");
            const eyeIcon = document.getElementById("eye-icon");

            toggleButton.addEventListener("click", function () {
                if (passwordField.type === "password") {
                    passwordField.type = "text";
                    eyeIcon.textContent = "visibility_off";
                } else {
                    passwordField.type = "password";
                    eyeIcon.textContent = "visibility";
                }
            });
        });
    </script>
</body>
</html>