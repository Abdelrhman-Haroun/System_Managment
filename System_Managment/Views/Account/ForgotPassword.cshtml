

@using BLL.ViewModels.Account
@model ForgetPasswordVM

@{
    ViewData["Title"] = "إعادة تعيين كلمة المرور";
    Layout = null;
}

<!DOCTYPE html>
<html class="light" dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - مزرعة آل سالم</title>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&family=Material+Symbols+Outlined&display=swap" rel="stylesheet">

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#2a7e41",
                        "background-light": "#f6f8f7",
                        "background-dark": "#141e17",
                    },
                    fontFamily: {
                        display: ["Inter", "sans-serif"]
                    },
                    borderRadius: {
                        DEFAULT: "0.5rem",
                        lg: "0.75rem",
                        xl: "1rem",
                        full: "9999px"
                    },
                },
            },
        }
    </script>

    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-[#121613] dark:text-white min-h-screen flex items-center justify-center p-4">

    <div class="w-full max-w-md">
        <div class="flex flex-col items-center gap-8">
            <!-- Logo -->
            <div class="flex h-20 w-20 items-center justify-center rounded-full bg-primary/10">
                <img src="~/Files/images/logo.jpg" alt="شعار مزرعة آل سالم" class="w-full h-full object-cover rounded-full" />
            </div>

            <!-- Heading -->
            <div class="text-center space-y-2">
                <h1 class="text-3xl font-black tracking-tight text-[#121613] dark:text-white">
                    إعادة تعيين كلمة المرور
                </h1>
                <p class="text-base text-[#6a8170] dark:text-gray-400">
                    أدخل بريدك الإلكتروني لإرسال رابط إعادة التعيين
                </p>
            </div>

            <!-- Form -->
            <form asp-action="ForgotPassword" method="post" class="w-full space-y-5">
                @Html.AntiForgeryToken()

                <!-- Validation Summary -->
                <div class="text-center">
                    <span asp-validation-summary="All" class="text-red-600 text-sm font-medium"></span>
                </div>

                <!-- Email Field -->
                <div class="space-y-2">
                    <label asp-for="Email" class="text-base font-medium text-[#121613] dark:text-white"></label>
                    <input asp-for="Email"
                           class="w-full h-14 px-4 rounded-lg border border-[#dde3df] dark:border-gray-600 bg-white dark:bg-gray-800 text-[#121613] dark:text-white placeholder:text-[#6a8170] dark:placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition"
                           placeholder="ادخل بريدك الإلكتروني" />
                    <span asp-validation-for="Email" class="text-red-600 text-xs"></span>
                </div>

                <!-- Submit Button -->
                <button type="submit"
                        class="w-full h-12 rounded-lg bg-primary text-white font-bold text-base tracking-wide hover:bg-primary/90 focus:outline-none focus:ring-4 focus:ring-primary/30 transition">
                    إرسال رابط إعادة التعيين
                </button>
            </form>

            <!-- Back to Login -->
            <a asp-action="Login" asp-controller="Account"
               class="text-sm font-medium text-[#6a8170] dark:text-gray-300 underline hover:text-primary dark:hover:text-primary/90 transition">
                العودة إلى تسجيل الدخول
            </a>
        </div>
    </div>

    <!-- Client-side Validation (شغال حتى بدون Layout) -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>