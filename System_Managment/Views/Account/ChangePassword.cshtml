
@model ChangePasswordVM

@{
    ViewData["Title"] = "تغيير كلمة المرور";
}

<div class="space-y-8">
    <!-- Back Button and Title -->
    <div class="flex items-center gap-4 mb-6">
        <span class="material-symbols-outlined"></span>
        <div>
            <h1 class="text-4xl font-black text-slate-900 dark:text-white tracking-tight">تغيير كلمة المرور</h1>
            <p class="text-slate-600 dark:text-slate-400 mt-2 text-lg">أدخل كلمة المرور الحالية والجديدة لتغيير كلمة المرور</p>
        </div>
    </div>

    <!-- Change Password Card -->
    <div class="bg-white dark:bg-slate-800/50 rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden shadow-sm">
        <form asp-action="ChangePassword" method="post" class="p-8 sm:p-12 md:p-16">
            @Html.AntiForgeryToken()

            <div class="max-w-2xl mx-auto space-y-8">
                <!-- Current Password Field -->
                <div class="relative">
                    <label class="absolute top-3 right-4 text-sm font-medium text-slate-600 dark:text-slate-400 z-10" for="current-password">
                        كلمة المرور الحالية
                    </label>
                    <button type="button"
                            class="absolute top-1/2 -translate-y-1/2 left-4 text-slate-600 dark:text-slate-400 hover:text-slate-800 dark:hover:text-slate-300 cursor-pointer z-20"
                            onclick="togglePasswordVisibility('current-password', this)">
                        <span class="material-symbols-outlined">visibility_off</span>
                    </button>
                    <input asp-for="CurrentPassword"
                           class="block w-full rounded-xl border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-800/70 p-4 pb-3 pl-12 pr-4 pt-9 text-right text-base text-slate-900 dark:text-white placeholder:text-slate-500 dark:placeholder:text-slate-400 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
                           id="current-password"
                           placeholder="••••••••"
                           type="password" />
                    <span asp-validation-for="CurrentPassword" class="text-red-600 text-sm mt-1 block"></span>
                </div>

                <!-- New Password Field -->
                <div class="relative">
                    <label class="absolute top-3 right-4 text-sm font-medium text-slate-600 dark:text-slate-400 z-10" for="new-password">
                        كلمة المرور الجديدة
                    </label>
                    <button type="button"
                            class="absolute top-1/2 -translate-y-1/2 left-4 text-slate-600 dark:text-slate-400 hover:text-slate-800 dark:hover:text-slate-300 cursor-pointer z-20"
                            onclick="togglePasswordVisibility('new-password', this)">
                        <span class="material-symbols-outlined">visibility_off</span>
                    </button>
                    <input asp-for="NewPassword"
                           class="block w-full rounded-xl border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-800/70 p-4 pb-3 pl-12 pr-4 pt-9 text-right text-base text-slate-900 dark:text-white placeholder:text-slate-500 dark:placeholder:text-slate-400 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
                           id="new-password"
                           placeholder="••••••••"
                           type="password" />
                    <span asp-validation-for="NewPassword" class="text-red-600 text-sm mt-1 block"></span>
                </div>

                <!-- Confirm New Password Field -->
                <div class="relative">
                    <label class="absolute top-3 right-4 text-sm font-medium text-slate-600 dark:text-slate-400 z-10" for="confirm-new-password">
                        تأكيد كلمة المرور الجديدة
                    </label>
                    <button type="button"
                            class="absolute top-1/2 -translate-y-1/2 left-4 text-slate-600 dark:text-slate-400 hover:text-slate-800 dark:hover:text-slate-300 cursor-pointer z-20"
                            onclick="togglePasswordVisibility('confirm-new-password', this)">
                        <span class="material-symbols-outlined">visibility_off</span>
                    </button>
                    <input asp-for="ConfirmPassword"
                           class="block w-full rounded-xl border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-800/70 p-4 pb-3 pl-12 pr-4 pt-9 text-right text-base text-slate-900 dark:text-white placeholder:text-slate-500 dark:placeholder:text-slate-400 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
                           id="confirm-new-password"
                           placeholder="••••••••"
                           type="password" />
                    <span asp-validation-for="ConfirmPassword" class="text-red-600 text-sm mt-1 block"></span>
                </div>

                <!-- Submit and Cancel Buttons -->
                <div class="pt-6 flex gap-3">
                    <button type="submit"
                            class="flex h-14 flex-1 items-center justify-center rounded-xl bg-primary px-6 text-base font-bold text-white shadow-lg hover:shadow-xl hover:bg-primary/90 transition-all">
                        <span class="material-symbols-outlined ml-2">check</span>
                        تغيير كلمة المرور
                    </button>
                    <a asp-controller="Home" asp-action="Index"
                       class="flex h-14 items-center justify-center rounded-xl border-2 border-slate-300 dark:border-slate-700 px-6 text-base font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-all">
                        إلغاء
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Toggle password visibility
        function togglePasswordVisibility(inputId, button) {
            const input = document.getElementById(inputId);
            const icon = button.querySelector('.material-symbols-outlined');

            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = 'visibility';
            } else {
                input.type = 'password';
                icon.textContent = 'visibility_off';
            }
        }
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}