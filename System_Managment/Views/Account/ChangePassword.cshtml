@model ChangePasswordVM

@{
    ViewData["Title"] = "تغيير كلمة المرور";
}

<div class="relative flex h-auto w-full flex-col group/design-root overflow-x-hidden">

    <!-- Main Content -->
    <main class="flex-grow px-4">
        <div class="flex flex-col items-center pt-8">
            <h1 class="text-stone-900 dark:text-stone-100 tracking-tight text-3xl font-bold leading-tight text-center pb-3">تغيير كلمة المرور</h1>
            <p class="text-stone-600 dark:text-stone-400 text-base font-normal leading-normal pb-8 text-center max-w-sm">أدخل كلمة المرور الحالية والجديدة لتغيير كلمة المرور.</p>
        </div>
        <form asp-action="ChangePassword" method="post" class="flex flex-col gap-4 w-full max-w-md mx-auto">
            @Html.AntiForgeryToken()



            <!-- Current Password Field -->
            <div class="flex flex-col w-full">
                <label class="flex flex-col">
                    <span asp-validation-for="CurrentPassword" class="text-lg" style="color:#FF0000"></span>
                    <p class="text-lg font-medium pb-2 text-text-light dark:text-text-dark">كلمة المرور الحالية</p>
                    <div class="flex w-full flex-1 items-stretch rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800">
                        <input asp-for="CurrentPassword" class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-r-lg bg-transparent text-text-light dark:text-text-dark focus:outline-none focus:ring-0 border-0 h-14 placeholder:text-gray-400 dark:placeholder:text-gray-500 p-4" placeholder="كلمة المرور الحالية" type="password" />
                        <div class="flex items-center justify-center pl-4 text-gray-500 cursor-pointer toggle-password" data-target="CurrentPassword">
                            <span class="material-symbols-outlined">visibility_off</span>
                        </div>
                    </div>
                </label>
            </div>

            <!-- New Password Field -->
            <div class="flex flex-col w-full">
                <label class="flex flex-col">
                    <span asp-validation-for="NewPassword" class="text-lg" style="color:#FF0000"></span>
                    <p class="text-lg font-medium pb-2 text-text-light dark:text-text-dark">كلمة المرور الجديدة</p>
                    <div class="flex w-full flex-1 items-stretch rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800">
                        <input asp-for="NewPassword" class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-r-lg bg-transparent text-text-light dark:text-text-dark focus:outline-none focus:ring-0 border-0 h-14 placeholder:text-gray-400 dark:placeholder:text-gray-500 p-4" placeholder="كلمة المرور الجديدة" type="password" />
                        <div class="flex items-center justify-center pl-4 text-gray-500 cursor-pointer toggle-password" data-target="NewPassword">
                            <span class="material-symbols-outlined">visibility_off</span>
                        </div>
                    </div>
                </label>
            </div>

            <!-- Confirm Password Field -->
            <div class="flex flex-col w-full">
                <label class="flex flex-col">
                    <span asp-validation-for="ConfirmPassword" class="text-lg" style="color:#FF0000"></span>
                    <p class="text-lg font-medium pb-2 text-text-light dark:text-text-dark">تأكيد كلمة المرور الجديدة</p>
                    <div class="flex w-full flex-1 items-stretch rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800">
                        <input asp-for="ConfirmPassword" class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-r-lg bg-transparent text-text-light dark:text-text-dark focus:outline-none focus:ring-0 border-0 h-14 placeholder:text-gray-400 dark:placeholder:text-gray-500 p-4" placeholder="تأكيد كلمة المرور الجديدة" type="password" />
                        <div class="flex items-center justify-center pl-4 text-gray-500 cursor-pointer toggle-password" data-target="ConfirmPassword">
                            <span class="material-symbols-outlined">visibility_off</span>
                        </div>
                    </div>
                </label>
            </div>

            <!-- Submit Button -->
            <div class="flex flex-col items-center mt-8 space-y-4 px-4 pb-8 w-full max-w-md mx-auto">
                <button type="submit" class="flex items-center justify-center w-full h-14 px-6 bg-custom text-white rounded-lg text-lg font-bold shadow-sm hover:bg-custom/90 focus:outline-none focus:ring-2 focus:ring-custom focus:ring-offset-2 dark:focus:ring-offset-background-dark transition-colors duration-200">
                    تغيير كلمة المرور
                </button>
            </div>
        </form>
    </main>
</div>

<script>
    // Password visibility toggle functionality
    document.addEventListener('DOMContentLoaded', function() {
        // Password toggle functionality
        const toggleButtons = document.querySelectorAll('.toggle-password');

        toggleButtons.forEach(button => {
            button.addEventListener('click', function() {
                const targetField = this.getAttribute('data-target');
                const input = document.querySelector(`input[name="${targetField}"]`);
                const icon = this.querySelector('span');

                if (input.type === 'password') {
                    input.type = 'text';
                    icon.textContent = 'visibility';
                } else {
                    input.type = 'password';
                    icon.textContent = 'visibility_off';
                }
            });
        });

</script>