@model PaymentFormVM

@{
    ViewData["Title"] = "تعديل دفعة";
}

<partial name="_PaymentForm" model="Model" />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePartyFields() {
            const partyType = document.getElementById('partyType').value;
            const customerField = document.getElementById('customerField');
            const supplierField = document.getElementById('supplierField');
            const customerSelect = document.getElementById('CustomerId');
            const supplierSelect = document.getElementById('SupplierId');
            const isCustomer = partyType === 'Customer';

            customerField.style.display = isCustomer ? 'block' : 'none';
            supplierField.style.display = isCustomer ? 'none' : 'block';

            if (isCustomer) {
                supplierSelect.value = '';
            } else {
                customerSelect.value = '';
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            document.getElementById('partyType').addEventListener('change', togglePartyFields);
            togglePartyFields();
        });
    </script>
}
