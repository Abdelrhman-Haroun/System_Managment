@using Microsoft.AspNetCore.Mvc.Rendering
@model PaymentFormVM

@{
    var customers = ViewBag.Customers as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
    var suppliers = ViewBag.Suppliers as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
    var isEdit = Model.Id > 0;
}

<div class="mx-auto max-w-3xl space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-black text-slate-900">@(isEdit ? "تعديل دفعة" : "إضافة دفعة")</h1>
            <p class="mt-2 text-slate-600">تحديث الرصيد يتم تلقائياً بمجرد حفظ الدفعة.</p>
        </div>
        <a asp-action="Index" class="rounded-xl bg-slate-100 px-5 py-3 font-bold text-slate-700 transition hover:bg-slate-200">رجوع</a>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <form method="post" class="space-y-6">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="rounded-xl bg-red-50 px-4 py-3 text-sm text-red-700"></div>

            <div class="grid gap-5 md:grid-cols-2">
                <div>
                    <label asp-for="PartyType" class="mb-2 block text-sm font-bold text-slate-700">نوع الجهة</label>
                    <select asp-for="PartyType" id="partyType" class="h-12 w-full rounded-xl border border-slate-300 px-4">
                        <option value="Customer">عميل</option>
                        <option value="Supplier">مورد</option>
                    </select>
                    <span asp-validation-for="PartyType" class="mt-1 block text-sm text-red-600"></span>
                </div>

                <div id="customerField">
                    <label asp-for="CustomerId" class="mb-2 block text-sm font-bold text-slate-700">العميل</label>
                    <select asp-for="CustomerId" asp-items="customers" class="h-12 w-full rounded-xl border border-slate-300 px-4">
                        <option value="">اختر العميل</option>
                    </select>
                    <span asp-validation-for="CustomerId" class="mt-1 block text-sm text-red-600"></span>
                </div>

                <div id="supplierField">
                    <label asp-for="SupplierId" class="mb-2 block text-sm font-bold text-slate-700">المورد</label>
                    <select asp-for="SupplierId" asp-items="suppliers" class="h-12 w-full rounded-xl border border-slate-300 px-4">
                        <option value="">اختر المورد</option>
                    </select>
                    <span asp-validation-for="SupplierId" class="mt-1 block text-sm text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Amount" class="mb-2 block text-sm font-bold text-slate-700">المبلغ</label>
                    <input asp-for="Amount" class="h-12 w-full rounded-xl border border-slate-300 px-4" />
                    <span asp-validation-for="Amount" class="mt-1 block text-sm text-red-600"></span>
                </div>

                <div>
                    <label asp-for="PaymentMethod" class="mb-2 block text-sm font-bold text-slate-700">طريقة الدفع</label>
                    <select asp-for="PaymentMethod" asp-items="Html.GetEnumSelectList<PaymentMethodType>()" class="h-12 w-full rounded-xl border border-slate-300 px-4"></select>
                    <span asp-validation-for="PaymentMethod" class="mt-1 block text-sm text-red-600"></span>
                </div>
            </div>

            <div>
                <label asp-for="Notes" class="mb-2 block text-sm font-bold text-slate-700">ملاحظات</label>
                <textarea asp-for="Notes" rows="4" class="w-full rounded-xl border border-slate-300 px-4 py-3"></textarea>
                <span asp-validation-for="Notes" class="mt-1 block text-sm text-red-600"></span>
            </div>

            <div class="flex justify-end gap-3">
                <a asp-action="Index" class="rounded-xl bg-slate-100 px-5 py-3 font-bold text-slate-700 transition hover:bg-slate-200">إلغاء</a>
                <button type="submit" class="rounded-xl bg-primary px-6 py-3 font-bold text-white transition hover:bg-primary/90">حفظ</button>
            </div>
        </form>
    </div>
</div>
