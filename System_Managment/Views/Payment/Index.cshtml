@model BLL.ViewModels.Payment.PaymentIndexVM
@using DAL.Models

@{
    ViewData["Title"] = "المدفوعات";
    var searchTerm = ViewBag.SearchTerm as string;
    var fromDate = ViewBag.FromDate as DateTime?;
    var toDate = ViewBag.ToDate as DateTime?;
}

<div class="container">
    <!-- Header -->
    <div class="mb-8 flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-4">
            <div class="size-12 text-primary bg-white rounded-xl shadow-sm border border-border-light p-2.5 flex items-center justify-center">
                <span class="material-symbols-outlined text-[28px]">payments</span>
            </div>
            <div>
                <h1 class="text-2xl font-bold text-text-main tracking-tight">إدارة المدفوعات</h1>
                <p class="text-sm text-text-secondary mt-1">سجل موحد للمدفوعات والأرصدة ووسائل الدفع</p>
            </div>
        </div>
        <div class="flex gap-2">
            <a asp-action="Create" class="openCreateDialog px-6 py-2.5 bg-primary hover:bg-primary-dark text-white font-bold rounded-xl shadow-lg transition-all flex items-center gap-2 cursor-pointer">
                <span class="material-symbols-outlined">add</span>
                إضافة دفعة
            </a>
            <a asp-controller="PaymentMethod" asp-action="Index" class="rounded-xl bg-primary px-5 py-3 font-bold text-white flex items-center gap-2">
                <span class="material-symbols-outlined">account_balance_wallet</span>
                وسائل الدفع
            </a>
        </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-6">
        <div class="bg-white rounded-2xl border border-green-200 shadow-sm p-6 flex flex-col">
            <span class="text-sm font-semibold text-text-secondary">إجمالي المقبوضات</span>
            <span class="mt-2 text-3xl font-black text-green-700">@Model.TotalIncoming.ToString("N2") <span class="text-lg font-bold text-green-600/70">ج.م</span></span>
        </div>
        <div class="bg-white rounded-2xl border border-red-200 shadow-sm p-6 flex flex-col">
            <span class="text-sm font-semibold text-text-secondary">إجمالي المدفوعات</span>
            <span class="mt-2 text-3xl font-black text-red-700">@Model.TotalOutgoing.ToString("N2") <span class="text-lg font-bold text-red-600/70">ج.م</span></span>
        </div>
        <div class="bg-white rounded-2xl border border-border-light shadow-sm p-6 flex flex-col">
            <span class="text-sm font-semibold text-text-secondary">إجمالي العمليات</span>
            <span class="mt-2 text-3xl font-black text-text-main">@Model.TotalCount <span class="text-lg font-bold text-text-secondary">عملية</span></span>
        </div>
    </div>
    <!-- Filter -->
    <div class="bg-white rounded-2xl border border-border-light shadow-sm p-6 mb-6">
        <h3 class="text-lg font-bold text-text-main mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">filter_alt</span>
            البحث والتصفية
        </h3>

        <form method="get" class="flex flex-col lg:flex-row gap-4 items-end">

            <!-- Search Input -->
            <div class="flex-1 relative">
                <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                    <span class="material-symbols-outlined text-text-secondary">search</span>
                </div>
                <input type="text"
                       name="searchTerm"
                       value="@searchTerm"
                       placeholder="ابحث باسم الجهة، المرجع، أو السبب..."
                       class="w-full h-11 pl-3 pr-10 rounded-xl border border-border-light bg-background-light text-text-main focus:border-primary focus:ring-primary transition-all" />
            </div>

            <!-- From Date -->
            <div class="w-40 flex flex-col">
                <label class="text-sm font-semibold text-text-secondary mb-1.5 block">
                    من تاريخ
                </label>
                <input type="date"
                       name="fromDate"
                       value="@(fromDate.HasValue? fromDate.Value.ToString("yyyy-MM-dd") : string.Empty)"
                       class="h-11 rounded-xl border border-border-light bg-background-light text-text-main focus:border-primary focus:ring-primary transition-all px-3" />
            </div>

            <!-- To Date -->
            <div class="w-40 flex flex-col">
                <label class="text-sm font-semibold text-text-secondary mb-1.5 block">
                    إلى تاريخ
                </label>
                <input type="date"
                       name="toDate"
                       value="@(toDate.HasValue? toDate.Value.ToString("yyyy-MM-dd") : string.Empty)"
                       class="h-11 rounded-xl border border-border-light bg-background-light text-text-main focus:border-primary focus:ring-primary transition-all px-3" />
            </div>

            <!-- Buttons -->
            <div class="flex gap-2 items-end">
                <button type="submit"
                        class="h-11 px-6 bg-primary hover:bg-primary-dark text-white font-bold rounded-xl transition-all flex items-center justify-center gap-2 whitespace-nowrap">
                    <span class="material-symbols-outlined">search</span>
                    بحث
                </button>

                <a asp-action="Index"
                   class="h-11 px-4 bg-gray-200 hover:bg-gray-300 text-text-main font-bold rounded-xl transition-all flex items-center justify-center">
                    <span class="material-symbols-outlined">refresh</span>
                </a>
            </div>

        </form>
    </div>

    <!-- Balances Section -->
    @if (Model.Balances.Any() && string.IsNullOrWhiteSpace(searchTerm))
    {
        <div class="mb-8">
            <h2 class="text-xl font-bold text-text-main mb-4">ملخص أرصدة الجهات النشطة</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
                @foreach (var balance in Model.Balances.Take(3))
                {
                    <div class="bg-white rounded-2xl border border-border-light shadow-sm p-5 hover:shadow-md transition-shadow">
                        <div class="flex justify-between items-start mb-3">
                            <div>
                                <span class="text-xs font-bold text-text-secondary bg-gray-100 px-2 py-1 rounded-full">@balance.PartyType</span>
                                <h3 class="font-bold text-text-main mt-2">@balance.PartyName</h3>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(balance.TransactionsUrl))
                            {
                                <a href="@balance.TransactionsUrl" class="text-primary hover:bg-primary/10 p-1 rounded transition-colors" title="سجل الحركة">
                                    <span class="material-symbols-outlined text-[20px]">receipt_long</span>
                                </a>
                            }
                        </div>
                        <div class="flex justify-between items-end border-t border-border-light pt-3 mt-3">
                            <div class="flex flex-col">
                                <span class="text-xs text-text-secondary mb-1">الرصيد الحالي</span>
                                <span class="font-bold text-sm @(balance.CurrentBalance > 0 ? "text-red-600" : (balance.CurrentBalance < 0 ? "text-green-600" : "text-text-main"))">@balance.CurrentBalance.ToString("N2") ج.م</span>
                            </div>
                            <div class="flex flex-col text-left">
                                <span class="text-xs text-text-secondary mb-1">إجمالي التعاملات</span>
                                <span class="font-bold text-sm text-text-main">@balance.TotalPayments.ToString("N2") ج.م</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Table -->
    <div class="bg-white rounded-2xl shadow-sm border border-border-light overflow-hidden">
        <div class="border-b border-border-light bg-gray-50/50 px-6 py-4">
            <h2 class="font-bold text-text-main">سجل حركات الدفع</h2>
        </div>
        
        @if (Model.Payments.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50 border-b border-border-light">
                        <tr>
                            <th class="py-4 px-6 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">التاريخ</th>
                            <th class="py-4 px-6 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">المرجع</th>
                            <th class="py-4 px-6 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الجهة</th>
                            <th class="py-4 px-6 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">السبب</th>
                            <th class="py-4 px-6 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">وسيلة الدفع</th>
                            <th class="py-4 px-6 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الرصيد قبل</th>
                            <th class="py-4 px-6 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">المبلغ</th>
                            <th class="py-4 px-6 text-right text-xs font-bold text-text-secondary uppercase tracking-wider">الرصيد بعد</th>
                            <th class="py-4 px-6 text-center text-xs font-bold text-text-secondary uppercase tracking-wider">الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border-light">
                        @foreach (var payment in Model.Payments)
                        {
                            <tr class="hover:bg-gray-50/50 transition-colors">
                                <td class="py-4 px-6 text-sm text-text-secondary">
                                    @payment.PaymentDate.ToString("dd/MM/yyyy")
                                </td>
                                <td class="py-4 px-6 text-sm font-bold text-primary">
                                    @payment.ReferenceNumber
                                </td>
                                <td class="py-4 px-6 text-sm font-medium text-text-main">
                                    <div class="flex flex-col">
                                        <span>@payment.PartyName</span>
                                        <span class="text-xs text-text-secondary">@payment.PartyType</span>
                                    </div>
                                </td>
                                <td class="py-4 px-6 text-sm text-text-secondary max-w-[200px] truncate" title="@payment.Reason">
                                    @payment.Reason
                                </td>
                                <td class="py-4 px-6 text-sm text-text-secondary">
                                    <div class="flex items-center gap-1">
                                        <span class="material-symbols-outlined text-[16px]">account_balance_wallet</span>
                                        @payment.PaymentSourceName
                                    </div>
                                </td>
                                <td class="py-4 px-6 text-sm text-text-secondary font-mono">
                                    @payment.BalanceBefore.ToString("N2")
                                </td>
                                <td class="py-4 px-6 text-sm font-bold font-mono">
                                    @if (payment.IsIncoming)
                                    {
                                        <span class="inline-flex items-center gap-1 text-green-700 bg-green-50 px-2 py-1 rounded-lg">
                                            <span class="material-symbols-outlined text-[14px]">arrow_downward</span>
                                            @payment.Amount.ToString("N2")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1 text-red-700 bg-red-50 px-2 py-1 rounded-lg">
                                            <span class="material-symbols-outlined text-[14px]">arrow_upward</span>
                                            @payment.Amount.ToString("N2")
                                        </span>
                                    }
                                </td>
                                <td class="py-4 px-6 text-sm font-bold text-text-main font-mono">
                                    @payment.BalanceAfter.ToString("N2")
                                </td>
                                <td class="py-4 px-6 text-center">
                                    <div class="flex items-center justify-center gap-2">
                                        <a href="@Url.Action("Print", new { id = payment.Id })" target="_blank"
                                           class="text-slate-600 hover:text-slate-800 p-2 hover:bg-slate-100 rounded-lg transition-all"
                                           title="طباعة">
                                            <span class="material-symbols-outlined text-xl">print</span>
                                        </a>

                                        @if (!string.IsNullOrWhiteSpace(payment.RelatedTransactionsUrl))
                                        {
                                            <a href="@payment.RelatedTransactionsUrl"
                                               class="text-blue-600 hover:text-blue-800 p-2 hover:bg-blue-100 rounded-lg transition-all"
                                               title="سجل الحركة">
                                                <span class="material-symbols-outlined text-xl">history</span>
                                            </a>
                                        }

                                        <a asp-action="Edit" asp-route-id="@payment.Id"
                                           class="openEditDialog p-2 text-primary hover:bg-primary/10 rounded-lg transition-all cursor-pointer"
                                           title="تعديل">
                                            <span class="material-symbols-outlined text-[20px]">edit</span>
                                        </a>

                                        <button type="button" onclick="deletePayment(@payment.Id)"
                                                class="p-2 text-red-600 hover:bg-red-50 rounded-lg transition-all"
                                                title="حذف">
                                            <span class="material-symbols-outlined text-[20px]">delete</span>
                                        </button>
                                        <form id="deleteForm_@payment.Id" method="post" asp-action="Delete" asp-route-id="@payment.Id" style="display:none;">
                                            @Html.AntiForgeryToken()
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-12 text-center">
                <span class="material-symbols-outlined text-gray-400 text-6xl mb-4">payments</span>
                <p class="text-text-secondary text-lg font-medium mb-2">لا توجد مدفوعات</p>
                <p class="text-text-secondary text-sm">ابدأ بإضافة دفعة جديدة لتسجيلها في النظام</p>
                <a asp-action="Create" class="openCreateDialog inline-block mt-4 px-6 py-2.5 bg-primary hover:bg-primary-dark text-white font-bold rounded-xl transition-all cursor-pointer">
                    إضافة دفعة
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function deletePayment(id) {
            Swal.fire({
                title: 'هل أنت متأكد؟',
                text: "سيتم حذف الدفعة وإعادة الأرصدة إلى حالتها السابقة!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#2a7f40',
                cancelButtonColor: '#d33',
                confirmButtonText: 'نعم، احذف',
                cancelButtonText: 'إلغاء'
            }).then((result) => {
                if (result.isConfirmed) {
                    const form = document.getElementById('deleteForm_' + id);
                    if (form) {
                        const formData = new FormData(form);
                        // Convert to Ajax delete to avoid page reload, utilizing _Layout and site.js alerts if needed
                        $.ajax({
                            url: form.action,
                            type: 'POST',
                            data: formData,
                            processData: false,
                            contentType: false,
                            success: function (res) {
                                if (res.success) {
                                    Swal.fire('تم بنجاح!', res.message, 'success').then(() => location.reload());
                                } else {
                                    Swal.fire('خطأ', res.message || 'حدث خطأ أثناء الحذف', 'error');
                                }
                            },
                            error: function () {
                                Swal.fire('خطأ', 'تعذر الاتصال بالخادم.', 'error');
                            }
                        });
                    }
                }
            });
        }
    </script>
}
