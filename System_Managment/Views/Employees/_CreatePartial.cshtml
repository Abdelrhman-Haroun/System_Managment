@model BLL.ViewModels.Employee.CreateEmployeeVM

<div class="bg-white dark:bg-slate-800 rounded-3xl shadow-2xl w-full max-w-3xl mx-auto overflow-y-auto">
    <div class="flex items-center justify-between p-6 border-b border-slate-200 dark:border-slate-700">
        <h2 class="text-2xl font-bold">إضافة موظف</h2>
        <button type="button" class="closeDialog text-slate-700 hover:text-red-600"><span class="material-symbols-outlined text-3xl">close</span></button>
    </div>
    <div class="p-8 pt-6">
        <form id="createEmployeeForm" class="grid grid-cols-1 md:grid-cols-2 gap-6">
            @Html.AntiForgeryToken()
            <div><label class="block text-sm font-semibold mb-2">الاسم</label><input asp-for="Name" class="w-full h-14 px-5 rounded-xl border" /></div>
            <div><label class="block text-sm font-semibold mb-2">الهاتف</label><input asp-for="PhoneNumber" class="w-full h-14 px-5 rounded-xl border" /></div>
            <div><label class="block text-sm font-semibold mb-2">الراتب</label><input asp-for="Salary" type="number" step="0.01" class="w-full h-14 px-5 rounded-xl border" /></div>
            <div><label class="block text-sm font-semibold mb-2">نوع الموظف</label><select asp-for="EmployeeTypeId" asp-items="ViewBag.EmployeeTypes" class="w-full h-14 px-5 rounded-xl border"><option value="">اختر النوع...</option></select></div>
            <div><label class="block text-sm font-semibold mb-2">المسمى الوظيفي</label><input asp-for="Position" class="w-full h-14 px-5 rounded-xl border" /></div>
            <div><label class="block text-sm font-semibold mb-2">تاريخ التعيين</label><input asp-for="HireDate" type="date" class="w-full h-14 px-5 rounded-xl border" /></div>
            <div class="md:col-span-2"><label class="block text-sm font-semibold mb-2">ملاحظات</label><textarea asp-for="Notes" class="w-full rounded-xl border p-4 min-h-[120px]"></textarea></div>
            <div class="md:col-span-2 flex items-center gap-3"><input asp-for="IsActive" /><label asp-for="IsActive">نشط</label></div>
            <div class="md:col-span-2"><button type="submit" class="w-full h-14 bg-primary hover:bg-primary/90 text-white font-bold rounded-xl">حفظ الموظف</button></div>
        </form>
    </div>
</div>
<script>
    $('#createEmployeeForm').on('submit', function (e) {
        e.preventDefault();
        $.ajax({
            url: '@Url.Action("Create", "Employees")',
            type: 'POST',
            data: new FormData(this),
            processData: false,
            contentType: false,
            success: function (res) {
                if (res.success) Swal.fire({ icon: 'success', title: 'تم', text: res.message }).then(() => location.reload());
                else Swal.fire({ icon: 'error', title: 'خطأ', text: res.message });
            }
        });
    });
</script>
